---
import Layout from '~/layouts/PageLayout.astro';
import ROICalculator from '~/components/widgets/ROICalculator.astro';
import type { MetaData } from '~/types';

interface Props {
  metadata: MetaData;
  title?: string;
  content: string;
  calculatorRootId?: string;
  width?: 'normal' | 'wide';
}

const { metadata, title, content, calculatorRootId, width = 'normal' } = Astro.props;
const calculatorMarker = '<div id="wsai-savings-1" class="wsai-sav-root"></div>';
const parts = calculatorRootId ? content.split(calculatorMarker) : [content];
---

<Layout metadata={metadata}>
  <section class="bg-section px-6 py-14 sm:px-8 lg:px-12">
    <div class:list={['mx-auto', width === 'wide' ? 'max-w-6xl' : 'max-w-4xl']}>
      {
        title && (
          <h1 class="mb-8 text-center font-heading text-4xl font-bold tracking-tight text-heading md:text-5xl">
            {title}
          </h1>
        )
      }
      <div class="worksmart-reference-content rounded-2xl bg-card p-6 shadow-card ring-1 ring-border sm:p-8 lg:p-10">
        <Fragment set:html={parts[0]} />
        {
          calculatorRootId && parts.length > 1 && (
            <div class="my-8 rounded-xl border border-default bg-section p-4 sm:p-6">
              <ROICalculator rootId={calculatorRootId} />
            </div>
          )
        }
        {calculatorRootId && parts.length > 1 && <Fragment set:html={parts.slice(1).join(calculatorMarker)} />}
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  .worksmart-reference-content {
    font-size: var(--aw-text-body, 1rem);
  }

  .worksmart-reference-content,
  .worksmart-reference-content p,
  .worksmart-reference-content li,
  .worksmart-reference-content td,
  .worksmart-reference-content th {
    color: var(--aw-color-text-default);
    font-family:
      Ubuntu,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      'Segoe UI',
      sans-serif;
    line-height: var(--aw-leading-body, 1.7);
  }

  .worksmart-reference-content :where(h1, h2, h3, h4) {
    color: var(--aw-color-text-heading);
    font-family:
      'Work Sans',
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      'Segoe UI',
      sans-serif;
    font-weight: 700;
    line-height: 1.2;
    margin-block: 1.5rem 0.75rem;
  }

  .worksmart-reference-content h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
  }
  .worksmart-reference-content h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
  }
  .worksmart-reference-content h3 {
    font-size: clamp(1.25rem, 3vw, 1.75rem);
  }

  .worksmart-reference-content p {
    margin-block: 1rem;
  }
  .worksmart-reference-content ul,
  .worksmart-reference-content ol {
    margin: 1rem 0 1.5rem 1.5rem;
    padding-left: 1rem;
  }
  .worksmart-reference-content ul {
    list-style: disc;
  }
  .worksmart-reference-content ol {
    list-style: decimal;
  }
  .worksmart-reference-content li {
    margin-block: 0.4rem;
  }
  .worksmart-reference-content strong {
    font-weight: 700;
  }
  .worksmart-reference-content em {
    font-style: italic;
  }

  .worksmart-reference-content a {
    color: var(--aw-color-link);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: var(--aw-color-secondary);
    text-underline-offset: 0.2em;
  }

  .worksmart-reference-content img {
    border-radius: 1rem;
    height: auto;
    max-width: 100%;
  }

  .worksmart-reference-content figure {
    margin-block: 1.5rem;
  }
  .worksmart-reference-content iframe {
    width: 100%;
    max-width: 100%;
  }

  .worksmart-reference-content table {
    border-collapse: collapse;
    display: block;
    margin-block: 1.5rem;
    overflow-x: auto;
    width: 100%;
  }

  .worksmart-reference-content th,
  .worksmart-reference-content td {
    border: 1px solid var(--aw-color-border);
    padding: 0.75rem;
    text-align: left;
  }

  .worksmart-reference-content th {
    background: var(--aw-color-bg-brand);
    color: var(--aw-brand-white);
    font-family: 'Work Sans', system-ui, sans-serif;
  }

  .worksmart-reference-content .wp-block-button__link,
  .worksmart-reference-content a.wp-block-button__link {
    background: var(--aw-color-accent, #ff7700);
    border: 1px solid var(--aw-color-accent, #ff7700);
    border-radius: 0.5rem;
    color: var(--aw-brand-white);
    display: inline-flex;
    font-weight: 700;
    justify-content: center;
    margin: 0.35rem;
    padding: 0.75rem 1.25rem;
    text-decoration: none;
  }

  .worksmart-reference-content .wp-block-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-block: 1.5rem;
  }

  .worksmart-reference-content .wp-block-columns {
    display: grid;
    gap: 1.5rem;
    margin-block: 1.5rem;
  }

  @media (min-width: 768px) {
    .worksmart-reference-content .wp-block-columns {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .worksmart-reference-content .wp-block-columns:has(.wp-block-column:nth-child(3)) {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .worksmart-reference-content .wp-block-group[style*='border'],
  .worksmart-reference-content .wp-block-themeisle-blocks-flip,
  .worksmart-reference-content details {
    border: 1px solid var(--aw-color-border);
    border-radius: 0.85rem;
    background: var(--aw-color-bg-card-elevated);
    padding: 1rem;
  }

  .worksmart-reference-content details + details {
    margin-top: 0.75rem;
  }
  .worksmart-reference-content summary {
    cursor: pointer;
    color: var(--aw-color-text-heading);
    font-family: 'Work Sans', system-ui, sans-serif;
  }
</style>
