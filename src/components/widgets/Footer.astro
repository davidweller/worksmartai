---
import { Icon } from 'astro-icon/components';
import logoMark from '~/assets/images/New Logo.png';

import type { FooterColumn, FooterLink } from '~/navigation';

export interface Props {
  columns: FooterColumn[];
  legalLinks: FooterLink[];
  contactEmail: string;
  linkedInUrl: string;
  healthCheckHref: string;
}

const { columns, legalLinks, contactEmail, linkedInUrl, healthCheckHref } = Astro.props;
---

<footer class="bg-[#012B42] px-6 py-12 text-white sm:px-8 lg:px-12 not-prose" no-intersect>
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-10 lg:grid-cols-[1fr_1fr_1fr_1.1fr]">
      {
        columns.map((column) => (
          <nav aria-label={column.title}>
            <h2 class="font-heading text-sm font-bold text-white">{column.title}</h2>
            <div class="mt-2 h-0.5 w-10 rounded-full bg-[#FF7700]" aria-hidden="true" />
            <ul class="mt-5 space-y-3">
              {column.links.map((link) => (
                <li>
                  <a href={link.href} class="font-sans text-sm text-white/65 transition hover:text-white">
                    {link.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
      <div>
        <h2 class="font-heading text-sm font-bold text-white">Get in touch</h2>
        <div class="mt-2 h-0.5 w-10 rounded-full bg-[#FF7700]" aria-hidden="true"></div>
        <a
          href={`mailto:${contactEmail}`}
          class="mt-5 inline-flex font-sans text-sm text-white/75 transition hover:text-white"
        >
          {contactEmail}
        </a>
        <div class="mt-5">
          <a
            href={linkedInUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 font-sans text-sm text-white/65 transition hover:text-white"
          >
            <Icon name="tabler:brand-linkedin" class="h-5 w-5" aria-hidden="true" />
            LinkedIn
          </a>
        </div>
        <a
          href={healthCheckHref}
          class="mt-6 inline-flex items-center justify-center rounded-full border border-[#FF7700] bg-[#FF7700] px-5 py-2.5 font-heading text-sm font-bold text-white transition hover:border-[#e55f00] hover:bg-[#e55f00]"
        >
          Book Your AI Capability Check
        </a>
      </div>
    </div>

    <div class="mt-12 border-t border-white/10 pt-8">
      <a href="/" class="inline-flex items-center gap-3" aria-label="WorkSmart-AI home">
        <img
          src={logoMark.src}
          alt=""
          width={logoMark.width}
          height={logoMark.height}
          class="h-10 w-10 shrink-0"
          loading="lazy"
          decoding="async"
          aria-hidden="true"
        />
        <span class="font-heading text-xl font-bold text-white">WorkSmart-AI</span>
      </a>
      <nav class="mt-8" aria-label="Legal links">
        <ul class="flex flex-wrap gap-x-5 gap-y-2">
          {
            legalLinks.map((link) => (
              <li>
                <a href={link.href} class="font-sans text-xs text-white/45 transition hover:text-white/75">
                  {link.text}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <p class="mt-5 font-sans text-xs text-white/40">&copy; WorkSmart-AI. All rights reserved.</p>
    </div>
  </div>
</footer>
