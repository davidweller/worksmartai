---
interface Props {
  rootId?: string;
}

const { rootId = 'wsai-roi-calculator' } = Astro.props;

const bookingsUrl = 'https://outlook.office.com/book/BookaMSTeamscallwithus@worksmart-ai.co.uk/?ismsaljsauthenabled';
---

<section class="wsai-sav-root">
  <div class="wsai-sav" id={rootId}>
    <header class="wsai-hero">
      <h2 class="wsai-hero-title">How much could you save with AI?</h2>
      <ol class="wsai-steps" aria-label="Calculator steps">
        <li class="wsai-step">
          <span class="wsai-step-badge" aria-hidden="true">1</span>
          <span class="wsai-step-label">Enter your staff count</span>
        </li>
        <li class="wsai-step-connector" aria-hidden="true"></li>
        <li class="wsai-step">
          <span class="wsai-step-badge" aria-hidden="true">2</span>
          <span class="wsai-step-label">Set your average salary</span>
        </li>
        <li class="wsai-step-connector" aria-hidden="true"></li>
        <li class="wsai-step">
          <span class="wsai-step-badge" aria-hidden="true">3</span>
          <span class="wsai-step-label">Choose your adoption level</span>
        </li>
      </ol>
    </header>

    <div class="wsai-banner">
      <div class="wsai-banner-main">
        <div class="wsai-banner-eyebrow">Annual saving</div>
        <div class="wsai-banner-value" id={`${rootId}-banner-annual`}>£0</div>
        <p class="wsai-banner-sub" id={`${rootId}-banner-sub`}>If 0 staff each reclaim ~0 hrs/week</p>
        <a class="wsai-banner-info" href="/how-our-calculator-works/">
          <svg class="wsai-info-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"></circle>
            <path d="M8 7v5M8 4.5v.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
          </svg>
          How we calculate this
        </a>
      </div>
      <div class="wsai-banner-cta-wrap">
        <a class="wsai-banner-cta" href={bookingsUrl} target="_blank" rel="noopener noreferrer">
          Discuss your saving →
        </a>
      </div>
    </div>

    <div class="wsai-card">
      <div class="wsai-grid">
        <div class="wsai-panel">
          <h3 class="wsai-panel-kicker">Your organisation</h3>

          <div id={`${rootId}-simple-controls`} class="wsai-simple-controls">
            <div class="wsai-field">
              <div class="wsai-label">
                <span>Number of employees</span><span class="wsai-val-navy" id={`${rootId}-staff-val`}>20</span>
              </div>
              <input id={`${rootId}-staff`} class="wsai-range" type="range" min="5" max="250" step="1" value="20" />
            </div>

            <div class="wsai-field">
              <div class="wsai-label">
                <span>Average annual salary</span><span class="wsai-val-navy" id={`${rootId}-salary-val`}>£39,000</span>
              </div>
              <input
                id={`${rootId}-salary`}
                class="wsai-range"
                type="range"
                min="20000"
                max="120000"
                step="1000"
                value="39000"
              />
            </div>
          </div>

          <div class="wsai-field">
            <div class="wsai-label wsai-label-single"><span>Adoption level</span></div>
            <div class="wsai-adopt" role="group" aria-label="Adoption level">
              <button type="button" class="wsai-chip" data-adopt="beginner">
                <span class="wsai-chip-title">Just starting out</span>
                <span class="wsai-chip-sub">A few staff experimenting with AI tools</span>
              </button>
              <button type="button" class="wsai-chip" data-adopt="intermediate">
                <span class="wsai-chip-title">Building momentum</span>
                <span class="wsai-chip-sub">Teams regularly using AI in their work</span>
              </button>
              <button type="button" class="wsai-chip" data-adopt="advanced">
                <span class="wsai-chip-title">Fully embedded</span>
                <span class="wsai-chip-sub">AI woven into daily workflows</span>
              </button>
            </div>
          </div>

          <details class="wsai-advanced-details">
            <summary class="wsai-advanced-summary">Advanced breakdown by role</summary>
            <div class="wsai-advanced-grid">
              <div class="wsai-advanced-col">
                <h4 class="wsai-col-h">Academic staff</h4>
                <div class="wsai-field wsai-field-adv">
                  <label class="wsai-label-adv" for={`${rootId}-adv-edu`}>Educators</label><input
                    type="number"
                    data-role-key="edu"
                    id={`${rootId}-adv-edu`}
                    class="wsai-input-adv"
                    placeholder="0"
                    min="0"
                  />
                </div>
                <div class="wsai-field wsai-field-adv">
                  <label class="wsai-label-adv" for={`${rootId}-adv-res`}>Researchers</label><input
                    type="number"
                    data-role-key="res"
                    id={`${rootId}-adv-res`}
                    class="wsai-input-adv"
                    placeholder="0"
                    min="0"
                  />
                </div>
                <div class="wsai-field wsai-field-adv">
                  <label class="wsai-label-adv" for={`${rootId}-adv-eduRes`}>Educator-Researchers</label><input
                    type="number"
                    data-role-key="eduRes"
                    id={`${rootId}-adv-eduRes`}
                    class="wsai-input-adv"
                    placeholder="0"
                    min="0"
                  />
                </div>
              </div>
              <div class="wsai-advanced-col">
                <h4 class="wsai-col-h">Professional services</h4>
                <div class="wsai-field wsai-field-adv">
                  <label class="wsai-label-adv" for={`${rootId}-adv-stu`}>Student Services / HR / Registry</label><input
                    type="number"
                    data-role-key="stu"
                    id={`${rootId}-adv-stu`}
                    class="wsai-input-adv"
                    placeholder="0"
                    min="0"
                  />
                </div>
                <div class="wsai-field wsai-field-adv">
                  <label class="wsai-label-adv" for={`${rootId}-adv-lib`}>Library & Learning Resources</label><input
                    type="number"
                    data-role-key="lib"
                    id={`${rootId}-adv-lib`}
                    class="wsai-input-adv"
                    placeholder="0"
                    min="0"
                  />
                </div>
                <div class="wsai-field wsai-field-adv">
                  <label class="wsai-label-adv" for={`${rootId}-adv-fin`}>Finance</label><input
                    type="number"
                    data-role-key="fin"
                    id={`${rootId}-adv-fin`}
                    class="wsai-input-adv"
                    placeholder="0"
                    min="0"
                  />
                </div>
                <div class="wsai-field wsai-field-adv">
                  <label class="wsai-label-adv" for={`${rootId}-adv-it`}>IT Services</label><input
                    type="number"
                    data-role-key="it"
                    id={`${rootId}-adv-it`}
                    class="wsai-input-adv"
                    placeholder="0"
                    min="0"
                  />
                </div>
                <div class="wsai-field wsai-field-adv">
                  <label class="wsai-label-adv" for={`${rootId}-adv-mar`}>Marketing & Comms</label><input
                    type="number"
                    data-role-key="mar"
                    id={`${rootId}-adv-mar`}
                    class="wsai-input-adv"
                    placeholder="0"
                    min="0"
                  />
                </div>
                <div class="wsai-field wsai-field-adv">
                  <label class="wsai-label-adv" for={`${rootId}-adv-est`}>Estates / Facilities</label><input
                    type="number"
                    data-role-key="est"
                    id={`${rootId}-adv-est`}
                    class="wsai-input-adv"
                    placeholder="0"
                    min="0"
                  />
                </div>
                <div class="wsai-field wsai-field-adv">
                  <label class="wsai-label-adv" for={`${rootId}-adv-oth`}>Other Admin</label><input
                    type="number"
                    data-role-key="oth"
                    id={`${rootId}-adv-oth`}
                    class="wsai-input-adv"
                    placeholder="0"
                    min="0"
                  />
                </div>
              </div>
            </div>
          </details>
        </div>

        <div class="wsai-panel wsai-panel-results">
          <h3 class="wsai-panel-kicker">Your potential savings</h3>

          <div class="wsai-result-block">
            <h4 class="wsai-group-label">Financial impact</h4>
            <div class="wsai-metrics wsai-metrics-fin">
              <article class="wsai-metric-card">
                <div class="wsai-metric-label">Annual saving</div>
                <div class="wsai-metric-value wsai-metric-navy" id={`${rootId}-k-savings`}>£0</div>
                <div class="wsai-metric-foot">Estimated financial impact this year</div>
              </article>
              <article class="wsai-metric-card">
                <div class="wsai-metric-label">5-year total</div>
                <div class="wsai-metric-value wsai-metric-navy" id={`${rootId}-k-proj`}>£0</div>
                <div class="wsai-metric-foot">Projected cumulative savings</div>
              </article>
            </div>
          </div>

          <div class="wsai-result-block wsai-result-block-prod">
            <h4 class="wsai-group-label">Productivity impact</h4>
            <div class="wsai-metrics wsai-metrics-prod-top">
              <article class="wsai-metric-card">
                <div class="wsai-metric-label">Hours saved / week</div>
                <div class="wsai-metric-value wsai-metric-navy" id={`${rootId}-k-hours`}>0 hrs</div>
                <div class="wsai-metric-foot">Across your whole team</div>
              </article>
              <article class="wsai-metric-card">
                <div class="wsai-metric-label">Capacity freed up</div>
                <div class="wsai-metric-value wsai-metric-green" id={`${rootId}-k-fte`}>0.0 roles</div>
                <div class="wsai-metric-foot">Equivalent full-time roles of capacity</div>
              </article>
            </div>
            <article class="wsai-metric-card wsai-metric-card-wide">
              <div class="wsai-metric-label">Productivity gain</div>
              <div class="wsai-metric-value wsai-metric-green" id={`${rootId}-k-prod`}>0%</div>
              <div class="wsai-metric-foot">Average increase per staff member</div>
            </article>
          </div>
        </div>
      </div>
    </div>

    <aside class="wsai-callout" aria-labelledby={`${rootId}-result-heading`}>
      <div class="wsai-callout-inner">
        <p id={`${rootId}-result-heading`} class="wsai-callout-kicker">Your result</p>
        <p class="wsai-callout-text">
          Your institution could save <strong id={`${rootId}-callout-save`}>£0</strong> this year — equivalent to freeing
          up
          <strong id={`${rootId}-callout-fte`}>0</strong> full-time staff members.
        </p>
      </div>
    </aside>

    <aside class="wsai-callout wsai-callout--get-in-touch" aria-labelledby={`${rootId}-cta-lead`}>
      <div class="wsai-callout-inner wsai-callout-inner--get-in-touch">
        <div class="wsai-copy-actions">
          <p class="wsai-copy-actions-lead" id={`${rootId}-cta-lead`}>
            To discuss how you can start seeing ROI in your adoption, reach out now.
          </p>
          <a class="wsai-pill-btn" href="/contact-us/">Get in Touch</a>
        </div>
      </div>
    </aside>

    <section class="wsai-methodology-callout" id="methodology" aria-labelledby={`${rootId}-methodology-heading`}>
      <div class="wsai-methodology-callout-inner">
        <h2 id={`${rootId}-methodology-heading`} class="wsai-methodology-h">How our calculator works</h2>
        <p class="wsai-methodology-p">
          Figures combine role-level eligibility, adoption level, and efficiency uplift assumptions drawn from research
          into AI in higher education. For the full methodology, assumptions, and limitations of this calculator:
        </p>
        <p class="wsai-methodology-cta">
          <a class="wsai-methodology-link" href="/how-our-calculator-works/">Read more here →</a>
        </p>
      </div>
    </section>
  </div>
</section>

<style>
  .wsai-sav-root {
    background: #f8f8f8;
    padding: 12px 0 32px;
  }

  .wsai-sav {
    --color-background-secondary: #f3f5f7;
    --line: #e2e5ea;
    --muted: #f2f4f7;
    --ink: #1b0101;
    --sub: #64748b;
    --navy: #015887;
    --accent: #ff7700;
    --green: #1a7a4a;
    --slider-thumb-size: 22px;
    --slider-track-height: 12px;
    --fill-percent: 50%;
    font-family:
      'Ubuntu',
      system-ui,
      -apple-system,
      Segoe UI,
      Roboto,
      Arial,
      sans-serif;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 16px;
    color: var(--ink);
    font-size: var(--aw-text-body, 1rem);
    line-height: var(--aw-leading-body, 1.7);
  }

  .wsai-hero {
    text-align: center;
    margin-bottom: 24px;
  }

  .wsai-hero-title {
    margin: 0;
    color: var(--navy);
    font-family:
      'Work Sans',
      system-ui,
      -apple-system,
      Segoe UI,
      Roboto,
      Arial,
      sans-serif;
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.15;
    font-weight: 700;
  }

  .wsai-steps {
    list-style: none;
    margin: 20px 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0;
    max-width: 920px;
    margin-left: auto;
    margin-right: auto;
  }

  .wsai-step {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 4px 0;
  }

  .wsai-step-badge {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--navy);
    color: #fff;
    font-family: 'Work Sans', system-ui, sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    line-height: 28px;
    text-align: center;
  }

  .wsai-step-label {
    font-size: 0.95rem;
    color: var(--ink);
    text-align: left;
  }

  .wsai-step-connector {
    flex: 1 1 24px;
    min-width: 16px;
    max-width: 48px;
    height: 2px;
    background: #cbd5e1;
    margin: 0 6px;
  }

  .wsai-banner {
    background: var(--navy);
    border-radius: 12px;
    padding: 22px 24px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 24px;
  }

  .wsai-banner-main {
    flex: 1 1 260px;
    min-width: 0;
  }

  .wsai-banner-eyebrow {
    font-size: 0.75rem;
    line-height: 1.4;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #ffffff;
    font-family: 'Work Sans', system-ui, sans-serif;
    font-weight: 700;
  }

  .wsai-banner-value {
    margin-top: 6px;
    font-size: clamp(32px, 5vw, 44px);
    line-height: 1.15;
    font-weight: 700;
    color: #ffffff;
    font-family: 'Work Sans', system-ui, sans-serif;
  }

  .wsai-banner-sub {
    margin: 8px 0 0;
    font-size: 1rem;
    color: #ffffff;
    line-height: 1.5;
  }

  .wsai-banner-info {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 12px;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: underline;
    font-weight: 600;
    font-family: 'Work Sans', system-ui, sans-serif;
  }

  .wsai-banner-info:hover {
    color: #ffffff;
  }

  .wsai-info-icon {
    flex-shrink: 0;
    opacity: 0.85;
  }

  .wsai-banner-cta-wrap {
    flex-shrink: 0;
  }

  .wsai-banner-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 22px;
    border-radius: 999px;
    border: 2px solid rgba(255, 255, 255, 0.85);
    background: transparent;
    color: #ffffff;
    font-family: 'Work Sans', system-ui, sans-serif;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition:
      background 0.2s ease,
      border-color 0.2s ease;
  }

  .wsai-banner-cta:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: #ffffff;
  }

  .wsai-card {
    background: #ffffff;
    border-radius: 12px;
    box-shadow: 0 4px 24px rgba(1, 88, 135, 0.08);
    padding: 20px 20px 24px;
  }

  .wsai-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .wsai-panel {
    padding: 4px 4px 8px;
    min-width: 0;
  }

  .wsai-panel-kicker {
    margin: 0 0 18px;
    color: var(--sub);
    font-size: 0.75rem;
    line-height: 1.4;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: 'Work Sans', system-ui, sans-serif;
    font-weight: 700;
  }

  .wsai-field {
    margin-bottom: 18px;
  }

  .wsai-label {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
    font-size: 1rem;
    color: #334155;
  }

  .wsai-val-navy {
    color: var(--navy);
    font-weight: 700;
    font-family: 'Work Sans', system-ui, sans-serif;
  }

  .wsai-label-single {
    justify-content: flex-start;
  }

  .wsai-adopt {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .wsai-chip {
    background: #ffffff;
    border: 1px solid #d3d8df;
    padding: 12px 14px;
    border-radius: 9999px;
    cursor: pointer;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-family: inherit;
  }

  .wsai-chip-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    font-family: 'Work Sans', system-ui, sans-serif;
  }

  .wsai-chip-sub {
    font-size: 0.95rem;
    color: #64748b;
    font-weight: 400;
    line-height: 1.45;
  }

  .wsai-chip[aria-pressed='true'] {
    border-color: var(--accent);
    background: #fff8f2;
    box-shadow: 0 0 0 1px var(--accent);
  }

  .wsai-chip[aria-pressed='true'] .wsai-chip-title {
    color: var(--accent);
  }

  .wsai-range {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: var(--slider-thumb-size);
    background: transparent;
    cursor: pointer;
  }

  .wsai-range::-webkit-slider-runnable-track {
    height: var(--slider-track-height);
    border-radius: var(--slider-track-height);
    background: linear-gradient(to right, var(--accent) var(--fill-percent), #e5e7eb var(--fill-percent));
  }

  .wsai-range::-moz-range-track {
    height: var(--slider-track-height);
    border-radius: var(--slider-track-height);
    background: linear-gradient(to right, var(--accent) var(--fill-percent), #e5e7eb var(--fill-percent));
  }

  .wsai-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    margin-top: calc((var(--slider-thumb-size) - var(--slider-track-height)) / -2);
    height: var(--slider-thumb-size);
    width: var(--slider-thumb-size);
    background-color: var(--accent);
    border-radius: 50%;
    border: 2px solid #ffffff;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.25);
  }

  .wsai-range::-moz-range-thumb {
    height: var(--slider-thumb-size);
    width: var(--slider-thumb-size);
    background-color: var(--accent);
    border-radius: 50%;
    border: 2px solid #ffffff;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.25);
  }

  .wsai-simple-controls[disabled='true'] .wsai-range {
    opacity: 0.45;
    pointer-events: none;
  }

  .wsai-advanced-details {
    margin-top: 4px;
  }

  .wsai-advanced-summary {
    cursor: pointer;
    font-size: 1rem;
    color: var(--sub);
    font-weight: 700;
    list-style: none;
  }

  .wsai-advanced-summary::-webkit-details-marker {
    display: none;
  }

  .wsai-advanced-summary::before {
    content: '▶ ';
    font-size: 0.75em;
    margin-right: 2px;
  }

  .wsai-advanced-details[open] .wsai-advanced-summary::before {
    content: '▼ ';
  }

  .wsai-advanced-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    background-color: var(--muted);
    padding: 12px;
    border-radius: 10px;
    margin-top: 12px;
  }

  .wsai-col-h {
    margin: 0 0 8px;
    color: var(--navy);
    font-size: 1rem;
    font-family: 'Work Sans', system-ui, sans-serif;
    font-weight: 700;
  }

  .wsai-field-adv {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
    gap: 10px;
  }

  .wsai-label-adv {
    font-size: 0.95rem;
    color: #374151;
  }

  .wsai-input-adv {
    width: 76px;
    min-width: 76px;
    font-size: 1rem;
    padding: 6px 8px;
    border: 1px solid #d3d8df;
    border-radius: 8px;
    text-align: right;
  }

  .wsai-group-label {
    margin: 0 0 12px;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sub);
    font-family: 'Work Sans', system-ui, sans-serif;
    font-weight: 700;
  }

  .wsai-result-block {
    margin-bottom: 20px;
  }

  .wsai-result-block-prod {
    padding-top: 16px;
    border-top: 1px solid var(--line);
  }

  .wsai-metrics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .wsai-metrics-prod-top {
    margin-bottom: 12px;
  }

  .wsai-metric-card {
    background: var(--color-background-secondary);
    border-radius: 10px;
    padding: 14px;
    border: none;
  }

  .wsai-metric-card-wide {
    grid-column: 1 / -1;
  }

  .wsai-metric-label {
    font-size: 0.72rem;
    line-height: 1.35;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #64748b;
    font-family: 'Work Sans', system-ui, sans-serif;
    font-weight: 700;
  }

  .wsai-metric-value {
    margin-top: 8px;
    font-size: clamp(22px, 3.5vw, 28px);
    line-height: 1.2;
    font-weight: 700;
