<style is:inline>
  @import url('https://fonts.googleapis.com/css2?family=Ubuntu:wght@400;700&family=Work+Sans:wght@400;700&display=swap');

  :root {
    --aw-font-sans: 'Ubuntu';
    --aw-font-serif: 'Ubuntu';
    --aw-font-heading: 'Work Sans';
    /* Body: 1rem tracks html; 18px root is visibly larger than a typical 16px default */
    --aw-text-body: 1rem;
    --aw-leading-body: 1.7;

    --aw-color-primary: rgb(1 88 135);
    --aw-color-secondary: rgb(134 191 226);
    --aw-color-accent: #ff7700;
    /* Slightly darker than accent for button hovers / focus borders (stays on-brand vs Tailwind `orange-600`) */
    --aw-color-accent-hover: #e55f00;

    --aw-color-text-heading: rgb(1 88 135);
    --aw-color-text-default: rgb(27 1 1);
    --aw-color-text-muted: rgb(27 1 1 / 66%);
    --aw-color-bg-page: rgb(248 248 248);
    --aw-color-bg-footer: rgb(226 239 247);

    --aw-color-bg-page-dark: rgb(1 88 135);

    ::selection {
      background-color: rgb(134 191 226 / 60%);
    }
  }

  .dark {
    --aw-font-sans: 'Ubuntu';
    --aw-font-serif: 'Ubuntu';
    --aw-font-heading: 'Work Sans';

    --aw-color-primary: rgb(1 88 135);
    --aw-color-secondary: rgb(134 191 226);
    --aw-color-accent: #ff7700;
    --aw-color-accent-hover: #e55f00;

    --aw-color-text-heading: rgb(248 248 248);
    --aw-color-text-default: rgb(248 248 248);
    --aw-color-text-muted: rgb(248 248 248 / 72%);
    --aw-color-bg-page: rgb(1 88 135);
    --aw-color-bg-footer: rgb(0 62 96);

    ::selection {
      background-color: color-mix(in srgb, var(--aw-color-accent) 35%, transparent);
      color: rgb(248 248 248);
    }
  }

  html {
    font-size: 18px;
  }

  body {
    font-size: var(--aw-text-body);
    line-height: var(--aw-leading-body);
  }

  .prose {
    font-size: var(--aw-text-body);
    line-height: var(--aw-leading-body);
  }
</style>
