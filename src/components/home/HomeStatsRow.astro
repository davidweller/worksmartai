---
const stats = [
  { amount: '290+', title: 'HE use cases mapped' },
  { amount: '12', title: 'Role-specific workshops' },
  { amount: '1.3 hrs', title: 'Saved per person per day' },
  { amount: '34%', title: 'of HE staff say AI stance affects retention' },
];
---

<section
  class="border-y border-[#E0E0E0] bg-[#F8F8F8] px-6 py-10 sm:px-8 lg:px-12"
  style="border-width: 0.5px"
  no-intersect
  aria-label="Key statistics"
>
  <div class="mx-auto grid max-w-6xl grid-cols-2 gap-8 text-center md:grid-cols-4">
    {
      stats.map(({ amount, title }) => (
        <div class="px-2">
          <div class="font-heading text-[28px] font-bold text-[#015887]">{amount}</div>
          <p class="mt-2 font-sans text-xs font-normal normal-case tracking-normal text-[#1B0101]">{title}</p>
        </div>
      ))
    }
  </div>
</section>
