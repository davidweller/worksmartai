---
const institutions = ['University of Exeter', 'University of Bristol', 'Harper Adams University', 'Jisc', 'Advance HE'];
---

<section class="bg-[#013A5A] px-6 py-4 sm:px-8 lg:px-12" no-intersect aria-label="Trusted by">
  <div class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
    <p class="shrink-0 font-sans text-[11px] text-white/40">Trusted by</p>
    <ul class="flex flex-wrap gap-2">
      {
        institutions.map((name) => (
          <li>
            <span class="inline-block rounded-[20px] border border-white/10 bg-white/[0.06] px-3 py-1 font-sans text-[11px] text-white/50">
              {name}
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
