---
const links = [
  { text: 'Privacy Policy', href: '/privacy-policy/' },
  { text: 'Cookie Policy', href: '/cookie-policy/' },
  { text: 'Terms of Service', href: '/terms-of-service/' },
  { text: 'Accessibility Statement', href: '/accessibility-statement/' },
];
---

<footer class="relative border-t border-white/10 bg-[#012B42] not-prose" no-intersect>
  <div class="relative mx-auto max-w-7xl px-4 py-8 sm:px-6">
    <nav aria-label="Footer legal links">
      <ul class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
        {
          links.map(({ text, href }) => (
            <li>
              <a href={href} class="font-sans text-sm text-white/40 transition hover:text-white/60 hover:underline">
                {text}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <p class="mt-6 text-center font-sans text-sm text-white/40">&copy; WorkSmart-AI. All rights reserved.</p>
  </div>
</footer>
