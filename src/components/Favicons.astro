---
import favicon32 from '~/assets/favicons/cropped-New-logo-favicon-32x32.png';
import favicon192 from '~/assets/favicons/cropped-New-logo-favicon-192x192.png';
import appleTouchIcon from '~/assets/favicons/cropped-New-logo-favicon-180x180.png';
---

<link rel="icon" type="image/png" sizes="32x32" href={favicon32.src} />
<link rel="shortcut icon" type="image/png" href={favicon32.src} />
<link rel="apple-touch-icon" sizes="180x180" href={appleTouchIcon.src} />
<link rel="icon" type="image/png" sizes="192x192" href={favicon192.src} />
