---
import { Icon } from 'astro-icon/components';

import { UI } from 'astrowind:config';

export interface Props {
  label?: string;
  class?: string;
  iconClass?: string;
}

const {
  label = 'Toggle between Dark and Light mode',
  class:
    className = 'text-muted hover:text-link-hover hover:bg-[color-mix(in_srgb,var(--aw-color-secondary)_20%,transparent)] focus:outline-none focus:ring-2 focus:ring-focus focus:ring-offset-2 rounded-lg text-sm p-2.5 inline-flex items-center',
  iconClass = 'w-6 h-6',
} = Astro.props;
---

{
  !(UI.theme && UI.theme.endsWith(':only')) && (
    <button type="button" class={className} aria-label={label} data-aw-toggle-color-scheme>
      <Icon name="tabler:moon" class={`${iconClass} dark:hidden`} />
      <Icon name="tabler:sun" class={`${iconClass} hidden dark:inline-block`} />
    </button>
  )
}
