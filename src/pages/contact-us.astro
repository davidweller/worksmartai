---
import Layout from '~/layouts/PageLayout.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Button from '~/components/ui/Button.astro';
import { BOOK_A_CALL_URL } from '~/config/booking';

const metadata = {
  title: 'Contact WorkSmart-AI for AI Training Support Today',
  description:
    'Contact WorkSmart-AI to ask about AI training, consultancy, booking a call or support for your organisation and its practical AI adoption journey today.',
  canonical: '/contact-us/',
};
---

<Layout metadata={metadata}>
  <section class="bg-section px-6 pb-16 pt-12 sm:px-8 sm:pt-14 lg:px-12 lg:pt-16">
    <div class="mx-auto max-w-5xl space-y-8">
      <header class="text-center">
        <h1 class="font-heading text-4xl font-bold tracking-tight text-heading sm:text-5xl">Contact Us</h1>
        <p class="mx-auto mt-4 max-w-2xl text-base text-muted">
          Book a call with us, or send a message below. We'll be in touch shortly.
        </p>
      </header>
      <div class="rounded-2xl bg-card p-6 shadow-card ring-1 ring-border sm:p-8">
        <h2 class="text-2xl font-bold tracking-tight text-heading">Book a call</h2>
        <p class="mt-2 text-muted">Choose a time that works for you and schedule a call on our booking page.</p>
        <div class="mt-6">
          <Button variant="primary" href={BOOK_A_CALL_URL} text="Book a Call" icon="tabler:calendar" />
        </div>
      </div>

      <div class="rounded-2xl bg-card p-6 shadow-card ring-1 ring-border sm:p-6">
        <h2 class="text-2xl font-bold tracking-tight text-heading">Send a message</h2>
        <p class="mt-2 text-muted">Use the form below and our team will get back to you.</p>
        <div class="mt-6">
          <iframe
            src="https://forms.office.com/e/QZi4iD4Sja?embed=true"
            width="100%"
            height="1200"
            class="w-full rounded-xl border-0"
            title="WorkSmart-AI contact form"
            loading="lazy"></iframe>
        </div>
      </div>
    </div>
  </section>
  <Features2
    title="We'll be in touch shortly"
    columns={3}
    items={[
      {
        title: 'Questions',
        description: "Have a question about how we can support your organisation's AI journey?",
        icon: 'tabler:help-circle',
      },
      {
        title: 'AI training support',
        description:
          'Use the form to discuss how WorkSmart-AI could help your staff become more AI-capable, confident and compliant.',
        icon: 'tabler:school',
      },
      {
        title: 'Book a call',
        description: 'If you would rather choose a time directly, use our booking page to schedule a call.',
        icon: 'tabler:calendar',
      },
    ]}
  />
</Layout>
