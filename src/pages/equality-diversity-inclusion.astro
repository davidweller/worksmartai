---
import LegalPage from '~/components/worksmart/LegalPage.astro';

const metadata = {
  title: 'Equality, Diversity and Inclusion Policy | WorkSmart-AI',
  description:
    'Read WorkSmart-AI commitments to inclusive AI training, accessible resources, equal opportunity and respectful delivery for clients and learners everywhere.',
  canonical: '/equality-diversity-inclusion/',
};

const content =
  '<div class="container single-page-container">\n\t<div class="row">\n\t\t\t\t<div class="nv-single-page-wrap col">\n\t\t\t<div class="nv-page-title-wrap nv-big-title" >\n\t<div class="nv-page-title ">\n\t\t<small class="neve-breadcrumbs-wrapper"></small>\t\t<h1>Equality, Diversity, Inclusion</h1>\n\t\t\t\t\t</div>\n</div> \n\t<div class="nv-content-wrap entry-content">\n<h3 class="wp-block-heading">WorkSmart AI Equality, Diversity &amp; Inclusion (EDI) Statement</h3>\n\n\n\n<p>Welcome to WorkSmart AI. These Terms of Service (“Terms”) govern your use of our website, tools, training, and consultancy services. By accessing or using our services, you agree to these Terms. If you do not agree, please do not use our site or services.</p>\n\n\n\n<p>At WorkSmart AI, we believe that digital transformation and AI adoption must be inclusive. We are committed to creating an environment where everyone is respected, valued, and supported to thrive.</p>\n\n\n\n<h2 class="wp-block-heading">1. Our Commitment</h2>\n\n\n\n<ul class="wp-block-list">\n<li>We treat all individuals with <strong>dignity, fairness, and respect</strong>, regardless of age, disability, gender identity, marital status, pregnancy or maternity, race, religion or belief, sex, or sexual orientation.</li>\n\n\n\n<li>We are committed to <strong>equality of opportunity</strong> in all aspects of our work — from training delivery to partnerships and recruitment.</li>\n\n\n\n<li>We design our services to be accessible and inclusive, recognising the diverse needs of staff and learners.</li>\n</ul>\n\n\n\n<h2 class="wp-block-heading">2. In PracticeWe will:</h2>\n\n\n\n<ul class="wp-block-list">\n<li>Develop and deliver training that is inclusive, avoiding bias and promoting accessibility.</li>\n\n\n\n<li>Ensure our website and resources are accessible (aligned with WCAG 2.1 AA standards).</li>\n\n\n\n<li>Consider the needs of different learners, offering flexible formats and support.</li>\n\n\n\n<li>Foster a culture of respect, collaboration, and open dialogue.</li>\n\n\n\n<li>Continuously review our practices to ensure they reflect best practice in EDI.</li>\n</ul>\n\n\n\n<h2 class="wp-block-heading">3. Responsibilities</h2>\n\n\n\n<ul class="wp-block-list">\n<li><strong>Leadership</strong>: WorkSmart AI leadership takes responsibility for upholding EDI principles in strategy and delivery.</li>\n\n\n\n<li><strong>Staff &amp; Associates</strong>: All trainers, facilitators, and consultants are expected to model inclusive behaviour and challenge discrimination where it arises.</li>\n\n\n\n<li><strong>Partners &amp; Clients</strong>: We encourage those we work with to share our commitment to equality, diversity, and inclusion.</li>\n</ul>\n\n\n\n<h2 class="wp-block-heading">4. Continuous Improvement</h2>\n\n\n\n<p>We view EDI as an ongoing journey. We will:</p>\n\n\n\n<ul class="wp-block-list">\n<li>Regularly review our policies and training content.</li>\n\n\n\n<li>Seek feedback from clients and participants to identify areas for improvement.</li>\n\n\n\n<li>Stay informed of legal requirements and sector best practice (e.g. Equality Act 2010, Public Sector Equality Duty).</li>\n</ul>\n\n\n\n<h2 class="wp-block-heading">5. Reporting Concerns</h2>\n\n\n\n<p>If you experience or witness discrimination in relation to our services, please contact us at [Insert contact email]. All reports will be treated seriously and handled confidentially.</p>\n\n\n\n<h2 class="wp-block-heading">6. Review</h2>\n\n\n\n<p>This statement will be reviewed annually and updated to reflect evolving practice and legislation.</p>\n\n\n\n<p>📩 <a href="/contact-us/" data-type="link" data-id="https://worksmart-ai.co.uk/contact-us/">Contact Us</a></p>\n</div>\t\t</div>\n\t\t\t</div>\n</div>';
---

<LegalPage
  metadata={metadata}
  title="Equality, Diversity, Inclusion"
  effectiveDate="20th October 2025"
  content={content}
/>
