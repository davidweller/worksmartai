---
import Layout from '~/layouts/PageLayout.astro';
import ROICalculator from '~/components/widgets/ROICalculator.astro';

const metadata = {
  title: 'WorkSmart-AI | AI skills training and consulting for higher education',
  description:
    'We help staff build confidence, capability and compliance with AI, to ensure digital transformation leads to measurable ROI.',
};
---

<Layout metadata={metadata}>
  <section class="bg-[#f8f8f8] px-6 py-20 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-5xl text-center">
      <h1 class="font-heading text-4xl font-bold leading-tight text-[#015887] sm:text-5xl">
        AI skills training and consulting for higher education.
      </h1>
      <p class="mx-auto mt-6 max-w-3xl text-lg text-slate-700">
        We help staff build confidence, capability and compliance with AI, to ensure digital transformation leads to
        measurable ROI.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-md border border-[#ff7700] bg-[#ff7700] px-6 py-3 font-semibold text-white transition hover:bg-orange-600 hover:border-orange-600"
        >
          Book a Call
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-md border border-[#015887] bg-transparent px-6 py-3 font-semibold text-[#015887] transition hover:bg-[#015887] hover:text-white"
        >
          Email Us
        </a>
      </div>
    </div>
  </section>

  <section class="w-full bg-[#f8f8f8] px-6 py-16 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-6xl">
      <ROICalculator rootId="roi-calculator-home" />
    </div>
  </section>

  <section class="bg-[#f8f8f8] px-6 py-20 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="font-heading text-3xl font-bold text-[#015887] sm:text-4xl">Struggling to see ROI from AI? You're not alone.</h2>
      <p class="mt-6 text-lg leading-relaxed text-slate-700">
        Organisations are overwhelmed with AI hype, staff feel anxious, and leaders can't see ROI. WorkSmart-AI
        provides people-first training that turns AI adoption into measurable savings, confident staff, and more
        productive organisations. With over a decade of experience working with universities in edtech, digital skills
        and AI, we're confident in helping you achieve your outcomes.
      </p>
    </div>
  </section>

  <section class="bg-[#015887] px-6 py-16 sm:px-8 lg:px-12">
    <blockquote class="mx-auto max-w-5xl border-l-4 border-[#ff7700] pl-6 text-2xl font-medium leading-relaxed text-white">
      ...the full potential of AI can only be unlocked if the staff are well-trained and confident in using these new
      technologies responsibly.
      <footer class="mt-6 text-base font-normal text-[#f8f8f8]">- AI and Jisc's Leadership Survey 2025</footer>
    </blockquote>
  </section>

  <section class="bg-[#f8f8f8] px-6 py-20 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="font-heading text-3xl font-bold text-[#015887] sm:text-4xl">Explore What We Offer</h2>
      <p class="mx-auto mt-5 max-w-3xl text-lg text-slate-700">
        Discover our services to find the right mix of training and support for your institution's AI goals.
      </p>
      <a
        href="/services"
        class="mt-8 inline-flex items-center justify-center rounded-md border border-[#ff7700] bg-[#ff7700] px-6 py-3 font-semibold text-white transition hover:bg-orange-600 hover:border-orange-600"
      >
        View Our Services
      </a>
    </div>
  </section>

  <section class="bg-[#015887] px-6 py-16 sm:px-8 lg:px-12">
    <blockquote class="mx-auto max-w-5xl border-l-4 border-[#ff7700] pl-6 text-2xl font-medium leading-relaxed text-white">
      On average, people say AI has made them 33% more productive and saves them about 1.3 hours per day.
      <footer class="mt-6 text-base font-normal text-[#f8f8f8]">- AI Collaboration Index 2025, Atlassian</footer>
    </blockquote>
  </section>

  <section class="bg-[#f8f8f8] px-6 py-20 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-6xl">
      <div class="text-center">
        <h2 class="font-heading text-3xl font-bold text-[#015887] sm:text-4xl">How we help you succeed</h2>
        <p class="mx-auto mt-4 max-w-3xl text-lg text-slate-700">
          A structured, people-first approach to confident and measurable AI adoption.
        </p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <article class="rounded-xl border border-[#015887]/15 bg-white p-6 shadow-sm">
          <h3 class="font-heading text-xl font-semibold text-[#015887]">Free Initial Consultation</h3>
          <p class="mt-3 leading-relaxed text-slate-700">
            A collaborative discussion to understand your institution's goals and challenges and see where you are on
            your AI journey.
          </p>
        </article>

        <article class="rounded-xl border border-[#015887]/15 bg-white p-6 shadow-sm">
          <h3 class="font-heading text-xl font-semibold text-[#015887]">AI Literacy &amp; Needs Analysis</h3>
          <p class="mt-3 leading-relaxed text-slate-700">
            A collaborative discussion to understand your institution's goals and challenges and see where you are on
            your AI journey.
          </p>
        </article>

        <article class="rounded-xl border border-[#015887]/15 bg-white p-6 shadow-sm">
          <h3 class="font-heading text-xl font-semibold text-[#015887]">Personalised Workshops</h3>
          <p class="mt-3 leading-relaxed text-slate-700">
            Choose four of our workshops for us to personalise and deliver. Expert-led, hands-on training sessions
            (F2F or online) tailored to your institution.
          </p>
        </article>

        <article class="rounded-xl border border-[#015887]/15 bg-white p-6 shadow-sm">
          <h3 class="font-heading text-xl font-semibold text-[#015887]">On-Demand Online Courses</h3>
          <p class="mt-3 leading-relaxed text-slate-700">
            On-demand access to asynchronous courses that reinforce and extend the learning from our live workshops,
            for up to 100 staff per package.
          </p>
        </article>

        <article class="rounded-xl border border-[#015887]/15 bg-white p-6 shadow-sm">
          <h3 class="font-heading text-xl font-semibold text-[#015887]">Strategic Roadmap Session</h3>
          <p class="mt-3 leading-relaxed text-slate-700">
            A high-level session with your leadership to translate training insights into a clear action plan for
            sustaining momentum.
          </p>
        </article>

        <article class="rounded-xl border border-[#015887]/15 bg-white p-6 shadow-sm">
          <h3 class="font-heading text-xl font-semibold text-[#015887]">Ongoing Support</h3>
          <p class="mt-3 leading-relaxed text-slate-700">
            Continuous access to resources and our AI Cafe drop-in sessions to keep momentum strong as AI evolves.
            Follow up calls with SLT.
          </p>
        </article>
      </div>

      <div class="mt-12 text-center">
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-md border border-[#ff7700] bg-[#ff7700] px-6 py-3 font-semibold text-white transition hover:bg-orange-600 hover:border-orange-600"
        >
          Book a Call
        </a>
      </div>
    </div>
  </section>
</Layout>
