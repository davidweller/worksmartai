---
import Layout from '~/layouts/PageLayout.astro';
import ROICalculator from '~/components/widgets/ROICalculator.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import { BOOK_A_CALL_URL } from '~/config/booking';

const metadata = {
  title: 'WorkSmart-AI | AI skills training and consulting for higher education',
  description:
    'We help staff build confidence, capability and compliance with AI, to ensure digital transformation leads to measurable ROI.',
};
---

<Layout metadata={metadata}>
  <Hero2
    tagline="WORKSMART-AI"
    topSpacerClass="pt-0 md:pt-[24px]"
    actions={[
      {
        variant: 'primary',
        text: 'Contact Us',
        href: '/contact-us/',
      },
      {
        text: 'ROI Calculator',
        href: '#roi-calculator',
        class: 'font-bold hover:bg-accent hover:border-accent hover:text-white',
      },
    ]}
    image={{
      src: '/images/home-hero.png',
      alt: 'Team discussing AI strategy in an office',
      width: 1200,
      height: 900,
      class: 'mx-auto rounded-2xl w-full shadow-none ring-0',
    }}
  >
    <Fragment slot="title">
      AI skills training for <span class="text-accent">higher education</span>.
    </Fragment>
    <Fragment slot="subtitle">
      We help staff build confidence, capability and compliance with AI, to ensure digital transformation leads to
      measurable ROI.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-gradient-to-b from-page via-page to-section"></div>
    </Fragment>
  </Hero2>

  <section id="roi-calculator" class="w-full bg-section px-6 py-16 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-6xl" data-aos="fade-up">
      <ROICalculator rootId="roi-calculator-home" />
    </div>
  </section>

  <section class="bg-section px-6 py-20 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="font-heading text-3xl font-bold text-heading sm:text-4xl" data-aos="fade-up">
        Struggling to see ROI from AI? You're not alone.
      </h2>
      <p class="mt-6 text-base leading-[var(--aw-leading-body,1.7)] text-muted" data-aos="fade-up" data-aos-delay="100">
        Organisations are overwhelmed with AI hype, staff feel anxious, and leaders can't see ROI. WorkSmart-AI provides
        people-first training that turns AI adoption into measurable savings, confident staff, and more productive
        organisations. With over a decade of experience working with universities in edtech, digital skills and AI,
        we're confident in helping you achieve your outcomes.
      </p>
    </div>
  </section>

  <section class="bg-brand px-6 py-16 sm:px-8 lg:px-12">
    <blockquote class="mx-auto max-w-5xl border-l-4 border-accent pl-6 text-white" data-aos="fade-right">
      <h4 class="font-heading text-lg font-semibold leading-[var(--aw-leading-body,1.7)]">
        ...the full potential of AI can only be unlocked if the staff are well-trained and confident in using these new
        technologies responsibly.
      </h4>
      <footer class="mt-6 text-base font-normal italic text-white/90">- AI and Jisc's Leadership Survey 2025</footer>
    </blockquote>
  </section>

  <section class="bg-section px-6 py-20 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="font-heading text-3xl font-bold text-heading sm:text-4xl" data-aos="fade-up">Explore What We Offer</h2>
      <p class="mx-auto mt-5 max-w-3xl text-base text-muted" data-aos="fade-up" data-aos-delay="100">
        Discover our services to find the right mix of training and support for your institution's AI goals.
      </p>
      <a
        data-aos="fade-up"
        data-aos-delay="180"
        href="/services"
        class="mt-8 inline-flex items-center justify-center rounded-full border border-accent bg-accent px-6 py-3 font-semibold text-white transition hover:bg-accent-hover hover:border-accent-hover"
      >
        View Our Services
      </a>
    </div>
  </section>

  <section class="bg-brand px-6 py-16 sm:px-8 lg:px-12">
    <blockquote class="mx-auto max-w-5xl border-l-4 border-accent pl-6 text-white" data-aos="fade-right">
      <h4 class="font-heading text-lg font-semibold leading-[var(--aw-leading-body,1.7)]">
        On average, people say AI has made them 33% more productive and saves them about 1.3 hours per day.
      </h4>
      <footer class="mt-6 text-base font-normal italic text-white/90">- AI Collaboration Index 2025, Atlassian</footer>
    </blockquote>
  </section>

  <section class="bg-section px-6 py-20 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-6xl">
      <div class="text-center">
        <h2 class="font-heading text-3xl font-bold text-heading sm:text-4xl" data-aos="fade-up">
          How we help you succeed
        </h2>
        <p class="mx-auto mt-4 max-w-3xl text-base text-muted" data-aos="fade-up" data-aos-delay="100">
          A structured, people-first approach to confident and measurable AI adoption.
        </p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <article class="rounded-xl border border-default bg-card p-6 shadow-card" data-aos="fade-up">
          <h3 class="font-heading text-xl font-semibold text-heading">Free Initial Consultation</h3>
          <p class="mt-3 text-base leading-[var(--aw-leading-body,1.7)] text-muted">
            A collaborative discussion to understand your institution's goals and challenges and see where you are on
            your AI journey.
          </p>
        </article>

        <article
          class="rounded-xl border border-default bg-card p-6 shadow-card"
          data-aos="fade-up"
          data-aos-delay="60"
        >
          <h3 class="font-heading text-xl font-semibold text-heading">AI Literacy &amp; Needs Analysis</h3>
          <p class="mt-3 text-base leading-[var(--aw-leading-body,1.7)] text-muted">
            A collaborative discussion to understand your institution's goals and challenges and see where you are on
            your AI journey.
          </p>
        </article>

        <article
          class="rounded-xl border border-default bg-card p-6 shadow-card"
          data-aos="fade-up"
          data-aos-delay="120"
        >
          <h3 class="font-heading text-xl font-semibold text-heading">Personalised Workshops</h3>
          <p class="mt-3 text-base leading-[var(--aw-leading-body,1.7)] text-muted">
            Choose four of our workshops for us to personalise and deliver. Expert-led, hands-on training sessions (F2F
            or online) tailored to your institution.
          </p>
        </article>

        <article
          class="rounded-xl border border-default bg-card p-6 shadow-card"
          data-aos="fade-up"
          data-aos-delay="180"
        >
          <h3 class="font-heading text-xl font-semibold text-heading">On-Demand Online Courses</h3>
          <p class="mt-3 text-base leading-[var(--aw-leading-body,1.7)] text-muted">
            On-demand access to asynchronous courses that reinforce and extend the learning from our live workshops, for
            up to 100 staff per package.
          </p>
        </article>

        <article
          class="rounded-xl border border-default bg-card p-6 shadow-card"
          data-aos="fade-up"
          data-aos-delay="240"
        >
          <h3 class="font-heading text-xl font-semibold text-heading">Strategic Roadmap Session</h3>
          <p class="mt-3 text-base leading-[var(--aw-leading-body,1.7)] text-muted">
            A high-level session with your leadership to translate training insights into a clear action plan for
            sustaining momentum.
          </p>
        </article>

        <article
          class="rounded-xl border border-default bg-card p-6 shadow-card"
          data-aos="fade-up"
          data-aos-delay="300"
        >
          <h3 class="font-heading text-xl font-semibold text-heading">Ongoing Support</h3>
          <p class="mt-3 text-base leading-[var(--aw-leading-body,1.7)] text-muted">
            Continuous access to resources and our AI Cafe drop-in sessions to keep momentum strong as AI evolves.
            Follow up calls with SLT.
          </p>
        </article>
      </div>

      <div class="mt-12 text-center" data-aos="fade-up">
        <a
          href={BOOK_A_CALL_URL}
          class="inline-flex items-center justify-center rounded-full border border-accent bg-accent px-6 py-3 font-semibold text-white transition hover:bg-accent-hover hover:border-accent-hover"
        >
          Book a Call
        </a>
      </div>
    </div>
  </section>
</Layout>
