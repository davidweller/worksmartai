---
import Layout from '~/layouts/PageLayout.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import { BOOK_A_CALL_URL } from '~/config/booking';

const metadata = {
  title: 'AI Skills Training for Higher Education | WorkSmart-AI',
  description:
    'Specialist AI training and consultancy for higher education, helping staff, students and senior leaders build confidence, capability and compliance with measurable impact.',
  canonical: '/',
};
---

<Layout metadata={metadata}>
  <Hero2
    tagline="WORKSMART-AI"
    topSpacerClass="pt-0 md:pt-[24px]"
    actions={[
      {
        variant: 'primary',
        text: 'View Our Services',
        href: '/services/',
      },
      {
        text: 'Contact Us',
        href: '/contact-us/',
        class: 'font-bold hover:bg-accent hover:border-accent hover:text-white',
      },
    ]}
    image={{
      src: '/images/home-hero-photo.png',
      alt: 'Team collaborating around a table with sticky notes during a planning session',
      width: 1200,
      height: 800,
      class: 'mx-auto rounded-2xl w-full shadow-none ring-0',
    }}
  >
    <Fragment slot="title">
      Specialist AI training and consultancy for <span class="text-accent">higher education</span>.
    </Fragment>
    <Fragment slot="subtitle">
      Build your institution&rsquo;s AI capability with personalised, HE-focused support tailored to your goals and
      priorities.
      <br />
      <br />
      Outcomes include:
      <br />
      &ndash; Your team being more productive
      <br />
      &ndash; Leaders more confident in AI decision-making
      <br />
      &ndash; Students work smarter with AI
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-gradient-to-b from-page via-page to-section"></div>
    </Fragment>
  </Hero2>

  <section class="bg-brand px-6 py-16 sm:px-8 lg:px-12">
    <blockquote class="mx-auto max-w-5xl border-l-4 border-accent pl-6 text-white" data-aos="fade-right">
      <h4 class="font-heading text-lg font-semibold leading-[var(--aw-leading-body,1.7)]">
        &ldquo;On average, people say AI has made them 33% more productive and saves them about 1.3 hours per
        day.&rdquo;
      </h4>
      <footer class="mt-6 text-base font-normal italic text-white/90">- AI Collaboration Index 2025, Atlassian</footer>
    </blockquote>
  </section>

  <section class="bg-section px-6 py-20 sm:px-8 lg:px-12">
    <div class="mx-auto grid max-w-6xl items-center gap-10 lg:grid-cols-2 lg:gap-14">
      <div class="order-1" data-aos="fade-right">
        <img
          src="/images/explore-offer-photo.png"
          alt="WorkSmart-AI team session with participants collaborating in person"
          class="h-full w-full rounded-2xl object-cover shadow-card"
          loading="lazy"
        />
      </div>

      <div class="order-2 text-center lg:text-left">
        <h2 class="font-heading text-3xl font-bold text-heading sm:text-4xl" data-aos="fade-up">Package of Support</h2>
        <p class="mt-5 text-base text-muted" data-aos="fade-up" data-aos-delay="100">
          HE specialists work with you to identify AI capability levels and design a tailored learning and development
          package to meet your institution&rsquo;s needs.
        </p>
        <p class="mt-4 text-base text-muted" data-aos="fade-up" data-aos-delay="130">
          Services include:
          <br />
          &ndash; Student AI work-ready workshops
          <br />
          &ndash; Staff foundational and advanced AI training packages
          <br />
          &ndash; Middle / senior leader 1:1 AI consultancy
          <br />
          &ndash; Academic AI coaching sessions
          <br />
          &ndash; Team away day / bespoke event AI sessions
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row lg:justify-start">
          <a
            data-aos="fade-up"
            data-aos-delay="180"
            href="/services/"
            class="inline-flex items-center justify-center rounded-full border border-accent bg-accent px-6 py-3 font-semibold text-white transition hover:bg-accent-hover hover:border-accent-hover"
          >
            View Our Services
          </a>
          <a
            data-aos="fade-up"
            data-aos-delay="220"
            href="/contact-us/"
            class="inline-flex items-center justify-center rounded-full border border-accent bg-transparent px-6 py-3 font-semibold text-accent transition hover:bg-accent hover:text-white"
          >
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-brand px-6 py-16 sm:px-8 lg:px-12">
    <blockquote class="mx-auto max-w-5xl border-l-4 border-accent pl-6 text-white" data-aos="fade-right">
      <h4 class="font-heading text-lg font-semibold leading-[var(--aw-leading-body,1.7)]">
        &ldquo;AI literacy is now a fundamental skill akin to reading and writing.&rdquo;
      </h4>
      <footer class="mt-6 text-base font-normal italic text-white/90">- HE Educators</footer>
    </blockquote>
  </section>

  <section class="bg-section px-6 py-20 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-6xl">
      <div class="text-center">
        <h2 class="font-heading text-3xl font-bold text-heading sm:text-4xl" data-aos="fade-up">
          Why choose WorkSmart-AI?
        </h2>
        <p class="mx-auto mt-4 max-w-3xl text-base text-muted" data-aos="fade-up" data-aos-delay="100">
          Our specialists have worked within HE and education for over 4 decades, supporting staff and students across
          the UK to develop digital skills and most recently AI capabilities.
        </p>
        <p class="mx-auto mt-4 max-w-3xl text-base text-muted" data-aos="fade-up" data-aos-delay="130">
          Understanding how universities operate, the systems they use, and the people they support, is integral to
          robust and sustainable AI transformation.
        </p>
        <p
          class="mx-auto mt-6 max-w-3xl font-heading text-lg font-semibold text-heading"
          data-aos="fade-up"
          data-aos-delay="160"
        >
          Our 5-step process:
        </p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <article class="rounded-xl border border-default bg-card p-6 shadow-card" data-aos="fade-up">
          <h3 class="font-heading text-xl font-semibold text-heading">Free HE-specific capability assessment</h3>
          <p class="mt-3 text-base leading-[var(--aw-leading-body,1.7)] text-muted">
            To identify AI usage and design a package of support.
          </p>
        </article>

        <article
          class="rounded-xl border border-default bg-card p-6 shadow-card"
          data-aos="fade-up"
          data-aos-delay="60"
        >
          <h3 class="font-heading text-xl font-semibold text-heading">Agree a learning and development schedule</h3>
          <p class="mt-3 text-base leading-[var(--aw-leading-body,1.7)] text-muted">
            Underpinned by measurable objectives to ensure ROI.
          </p>
        </article>

        <article
          class="rounded-xl border border-default bg-card p-6 shadow-card"
          data-aos="fade-up"
          data-aos-delay="120"
        >
          <h3 class="font-heading text-xl font-semibold text-heading">
            Learning and development package of activities
          </h3>
          <p class="mt-3 text-base leading-[var(--aw-leading-body,1.7)] text-muted">
            Designed around your needs, timescales and budget.
          </p>
        </article>

        <article
          class="rounded-xl border border-default bg-card p-6 shadow-card"
          data-aos="fade-up"
          data-aos-delay="180"
        >
          <h3 class="font-heading text-xl font-semibold text-heading">Data-driven final review and roadmap session</h3>
          <p class="mt-3 text-base leading-[var(--aw-leading-body,1.7)] text-muted">
            To demonstrate progression and identify next steps.
          </p>
        </article>

        <article
          class="rounded-xl border border-default bg-card p-6 shadow-card"
          data-aos="fade-up"
          data-aos-delay="240"
        >
          <h3 class="font-heading text-xl font-semibold text-heading">On-going support</h3>
          <p class="mt-3 text-base leading-[var(--aw-leading-body,1.7)] text-muted">
            Online drop-in sessions and asynchronous extension courses help embed learning and support sustainability.
          </p>
        </article>
      </div>

      <div class="mt-12 text-center" data-aos="fade-up">
        <a
          href={BOOK_A_CALL_URL}
          class="inline-flex items-center justify-center rounded-full border border-accent bg-accent px-6 py-3 font-semibold text-white transition hover:bg-accent-hover hover:border-accent-hover"
        >
          Book a Call
        </a>
      </div>
    </div>
  </section>
</Layout>
