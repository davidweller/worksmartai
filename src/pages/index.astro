---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Contact from '~/components/widgets/Contact.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';

const metadata = {
  title: 'WorkSmart-AI | AI skills training and consulting for higher education',
  description:
    'We help staff build confidence, capability and compliance with AI, to ensure digital transformation leads to measurable ROI.',
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        text: 'Book a Call',
        href: '/book-a-call',
        class: 'bg-accent border-accent text-white hover:bg-orange-600 hover:border-orange-600',
      },
      {
        variant: 'secondary',
        text: 'View Calculator',
        href: '/calculator',
      },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'WorkSmart-AI consulting team' }}
  >
    <Fragment slot="title">AI skills training and consulting for higher education.</Fragment>

    <Fragment slot="subtitle">
      We help staff build confidence, capability and compliance with AI, to ensure digital transformation leads to
      measurable ROI.
    </Fragment>
  </Hero>

  <Stats
    title="Trusted outcomes"
    subtitle="Placeholder social-proof stats - to be replaced with real customer evidence."
    stats={[
      { title: 'Universities supported', amount: 'XX+' },
      { title: 'Staff trained', amount: 'XXX+' },
      { title: 'Avg. time saved', amount: 'X hrs/week' },
      { title: 'Policy-aligned programs', amount: 'XX' },
    ]}
  />

  <Features
    id="services"
    tagline="Services"
    title="How WorkSmart-AI helps higher education teams"
    subtitle="People-first training and consulting designed to build confidence, capability and measurable institutional value."
    columns={2}
    items={[
      {
        title: 'Senior Leadership Teams',
        description:
          'Build confidence at the top with strategic, ethical AI adoption aligned to institutional goals, savings, compliance and productivity.',
        icon: 'tabler:users-group',
      },
      {
        title: 'Academic Educators and Researchers',
        description:
          'Use AI to enhance learning design, assessment and research efficiency while supporting academic integrity and ethical standards.',
        icon: 'tabler:school',
      },
      {
        title: 'Professional Service Staff',
        description:
          'Enable teams to save time and work smarter by applying AI responsibly to everyday workflows and service delivery.',
        icon: 'tabler:briefcase',
      },
      {
        title: 'Foundations of AI',
        description:
          'For staff beginning their AI journey: build understanding, reduce anxiety, and create confidence using AI tools.',
        icon: 'tabler:book',
      },
    ]}
  />

  <CallToAction
    id="calculator"
    title="How much could you save with AI?"
    subtitle="Use our ROI calculator to estimate how much time, cost and capacity your institution could reclaim."
    actions={[
      {
        variant: 'primary',
        text: 'View Calculator',
        href: '/calculator',
      },
    ]}
  />

  <Contact
    id="guide"
    tagline="Free Guide"
    title="Get the Higher Education AI Use Cases guide"
    subtitle="Placeholder lead-magnet form. We will connect this to email capture automation in a later step."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Name',
        placeholder: 'Your full name',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email',
        placeholder: 'you@institution.edu',
      },
    ]}
    button="Get the Free Guide"
    description="By submitting, you agree to receive related updates from WorkSmart-AI. Placeholder consent text."
  />

  <Testimonials
    title="What our partners are saying"
    subtitle="Placeholder testimonials - real quotes and names will be added next."
    testimonials={[
      {
        title: 'Placeholder testimonial one',
        testimonial: 'WorkSmart-AI helped our teams move from AI uncertainty to practical confidence.',
        name: 'Name to be added',
        job: 'Role and institution to be added',
      },
      {
        title: 'Placeholder testimonial two',
        testimonial: 'The workshops connected policy, pedagogy and productivity in a way our staff could immediately apply.',
        name: 'Name to be added',
        job: 'Role and institution to be added',
      },
      {
        title: 'Placeholder testimonial three',
        testimonial: 'We can now see clearer ROI pathways for responsible AI adoption across departments.',
        name: 'Name to be added',
        job: 'Role and institution to be added',
      },
    ]}
  />

  <CallToAction
    title="Ready to upskill with AI?"
    subtitle="Book a call to discuss your institution's priorities and next steps."
    actions={[
      {
        text: 'Book a Call',
        href: '/book-a-call',
        class: 'bg-accent border-accent text-white hover:bg-orange-600 hover:border-orange-600',
      },
    ]}
  />
</Layout>
