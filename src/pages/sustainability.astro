const content =
  '<div class="container single-page-container">\n\t<div class="row">\n\t\t\t\t<div class="nv-single-page-wrap col">\n\t\t\t<div class="nv-page-title-wrap nv-big-title" >\n\t<div class="nv-page-title ">\n\t\t<small class="neve-breadcrumbs-wrapper"></small>\t\t<h1>Sustainability</h1>\n\t\t\t\t\t</div>\n</div> \n\t<div class="nv-content-wrap entry-content">\n<h3 class="wp-block-heading">WorkSmart-AI Sustainability &amp; Environmental Policy</h3>\n\n\n\n<p>At WorkSmart-AI, we recognise our responsibility to minimise environmental impact and contribute to a more sustainable future. As a training and consultancy provider, our operations are low carbon by design, but we are committed to continuous improvement in sustainability.</p>\n\n\n\n<h2 class="wp-block-heading">1. Our Commitment</h2>\n\n\n\n<p>We are committed to:</p>\n\n\n\n<ul class="wp-block-list">\n<li>Reducing our carbon footprint by prioritising digital-first delivery.</li>\n\n\n\n<li>Minimising waste and encouraging sustainable resource use.</li>\n\n\n\n<li>Embedding environmental responsibility into the way we work and the services we provide.</li>\n</ul>\n\n\n\n<h2 class="wp-block-heading">2. In Practice</h2>\n\n\n\n<p>We take the following steps to meet our commitment:</p>\n\n\n\n<ul class="wp-block-list">\n<li><strong>Digital-first delivery</strong>: We deliver most training and consultancy services online, significantly reducing travel and paper use.</li>\n\n\n\n<li><strong>Sustainable travel</strong>: When in-person sessions are required, we use sustainable transport options where possible and group sessions to minimise journeys.</li>\n\n\n\n<li><strong>Paper reduction</strong>: We provide digital resources by default and avoid unnecessary printing.</li>\n\n\n\n<li><strong>Energy efficiency</strong>: We use cloud-based services with providers that have published commitments to renewable energy and carbon reduction.</li>\n\n\n\n<li><strong>Procurement</strong>: We consider sustainability when selecting venues, suppliers, and technology partners.</li>\n</ul>\n\n\n\n<h2 class="wp-block-heading">3. Continuous Improvement</h2>\n\n\n\n<p>We will:</p>\n\n\n\n<ul class="wp-block-list">\n<li>Regularly review our environmental practices and seek new ways to reduce impact.</li>\n\n\n\n<li>Monitor developments in sustainability and adopt best practices relevant to our sector.</li>\n\n\n\n<li>Encourage staff, associates, and clients to contribute to sustainability goals.</li>\n</ul>\n\n\n\n<h2 class="wp-block-heading">4. Responsibility</h2>\n\n\n\n<ul class="wp-block-list">\n<li><strong>Leadership</strong>: WorkSmart-AI leadership is accountable for sustainability commitments and policy implementation.</li>\n\n\n\n<li><strong>Staff &amp; Associates</strong>: Expected to follow sustainable practices in their work and promote environmentally responsible behaviours.</li>\n\n\n\n<li><strong>Partners &amp; Clients</strong>: Encouraged to work with us in ways that align with sustainability objectives.</li>\n</ul>\n\n\n\n<h2 class="wp-block-heading">5. Review</h2>\n\n\n\n<p>This policy will be reviewed annually and updated to reflect changes in best practice, technology, and regulation.</p>\n\n\n\n<p>📩 <a href="/contact-us/" data-type="link" data-id="https://worksmart-ai.co.uk/contact-us/">Contact Us Here</a></p>\n\n\n\n<p></p>\n</div>\t\t</div>\n\t\t\t</div>\n</div>';
