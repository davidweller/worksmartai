---
import { Icon } from 'astro-icon/components';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Leadership & Manager Consulting | WorkSmart-AI',
  description:
    'Practical AI strategy and advisory for higher education managers and team leaders. Build confident, policy-aligned adoption in day-to-day operations.',
  canonical: '/services/senior-consulting/',
};

const advisoryAreas = [
  'Translating institutional AI policy into team-level practice',
  'Identifying quick-win workflows for service improvement',
  'Building confident, responsible AI use across teams',
  'Designing practical guidance for quality and compliance',
  'Evaluating tools and use cases against real team needs',
  'Supporting cross-team collaboration on AI-enabled change',
  'Creating implementation roadmaps managers can deliver',
];

const howWeWork = [
  'Practical and context-specific - focused on your team workflow',
  'Independent - we have no vendor affiliations',
  'Flexible - one-off workshops or ongoing support',
  'Collaborative - designed for managers and frontline leaders',
  'Higher-education specific - no generic consulting playbooks',
  'Fast to mobilise - typically within one week',
];

const engagementTags = [
  'Manager strategy workshop',
  'Team implementation planning',
  'Policy-in-practice support',
  'Cross-department facilitation',
  'Workflow improvement design',
  'Ongoing advisory support',
];

const leadershipWorkshops = [
  {
    code: 'W11',
    name: 'The AI Leadership Briefing (3-hour)',
    level: 'Strategic',
    prerequisite: 'None',
  },
  {
    code: 'W12',
    name: 'The AI Strategic Roadmap (Full day)',
    level: 'Strategic',
    prerequisite: 'W11',
  },
];
---

<Layout metadata={metadata}>
  <div class="bg-section px-6 pt-8 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-6xl">
      <a
        href="/services/"
        class="inline-flex items-center text-sm font-semibold text-link transition-colors hover:text-accent"
      >
        ← Back to Services
      </a>
    </div>
  </div>

  <section class="bg-brand px-6 py-16 sm:px-8 lg:px-12 lg:py-20" data-aos="fade-up">
    <div class="mx-auto max-w-4xl text-center">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-secondary sm:text-sm">
        Leadership & Manager Consulting
      </p>
      <h1 class="font-heading text-3xl font-bold leading-tight text-white sm:text-4xl lg:text-5xl">
        Practical AI leadership support for managers and team leads
      </h1>
      <p class="mt-6 text-base leading-[var(--aw-leading-body,1.7)] text-white/90 sm:text-lg">
        Hands-on support for managers and operational leaders who need clear, practical direction on introducing AI in
        responsible, high-impact ways.
      </p>
    </div>
  </section>

  <section class="bg-section px-6 py-16 sm:px-8 lg:px-12 lg:py-20">
    <div class="mx-auto max-w-6xl">
      <div class="rounded-xl border border-default bg-card p-6 shadow-card md:p-10" data-aos="fade-up">
        <h2 class="font-heading text-2xl font-bold text-heading sm:text-3xl">The challenge managers and team leads face</h2>
        <div class="mt-6 space-y-5 text-default">
          <p>
            Most teams are already experimenting with AI, but adoption is often uneven, inconsistent and disconnected
            from day-to-day priorities. Managers are expected to improve outcomes, maintain quality and reduce risk -
            often without clear guidance on what good implementation looks like.
          </p>
          <p>
            We help middle leaders turn broad institutional ambitions into practical action: where to start, what to
            standardise, which workflows to prioritise, and how to build confidence across the team without adding
            unnecessary complexity.
          </p>
        </div>
      </div>

      <div class="mt-8 grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-10">
        <div class="rounded-xl border border-default bg-card p-6 shadow-card md:p-8" data-aos="fade-up">
          <h3 class="font-heading text-xl font-bold text-heading">Advisory areas</h3>
          <ul class="mt-6 space-y-3">
            {
              advisoryAreas.map((item) => (
                <li class="flex gap-3 text-default">
                  <Icon name="tabler:check" class="mt-0.5 h-5 w-5 shrink-0 text-accent" aria-hidden="true" />
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
        <div
          class="rounded-xl border border-default bg-card p-6 shadow-card md:p-8"
          data-aos="fade-up"
          data-aos-delay="50"
        >
          <h3 class="font-heading text-xl font-bold text-heading">How we work</h3>
          <ul class="mt-6 space-y-3">
            {
              howWeWork.map((item) => (
                <li class="flex gap-3 text-default">
                  <Icon name="tabler:check" class="mt-0.5 h-5 w-5 shrink-0 text-accent" aria-hidden="true" />
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div
        class="mt-10 rounded-xl border-2 border-dashed border-primary/30 bg-card p-6 shadow-card md:mt-14 md:p-10"
        data-aos="fade-up"
      >
        <h2 class="font-heading text-2xl font-bold text-heading sm:text-3xl">Leadership Planning Workshops</h2>
        <p class="mt-3 text-muted">
          Structured senior-level workshops that help leadership teams align strategy, governance and implementation
          priorities for AI.
        </p>

        <div class="mt-6 overflow-hidden rounded-lg border border-default bg-card">
          <div class="grid grid-cols-[minmax(0,1fr)_auto_auto] gap-4 border-b border-default bg-brand/5 px-4 py-3">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Workshop</p>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Level</p>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Prerequisite</p>
          </div>

          <div class="divide-y divide-default/70">
            {
              leadershipWorkshops.map((workshop) => (
                <article class="grid grid-cols-[minmax(0,1fr)_auto_auto] items-center gap-4 px-4 py-3">
                  <h4 class="text-sm font-medium text-default sm:text-base">
                    <span class="font-semibold text-heading">{workshop.code}.</span> {workshop.name}
                  </h4>
                  <span class="inline-flex rounded-full bg-accent/15 px-3 py-1 text-xs font-semibold text-accent">
                    {workshop.level}
                  </span>
                  <span class="text-sm font-medium text-default">{workshop.prerequisite}</span>
                </article>
              ))
            }
          </div>
        </div>
      </div>

      <div class="mt-10 rounded-xl border border-default bg-card p-6 shadow-card md:mt-14 md:p-10" data-aos="fade-up">
        <h2 class="font-heading text-2xl font-bold text-heading sm:text-3xl">Typical engagements</h2>
        <div class="mt-6 space-y-5 text-default">
          <p>
            Engagements are shaped around practical team needs. Common starting points include a manager-led planning
            workshop, a workflow redesign sprint for one service area, or implementation support to embed AI into
            everyday operations in a safe, measurable way.
          </p>
          <p>
            We regularly work with heads of service, programme leads, department managers and cross-functional project
            teams to improve consistency, capability and impact. Support is flexible and matched to your priorities,
            capacity and timeline.
          </p>
        </div>
        <div class="mt-6 flex flex-wrap gap-2">
          {
            engagementTags.map((tag, i) => (
              <span
                class:list={[
                  'inline-flex rounded-full border px-3 py-1.5 text-sm font-medium',
                  i === 3 ? 'border-accent bg-accent/10 text-accent' : 'border-primary/25 text-default',
                ]}
              >
                {tag}
              </span>
            ))
          }
        </div>
      </div>

      <section class="mt-10 rounded-2xl bg-brand px-6 py-12 text-center sm:px-10 md:mt-14 md:py-16" data-aos="fade-up">
        <h2 class="font-heading text-2xl font-bold text-white sm:text-3xl">Let's scope what your team needs</h2>
        <p class="mx-auto mt-4 max-w-2xl text-white/90">
          Book a practical scoping call to identify the right starting point for your managers and teams.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="/contact/"
            class="inline-flex min-w-[10rem] items-center justify-center rounded-full bg-accent px-8 py-3.5 font-semibold text-white transition-colors hover:bg-accent-hover"
          >
            Book a scoping call
          </a>
          <a
            href="/services/"
            class="inline-flex min-w-[10rem] items-center justify-center rounded-full border-2 border-white px-8 py-3.5 font-semibold text-white transition-colors hover:bg-white/10"
          >
            View all services
          </a>
        </div>
      </section>
    </div>
  </section>
</Layout>
