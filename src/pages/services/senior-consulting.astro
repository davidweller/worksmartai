---
import { Icon } from 'astro-icon/components';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Senior Leader Consulting | WorkSmart-AI',
  description:
    'Independent AI strategy and advisory for higher education senior leaders. No vendor agenda. Confidential support for Vice-Chancellors, Deans and executive teams.',
  canonical: '/services/senior-consulting/',
};

const advisoryAreas = [
  'Developing an institution-wide AI strategy',
  'AI policy drafting and governance frameworks',
  'Evaluating AI vendor proposals and claims',
  'Academic integrity policy in the age of AI',
  'Competitive positioning and sector benchmarking',
  'Staff and student engagement planning',
  'Board and senate briefings on AI',
];

const howWeWork = [
  'Fully confidential - no case studies without consent',
  'Independent - we have no vendor affiliations',
  'Flexible - monthly retainer or project-by-project',
  'Senior-level only - you speak directly with us',
  'Sector-specific - no generic management consulting',
  'Fast to mobilise - typically within one week',
];

const engagementTags = [
  'SLT strategy workshop',
  'Policy drafting and review',
  'Monthly retainer',
  'Board and senate briefing',
  'Vendor evaluation support',
  '1-to-1 executive advisory',
];
---

<Layout metadata={metadata}>
  <div class="bg-section px-6 pt-8 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-6xl">
      <a
        href="/services/"
        class="inline-flex items-center text-sm font-semibold text-link transition-colors hover:text-accent"
      >
        ← Back to Services
      </a>
    </div>
  </div>

  <section class="bg-brand px-6 py-16 sm:px-8 lg:px-12 lg:py-20" data-aos="fade-up">
    <div class="mx-auto max-w-4xl text-center">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-secondary sm:text-sm">
        Senior Leader Consulting
      </p>
      <h1 class="font-heading text-3xl font-bold leading-tight text-white sm:text-4xl lg:text-5xl">
        Strategic AI leadership for higher education executives
      </h1>
      <p class="mt-6 text-base leading-[var(--aw-leading-body,1.7)] text-white/90 sm:text-lg">
        Confidential advisory support for Vice-Chancellors, Deans and senior leaders who need clear, honest thinking on
        AI strategy - without the vendor agenda.
      </p>
    </div>
  </section>

  <section class="bg-section px-6 py-16 sm:px-8 lg:px-12 lg:py-20">
    <div class="mx-auto max-w-6xl">
      <div class="rounded-xl border border-default bg-card p-6 shadow-card md:p-10" data-aos="fade-up">
        <h2 class="font-heading text-2xl font-bold text-heading sm:text-3xl">The challenge senior leaders face</h2>
        <div class="mt-6 space-y-5 text-default">
          <p>
            AI is reshaping higher education faster than any governance process can keep pace with. Competitors are
            making bold claims. Staff are using tools you haven't sanctioned. Students expect more. And every software
            vendor in the sector is now calling themselves an AI company.
          </p>
          <p>
            Senior leaders need a trusted, independent perspective - someone who understands both the technology and the
            unique pressures of the sector, and who has no interest in selling you a platform. That is what we provide.
          </p>
        </div>
      </div>

      <div class="mt-8 grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-10">
        <div class="rounded-xl border border-default bg-card p-6 shadow-card md:p-8" data-aos="fade-up">
          <h3 class="font-heading text-xl font-bold text-heading">Advisory areas</h3>
          <ul class="mt-6 space-y-3">
            {
              advisoryAreas.map((item) => (
                <li class="flex gap-3 text-default">
                  <Icon name="tabler:check" class="mt-0.5 h-5 w-5 shrink-0 text-accent" aria-hidden="true" />
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
        <div
          class="rounded-xl border border-default bg-card p-6 shadow-card md:p-8"
          data-aos="fade-up"
          data-aos-delay="50"
        >
          <h3 class="font-heading text-xl font-bold text-heading">How we work</h3>
          <ul class="mt-6 space-y-3">
            {
              howWeWork.map((item) => (
                <li class="flex gap-3 text-default">
                  <Icon name="tabler:check" class="mt-0.5 h-5 w-5 shrink-0 text-accent" aria-hidden="true" />
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div class="mt-10 rounded-xl border border-default bg-card p-6 shadow-card md:mt-14 md:p-10" data-aos="fade-up">
        <h2 class="font-heading text-2xl font-bold text-heading sm:text-3xl">Typical engagements</h2>
        <div class="mt-6 space-y-5 text-default">
          <p>
            Consulting engagements vary considerably in scope. Common starting points include a one-off strategic review
            session with the senior leadership team, a policy audit and drafting project for academic integrity or data
            governance, or an ongoing monthly advisory retainer for institutions navigating a major AI initiative.
          </p>
          <p>
            We are equally comfortable presenting to governing bodies, facilitating senior leadership team workshops, or
            providing discreet one-to-one counsel to an individual executive. Engagements are entirely shaped around
            your needs and timeline.
          </p>
        </div>
        <div class="mt-6 flex flex-wrap gap-2">
          {
            engagementTags.map((tag, i) => (
              <span
                class:list={[
                  'inline-flex rounded-full border px-3 py-1.5 text-sm font-medium',
                  i === 3 ? 'border-accent bg-accent/10 text-accent' : 'border-primary/25 text-default',
                ]}
              >
                {tag}
              </span>
            ))
          }
        </div>
      </div>

      <section class="mt-10 rounded-2xl bg-brand px-6 py-12 text-center sm:px-10 md:mt-14 md:py-16" data-aos="fade-up">
        <h2 class="font-heading text-2xl font-bold text-white sm:text-3xl">A confidential conversation first</h2>
        <p class="mx-auto mt-4 max-w-2xl text-white/90">
          All initial conversations are completely confidential and without obligation. Book a private call to explore
          how we can help.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="/contact/"
            class="inline-flex min-w-[10rem] items-center justify-center rounded-full bg-accent px-8 py-3.5 font-semibold text-white transition-colors hover:bg-accent-hover"
          >
            Book a private call
          </a>
          <a
            href="/services/"
            class="inline-flex min-w-[10rem] items-center justify-center rounded-full border-2 border-white px-8 py-3.5 font-semibold text-white transition-colors hover:bg-white/10"
          >
            View all services
          </a>
        </div>
      </section>
    </div>
  </section>
</Layout>
