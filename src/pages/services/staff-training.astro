---
import { Icon } from 'astro-icon/components';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Staff Training | WorkSmart-AI',
  description:
    'Role-specific AI training for higher education staff. Practical, hands-on workshops and programmes that build real capability across your whole institution.',
  canonical: '/services/staff-training/',
};

const included = [
  'Pre-training needs assessment',
  'Role-specific workshop content',
  'Hands-on practical exercises',
  'Prompt writing and AI workflow guides',
  'Post-training resource pack',
  '30-day follow-up Q&A support',
  'Progress and impact reporting',
];

const outcomes = [
  'Staff save 3-8 hours per week on routine tasks',
  'Consistent, higher-quality written communications',
  'Faster turnaround on reports and data summaries',
  'Reduced anxiety and resistance around AI adoption',
  'A shared institutional vocabulary around AI',
  'Improved confidence with new tools going forward',
];

const deliveryTags = ['Online', 'Face to face', 'Blended'];
---

<Layout metadata={metadata}>
  <div class="bg-section px-6 pt-8 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-6xl">
      <a
        href="/services/"
        class="inline-flex items-center text-sm font-semibold text-link transition-colors hover:text-accent"
      >
        ← Back to Services
      </a>
    </div>
  </div>

  <section class="bg-brand px-6 py-16 sm:px-8 lg:px-12 lg:py-20" data-aos="fade-up">
    <div class="mx-auto max-w-4xl text-center">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-secondary sm:text-sm">Staff Training</p>
      <h1 class="font-heading text-3xl font-bold leading-tight text-white sm:text-4xl lg:text-5xl">
        AI training that works for your whole institution
      </h1>
      <p class="mt-6 text-base leading-[var(--aw-leading-body,1.7)] text-white/90 sm:text-lg">
        Role-specific, practical AI training for professional services, academic and support staff - built around your
        workflows and delivered in a format that fits your team.
      </p>
    </div>
  </section>

  <section class="border-b border-default bg-section px-6 py-10 sm:px-8 lg:px-12">
    <div class="mx-auto grid max-w-6xl grid-cols-1 gap-6 md:grid-cols-3">
      <div class="rounded-xl border border-default bg-card p-6 text-center shadow-card">
        <p class="font-heading text-3xl font-bold text-heading">3hrs</p>
        <p class="mt-2 text-sm text-muted">Average time to first real-world application</p>
      </div>
      <div class="rounded-xl border border-default bg-card p-6 text-center shadow-card">
        <p class="font-heading text-3xl font-bold text-heading">94%</p>
        <p class="mt-2 text-sm text-muted">Participant confidence improvement reported</p>
      </div>
      <div class="rounded-xl border border-default bg-card p-6 text-center shadow-card">
        <p class="font-heading text-3xl font-bold text-heading">40+</p>
        <p class="mt-2 text-sm text-muted">HE institutions trained across the UK</p>
      </div>
    </div>
  </section>

  <section class="bg-section px-6 py-16 sm:px-8 lg:px-12 lg:py-20">
    <div class="mx-auto max-w-6xl">
      <div class="rounded-xl border border-default bg-card p-6 shadow-card md:p-10" data-aos="fade-up">
        <h2 class="font-heading text-2xl font-bold text-heading sm:text-3xl">What this service covers</h2>
        <div class="mt-6 space-y-5 text-default">
          <p>
            Most AI training fails because it is either too generic or too technical. Our staff training programmes are
            built around the specific roles, responsibilities and workflows of your people - whether that is admissions,
            registry, student services, finance, marketing, IT, or academic administration.
          </p>
          <p>
            Each programme begins with a scoping conversation to understand your team's current AI awareness, the tools
            already in use across the institution, and the outcomes you want to achieve. We then design and deliver
            training that maps directly to your staff's day-to-day tasks.
          </p>
        </div>
      </div>

      <div class="mt-8 grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-10">
        <div class="rounded-xl border border-default bg-card p-6 shadow-card md:p-8" data-aos="fade-up">
          <h3 class="font-heading text-xl font-bold text-heading">What's included</h3>
          <ul class="mt-6 space-y-3">
            {
              included.map((item) => (
                <li class="flex gap-3 text-default">
                  <Icon name="tabler:check" class="mt-0.5 h-5 w-5 shrink-0 text-accent" aria-hidden="true" />
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
        <div
          class="rounded-xl border border-default bg-card p-6 shadow-card md:p-8"
          data-aos="fade-up"
          data-aos-delay="40"
        >
          <h3 class="font-heading text-xl font-bold text-heading">Typical outcomes</h3>
          <ul class="mt-6 space-y-3">
            {
              outcomes.map((item) => (
                <li class="flex gap-3 text-default">
                  <Icon name="tabler:check" class="mt-0.5 h-5 w-5 shrink-0 text-accent" aria-hidden="true" />
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div
        class="mt-10 rounded-xl border-2 border-dashed border-primary/30 bg-card p-6 shadow-card md:mt-14 md:p-10"
        data-aos="fade-up"
      >
        <h2 class="font-heading text-2xl font-bold text-heading sm:text-3xl">Our staff training courses</h2>
        <p class="mt-3 text-muted">Courses coming soon - check back shortly.</p>
        <div class="mt-4 min-h-[120px]" aria-hidden="true"></div>
        <!-- TODO: Add course cards here. Each course should show: course name (h4), 2-sentence outcome description, and duration tag. -->
      </div>

      <div class="mt-10 rounded-xl border border-default bg-card p-6 shadow-card md:mt-14 md:p-10" data-aos="fade-up">
        <h2 class="font-heading text-2xl font-bold text-heading sm:text-3xl">Delivery formats</h2>
        <p class="mt-4 text-default">
          We offer maximum flexibility around how training is delivered to minimise disruption to your staff's workload.
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          {
            deliveryTags.map((tag) => (
              <span class="inline-flex rounded-full border border-primary/25 px-3 py-1.5 text-sm font-medium text-default">
                {tag}
              </span>
            ))
          }
        </div>
      </div>

      <section class="mt-10 rounded-2xl bg-brand px-6 py-12 text-center sm:px-10 md:mt-14 md:py-16" data-aos="fade-up">
        <h2 class="font-heading text-2xl font-bold text-white sm:text-3xl">Ready to get started?</h2>
        <p class="mx-auto mt-4 max-w-2xl text-white/90">
          Book a free 30-minute scoping call to discuss your institution's needs.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="/contact/"
            class="inline-flex min-w-[10rem] items-center justify-center rounded-full bg-accent px-8 py-3.5 font-semibold text-white transition-colors hover:bg-accent-hover"
          >
            Book a call
          </a>
          <a
            href="/services/"
            class="inline-flex min-w-[10rem] items-center justify-center rounded-full border-2 border-white px-8 py-3.5 font-semibold text-white transition-colors hover:bg-white/10"
          >
            View all services
          </a>
        </div>
      </section>
    </div>
  </section>
</Layout>
