---
import { Icon } from 'astro-icon/components';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Academic Coaching | WorkSmart-AI',
  description:
    'Personal AI coaching for academics in higher education. 1-to-1 and small group coaching to accelerate research, improve teaching and reduce admin burden.',
  canonical: '/services/academic-coaching/',
};

const coachingAreas = [
  'AI for research and literature review',
  'Grant and funding application writing',
  'Academic writing and publishing',
  'Lecture and course design with AI',
  'Marking and assessment feedback at scale',
  'Administrative task automation',
  'Presenting and communicating research',
];

const whatToExpect = [
  'Free 30-minute discovery call to assess fit',
  'Bespoke coaching plan for your priorities',
  'Weekly or fortnightly sessions via MS Teams',
  'Hands-on work with your real tasks and documents',
  'Session notes and action points after every call',
  'Email support between sessions included',
  'Flexible scheduling around teaching commitments',
];

const formatTags = [
  'Individual 1-to-1 sessions',
  '4-session starter package',
  'Monthly coaching retainer',
  'Small group (up to 6)',
  'Department cohort coaching',
];
---

<Layout metadata={metadata}>
  <div class="bg-section px-6 pt-8 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-6xl">
      <a
        href="/services/"
        class="inline-flex items-center text-sm font-semibold text-link transition-colors hover:text-accent"
      >
        ← Back to Services
      </a>
    </div>
  </div>

  <section class="bg-brand px-6 py-16 sm:px-8 lg:px-12 lg:py-20" data-aos="fade-up">
    <div class="mx-auto max-w-4xl text-center">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-secondary sm:text-sm">Academic Coaching</p>
      <h1 class="font-heading text-3xl font-bold leading-tight text-white sm:text-4xl lg:text-5xl">
        Personal AI coaching for academics who want to do more
      </h1>
      <p class="mt-6 text-base leading-[var(--aw-leading-body,1.7)] text-white/90 sm:text-lg">
        Intensive 1-to-1 and small group coaching that helps academics use AI to accelerate research, improve teaching,
        reduce admin burden and reclaim time for the work that matters most.
      </p>
    </div>
  </section>

  <section class="border-b border-default bg-section px-6 py-10 sm:px-8 lg:px-12">
    <div class="mx-auto grid max-w-6xl grid-cols-1 gap-6 md:grid-cols-3">
      <div class="rounded-xl border border-default bg-card p-6 text-center shadow-card">
        <p class="font-heading text-3xl font-bold text-heading">6hrs</p>
        <p class="mt-2 text-sm text-muted">Average weekly time saved after 4 coaching sessions</p>
      </div>
      <div class="rounded-xl border border-default bg-card p-6 text-center shadow-card">
        <p class="font-heading text-2xl font-bold text-heading sm:text-3xl">1-to-1</p>
        <p class="mt-2 text-sm text-muted">Or small groups of up to 6 - you choose the format</p>
      </div>
      <div class="rounded-xl border border-default bg-card p-6 text-center shadow-card">
        <p class="font-heading text-3xl font-bold text-heading">Online</p>
        <p class="mt-2 text-sm text-muted">All sessions delivered via MS Teams, no travel required</p>
      </div>
    </div>
  </section>

  <section class="bg-section px-6 py-16 sm:px-8 lg:px-12 lg:py-20">
    <div class="mx-auto max-w-6xl">
      <div class="rounded-xl border border-default bg-card p-6 shadow-card md:p-10" data-aos="fade-up">
        <h2 class="font-heading text-2xl font-bold text-heading sm:text-3xl">
          Why academics benefit from coaching rather than training
        </h2>
        <div class="mt-6 space-y-5 text-default">
          <p>
            Generic AI training rarely meets the specific needs of an academic. A professor of medieval history and a
            lecturer in data science face entirely different challenges and opportunities when it comes to AI - and a
            group workshop cannot address both at once.
          </p>
          <p>
            Academic coaching is different. It starts with your specific workload, your discipline, your frustrations,
            and your ambitions. Together we identify the highest-leverage areas where AI can make a real difference -
            whether that is literature reviewing, grant writing, marking feedback, course design, or academic writing -
            and we work through them practically, with your actual work, in real time.
          </p>
        </div>
      </div>

      <div class="mt-8 grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-10">
        <div class="rounded-xl border border-default bg-card p-6 shadow-card md:p-8" data-aos="fade-up">
          <h3 class="font-heading text-xl font-bold text-heading">Coaching areas</h3>
          <ul class="mt-6 space-y-3">
            {
              coachingAreas.map((item) => (
                <li class="flex gap-3 text-default">
                  <Icon name="tabler:check" class="mt-0.5 h-5 w-5 shrink-0 text-accent" aria-hidden="true" />
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
        <div
          class="rounded-xl border border-default bg-card p-6 shadow-card md:p-8"
          data-aos="fade-up"
          data-aos-delay="50"
        >
          <h3 class="font-heading text-xl font-bold text-heading">What to expect</h3>
          <ul class="mt-6 space-y-3">
            {
              whatToExpect.map((item) => (
                <li class="flex gap-3 text-default">
                  <Icon name="tabler:check" class="mt-0.5 h-5 w-5 shrink-0 text-accent" aria-hidden="true" />
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div class="mt-10 rounded-xl border border-default bg-card p-6 shadow-card md:mt-14 md:p-10" data-aos="fade-up">
        <h2 class="font-heading text-2xl font-bold text-heading sm:text-3xl">Formats and packages</h2>
        <div class="mt-6 space-y-5 text-default">
          <p>
            Coaching is available as individual sessions, structured packages or ongoing monthly arrangements. Small
            group coaching (up to 6 academics from the same department or discipline) is available at a reduced
            per-person rate and is particularly effective for building shared practice across a team.
          </p>
          <p>
            Many academics begin with a four-session starter package to tackle a specific project - a grant application,
            a new module, a book chapter - and then continue on a monthly basis for ongoing support.
          </p>
        </div>
        <div class="mt-6 flex flex-wrap gap-2">
          {
            formatTags.map((tag, i) => (
              <span
                class:list={[
                  'inline-flex rounded-full border px-3 py-1.5 text-sm font-medium',
                  i === 3 ? 'border-accent bg-accent/10 text-accent' : 'border-primary/25 text-default',
                ]}
              >
                {tag}
              </span>
            ))
          }
        </div>
      </div>

      <section class="mt-10 rounded-2xl bg-brand px-6 py-12 text-center sm:px-10 md:mt-14 md:py-16" data-aos="fade-up">
        <h2 class="font-heading text-2xl font-bold text-white sm:text-3xl">Start with a free discovery call</h2>
        <p class="mx-auto mt-4 max-w-2xl text-white/90">
          Book a no-obligation 30-minute session to discuss your specific needs and whether coaching is the right fit.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="/contact/"
            class="inline-flex min-w-[10rem] items-center justify-center rounded-full bg-accent px-8 py-3.5 font-semibold text-white transition-colors hover:bg-accent-hover"
          >
            Book a free call
          </a>
          <a
            href="/services/"
            class="inline-flex min-w-[10rem] items-center justify-center rounded-full border-2 border-white px-8 py-3.5 font-semibold text-white transition-colors hover:bg-white/10"
          >
            View all services
          </a>
        </div>
      </section>
    </div>
  </section>
</Layout>
