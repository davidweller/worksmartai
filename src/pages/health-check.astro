            </button>

            <p id="hc-form-note" class="text-center text-xs leading-relaxed text-slate-500">
              We will use your details to arrange your Health Check and relevant follow-up. Read our{' '}
              <a
                href="/privacy-policy/"
                class="font-semibold text-brand underline-offset-2 hover:text-accent hover:underline">privacy policy</a
              >.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Mobile sticky CTA -->
  <a
    data-mobile-cta-hc
    href="#book"
    class="fixed inset-x-3 bottom-3 z-40 flex items-center justify-center gap-2 rounded-full bg-accent px-5 py-3.5 text-center font-heading text-base font-semibold text-white shadow-card-elevated ring-1 ring-accent/40 transition duration-200 hover:bg-accent-hover lg:hidden"
    aria-label="Jump to the booking form"
  >
    <Icon name="tabler:stethoscope" class="h-5 w-5" />
    Book your free Health Check
  </a>

  <style>
    html {
      scroll-behavior: smooth;
    }
    @media (max-width: 1023px) {
      body {
        padding-bottom: 4.5rem;
      }
    }
  </style>

  <!-- Hide mobile sticky CTA when the form is visible -->
  <script is:inline>
    (function () {
      var cta = document.querySelector('a[data-mobile-cta-hc]');
      var form = document.getElementById('book');
      if (!cta || !form || !('IntersectionObserver' in window)) return;
      var io = new IntersectionObserver(
        function (entries) {
          for (var i = 0; i < entries.length; i++) {
            cta.classList.toggle('opacity-0', entries[i].isIntersecting);
            cta.classList.toggle('pointer-events-none', entries[i].isIntersecting);
          }
        },
        { threshold: 0.25 }
      );
      io.observe(form);
    })();
  </script>

  <!-- Booking form: post to Supabase REST -->
  <script is:inline>
    (function () {
      var form = document.getElementById('hc-booking-form');
      var feedback = document.getElementById('hc-form-feedback');
      if (!form) return;

      var supabaseUrl = (form.getAttribute('data-supabase-url') || '').trim();
      var supabaseAnonKey = (form.getAttribute('data-supabase-anon-key') || '').trim();
      var baseUrl = supabaseUrl.replace(/\/$/, '');
      var restUrl = baseUrl + '/rest/v1/leads';

      function showFeedback(message, isError) {
        if (!feedback) return;
        feedback.textContent = message;
        feedback.className = isError
          ? 'mt-3 rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-center text-sm text-red-800'
          : 'mt-3 rounded-lg border border-green-200 bg-green-50 px-3 py-2 text-center text-sm text-green-800';
      }

      function clearFeedback() {
        if (!feedback) return;
        feedback.textContent = '';
        feedback.className = 'hidden';
      }

      if (!supabaseUrl || !supabaseAnonKey) {
        form.addEventListener('submit', function (e) {
          e.preventDefault();
          showFeedback('Bookings are temporarily unavailable. Please email hello@worksmart-ai.co.uk instead.', true);
        });
        return;
      }

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var fd = new FormData(form);
        var submitBtn = form.querySelector('button[type="submit"]');

        var payload = {
          name: String(fd.get('full_name') || '').trim(),
          email: String(fd.get('work_email') || '').trim(),
          source: String(fd.get('source') || '').trim(),
          metadata: {
            institution: String(fd.get('institution') || '').trim(),
            role: String(fd.get('role') || '').trim(),
            team: String(fd.get('team') || '').trim(),
            team_size: String(fd.get('team_size') || '').trim(),
            message: String(fd.get('message') || '').trim(),
          },
        };

        if (!payload.name || !payload.email) return;

        clearFeedback();
        if (submitBtn) submitBtn.disabled = true;

        fetch(restUrl, {
          method: 'POST',
          headers: {
            apikey: supabaseAnonKey,
            Authorization: 'Bearer ' + supabaseAnonKey,
            'Content-Type': 'application/json',
            Prefer: 'return=minimal',
          },
          body: JSON.stringify(payload),
        })
          .then(function (res) {
            return res.text().then(function (text) {
              if (submitBtn) submitBtn.disabled = false;
              if (res.ok) {
                showFeedback(
                  'Thank you! We will be in touch within two working days to arrange your Health Check.',
                  false
                );
                form.reset();
                return;
              }
              if (typeof console !== 'undefined' && console.error) {
                console.error('[WorkSmart] Health Check booking failed', { status: res.status, detail: text });
              }
              showFeedback('Something went wrong. Please try again or email hello@worksmart-ai.co.uk.', true);
            });
          })
          .catch(function () {
            if (submitBtn) submitBtn.disabled = false;
            showFeedback(
              'Something went wrong. Check your connection and try again, or email hello@worksmart-ai.co.uk.',
              true
            );
          });
      });
    })();
  </script>
</Layout>
