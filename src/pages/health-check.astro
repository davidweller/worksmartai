            <div>
              <label for="hc-team-size" class="block text-sm font-semibold text-slate-900">Approximate team size</label>
              <select
                id="hc-team-size"
                name="team_size"
                required
                class="mt-1.5 block w-full rounded-xl border border-slate-200 bg-slate-50/80 px-4 py-3 text-base text-slate-900 shadow-sm transition focus:border-accent focus:bg-white focus:outline-none focus:ring-2 focus:ring-accent/25"
              >
                <option value="" disabled selected>Select team size</option>
                <option value="1-10">1-10</option>
                <option value="11-25">11-25</option>
                <option value="26-50">26-50</option>
                <option value="51-100">51-100</option>
                <option value="100+">100+</option>
              </select>
            </div>

            <div>
              <label for="hc-message" class="block text-sm font-semibold text-slate-900">
