---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'AI Health Check for higher education teams - WorkSmart-AI',
  description:
    'A free 45-minute AI Health Check for UK higher education teams. We map where your team is today, where the realistic next steps are, and what credible progress looks like over the next twelve months.',
  canonical: '/health-check/',
  openGraph: {
    images: [{ url: '/images/health-check-og.png' }],
    type: 'website',
  },
};

const faqs = [
  {
    q: 'Is the Health Check really free?',
    a: 'Yes. There is no fee, no commitment, and no requirement to do anything further. It exists because the most useful conversations we have with potential clients tend to start from a shared understanding of where their team actually is, and the Health Check is the most efficient way to build that.',
  },
  {
    q: 'Who will I be speaking to?',
    a: 'You will speak with one of the WorkSmart-AI founders, both of whom previously held Digital Skills Lead roles at a UK university before starting the business. You will not be passed to a junior account manager.',
  },
  {
    q: 'What information do you need before the call?',
    a: 'Very little. The booking form asks for your name, institution, role, the team or department the Health Check is for, and rough team size. We do not ask for confidential information, and you do not need to send documents in advance.',
  },
  {
    q: 'Can I bring colleagues?',
    a: 'Yes. Many heads of department find it useful to invite an L&D partner, digital lead, or deputy. We would suggest a maximum of three people on the call to keep the conversation focused.',
  },
  {
    q: 'Will you try to sell me a workshop at the end?',
    a: 'No. If something we offer looks like a genuine fit for what you have described, we will say so, and you can decide whether to explore that separately. If nothing fits, we will tell you that too. The Health Check is the deliverable, not the bait.',
  },
  {
    q: 'What if my team is at a very early stage and I would feel embarrassed to talk about it?',
    a: 'Most teams are at a very early stage. Honestly, that is the median position in higher education right now, and there is no judgement attached to it. The Health Check is more useful, not less, the earlier you are.',
  },
  {
    q: 'Is this only for UK universities?',
    a: 'We work primarily with UK higher education institutions. We will run a Health Check for further education colleges and other education settings on request, but the framework and benchmarks are most precisely calibrated for UK HE.',
  },
];

const steps = [
  {
    icon: 'tabler:calendar-event',
    title: 'Book a slot',
    body: 'Get in touch to tell us a little about your team and pick a 45-minute window that suits you. We will send a short note in advance explaining the kinds of questions we will cover, so you can think about what you want to bring to the conversation.',
  },
  {
    icon: 'tabler:messages',
    title: 'The conversation',
    body: 'A 45-minute call over Teams or Zoom. No slides, no sales pitch, no homework. We ask, you talk, we listen and probe where it helps. The agenda is shaped around your team and what would be most useful for you to leave with.',
  },
  {
    icon: 'tabler:mail-forward',
    title: 'Your written summary',
    body: 'Within three working days you receive a written Health Check summary by email. It is yours to share, file, ignore, or act on, as you see fit. If you want a follow-up conversation to talk through it, we are happy to. If you do not, that is genuinely fine.',
  },
];

const deliverables = [
  {
    icon: 'tabler:chart-dots-3',
    title: 'A current-state snapshot',
    body: 'A clear, evidence-based view of where your team sits on the AI Use Hierarchy today, including the realistic distribution across your staff. Most teams are not all at one level, and that itself matters.',
  },
  {
    icon: 'tabler:list-check',
    title: 'A prioritised set of next moves',
    body: "Two or three specific, achievable steps that would meaningfully shift your team's capability in the next quarter, sequenced sensibly so foundations come before sophistication.",
  },
  {
    icon: 'tabler:telescope',
    title: 'A twelve-month outlook',
    body: 'A short narrative on what credible progress looks like for a team like yours over the next year, including which staff groups would benefit from what kind of support, and where the obvious quick wins sit alongside the deeper capability shifts.',
  },
];
---

<Layout metadata={metadata}>
  <!-- =========================================================
       HERO
       ========================================================= -->
  <section
    class="relative overflow-hidden bg-brand px-6 pb-20 pt-16 sm:px-8 md:pb-24 md:pt-20 lg:px-12"
    aria-labelledby="hc-hero-heading"
  >
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-brand via-brand to-[#013a5c] opacity-95">
    </div>
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.07]"
      style="background-image:radial-gradient(rgba(255,255,255,0.9) 1px, transparent 1px);background-size:22px 22px;"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-accent/20 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute -bottom-32 -left-16 h-80 w-80 rounded-full bg-secondary/20 blur-3xl"
      aria-hidden="true"
    >
    </div>

    <div class="relative mx-auto max-w-4xl text-center text-white" data-aos="fade-up">
      <h1
        id="hc-hero-heading"
        class="font-heading text-4xl font-bold leading-tight sm:text-5xl lg:text-[3rem] lg:leading-[1.1]"
      >
        Where does your team <br />really sit with AI?
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-[var(--aw-leading-body,1.7)] text-white/90">
        A free AI Health Check for higher education teams, departments, and faculties. We map where your team is today,
        where the realistic next steps are, and what credible progress looks like over the next twelve months.
      </p>
      <div class="mt-8">
        <a
          href="/contact-us/"
          class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-accent bg-accent px-7 py-3.5 font-heading font-semibold text-white shadow-lg shadow-accent/25 transition hover:-translate-y-0.5 hover:border-accent-hover hover:bg-accent-hover focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-brand"
        >
          <Icon name="tabler:stethoscope" class="h-5 w-5 shrink-0" aria-hidden="true" />
          Book your free AI Health Check
        </a>
      </div>
      <p class="mt-5 flex flex-wrap items-center justify-center gap-x-2 gap-y-1 text-sm text-white/70">
        <Icon name="tabler:shield-check" class="h-4 w-4 text-accent" aria-hidden="true" />
        <span>No prep required.</span>
        <span class="opacity-50">&middot;</span>
        <span>45 minutes.</span>
        <span class="opacity-50">&middot;</span>
        <span>A written summary in your inbox afterwards.</span>
      </p>
    </div>
  </section>

  <!-- =========================================================
       SECTION 1 - What the AI Health Check is
       ========================================================= -->
  <section class="bg-page px-6 py-20 sm:px-8 lg:px-12" aria-labelledby="what-is-heading">
    <div class="mx-auto max-w-3xl" data-aos="fade-up">
      <h2 id="what-is-heading" class="font-heading text-3xl font-bold text-heading sm:text-4xl">
        What the AI Health Check is
      </h2>
      <p class="mt-6 text-base leading-[var(--aw-leading-body,1.7)] text-default">
        The Health Check is a focused, free diagnostic for a specific team, department, or faculty. It is built around
        the WorkSmart-AI Use Hierarchy, a six-level framework that describes how individual staff progress in their AI
        capability, from first conversations with a chatbot through to designing automated workflows.
      </p>
      <p class="mt-5 text-base leading-[var(--aw-leading-body,1.7)] text-default">
        You do not need to prepare anything. You do not need to have your team complete a survey beforehand (although we
        can run one if you want a more detailed snapshot). What you do need is around 45 minutes with someone who knows
        the team well enough to answer questions about how staff currently work, what tools are in use, where the
        friction is, and what would constitute a meaningful win in the next six to twelve months.
      </p>
      <p class="mt-5 text-base leading-[var(--aw-leading-body,1.7)] text-default">
        From that conversation, we produce a written summary that you can share with colleagues, take to your senior
        team, or use to inform your own planning. It is yours to keep, whether or not you ever speak to us again.
      </p>
    </div>
  </section>

  <!-- =========================================================
       SECTION 2 - What you get
       ========================================================= -->
  <section class="bg-section px-6 py-20 sm:px-8 lg:px-12" aria-labelledby="what-you-get-heading">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center" data-aos="fade-up">
        <h2 id="what-you-get-heading" class="font-heading text-3xl font-bold text-heading sm:text-4xl">What you get</h2>
        <p class="mt-5 text-base leading-[var(--aw-leading-body,1.7)] text-muted">
          Every AI Health Check produces three things.
        </p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          deliverables.map((card, i) => (
            <article
              class="flex h-full flex-col rounded-2xl border border-slate-200/90 bg-white p-6 shadow-[0_4px_24px_-8px_rgba(0,36,56,0.12)] transition duration-300 hover:-translate-y-0.5 hover:shadow-[0_12px_40px_-12px_rgba(0,36,56,0.18)]"
              data-aos="fade-up"
              data-aos-delay={i * 80}
            >
              <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-brand text-white shadow-sm">
                <Icon name={card.icon} class="h-5 w-5" aria-hidden="true" />
              </span>
              <h3 class="mt-5 font-heading text-xl font-bold text-heading">{card.title}</h3>
              <p class="mt-3 text-base leading-relaxed text-muted">{card.body}</p>
            </article>
          ))
        }
      </div>

      <p
        class="mx-auto mt-10 max-w-3xl text-center text-base leading-[var(--aw-leading-body,1.7)] text-muted"
        data-aos="fade-up"
      >
        The summary is written in plain English, free of jargon, and designed to be useful even if AI is not your
        specialist area.
      </p>
    </div>
  </section>

  <!-- =========================================================
       SECTION 3 - Who it is for
       ========================================================= -->
  <section class="bg-page px-6 py-20 sm:px-8 lg:px-12" aria-labelledby="who-for-heading">
    <div class="mx-auto max-w-3xl" data-aos="fade-up">
      <h2 id="who-for-heading" class="font-heading text-3xl font-bold text-heading sm:text-4xl">Who it is for</h2>
      <p class="mt-6 text-base leading-[var(--aw-leading-body,1.7)] text-default">
        The AI Health Check is most useful if you lead, manage, or have oversight of a team in a UK higher education
        institution. That includes heads of department, faculty deans, professional services managers, programme
        directors, research group leads, and anyone in HR, L&amp;D, or digital roles thinking about staff capability at
        team level rather than across the whole institution.
      </p>
      <p class="mt-5 text-base leading-[var(--aw-leading-body,1.7)] text-default">
        It is particularly useful if you are facing a budget conversation, a strategy refresh, an audit, or a senior
        leadership request for &ldquo;the AI plan&rdquo; and you would like to be able to answer that question with
        evidence rather than impressions.
      </p>
      <p class="mt-5 text-base leading-[var(--aw-leading-body,1.7)] text-default">
        It is not the right tool if you are looking for an individual self-assessment (our free AI Staff Readiness Quiz
        is the better starting point for that) or if you are looking for an institution-wide strategic review (in which
        case our AI Leadership Clarity Programme is the more appropriate engagement).
      </p>
    </div>
  </section>

  <!-- =========================================================
       SECTION 4 - How it works
       ========================================================= -->
  <section class="bg-section px-6 py-20 sm:px-8 lg:px-12" aria-labelledby="how-it-works-heading">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center" data-aos="fade-up">
        <h2 id="how-it-works-heading" class="font-heading text-3xl font-bold text-heading sm:text-4xl">How it works</h2>
        <p class="mt-5 text-base leading-[var(--aw-leading-body,1.7)] text-muted">
          Three steps, and the whole process takes about a week from booking to receiving your summary.
        </p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          steps.map((step, i) => (
            <article
              class="relative flex h-full flex-col rounded-2xl border border-slate-200/90 bg-white p-6 shadow-[0_4px_24px_-8px_rgba(0,36,56,0.12)] transition duration-300 hover:-translate-y-0.5 hover:shadow-[0_12px_40px_-12px_rgba(0,36,56,0.18)]"
              data-aos="fade-up"
              data-aos-delay={i * 80}
            >
              <div class="flex items-start justify-between gap-3">
                <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-accent text-white shadow-sm">
                  <Icon name={step.icon} class="h-5 w-5" aria-hidden="true" />
                </span>
                <span class="font-heading text-2xl font-bold leading-none text-slate-300 tabular-nums">
                  {String(i + 1).padStart(2, '0')}
                </span>
              </div>
              <h3 class="mt-5 font-heading text-xl font-bold text-heading">{step.title}</h3>
              <p class="mt-3 text-base leading-relaxed text-muted">{step.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- =========================================================
       SECTION 5 - What happens after
       ========================================================= -->
  <section class="bg-page px-6 py-20 sm:px-8 lg:px-12" aria-labelledby="after-heading">
    <div class="mx-auto max-w-3xl" data-aos="fade-up">
      <h2 id="after-heading" class="font-heading text-3xl font-bold text-heading sm:text-4xl">What happens after</h2>
      <p class="mt-6 text-base leading-[var(--aw-leading-body,1.7)] text-default">
        Some teams take the Health Check, use the summary internally, and we never hear from them again. That is a
        perfectly good outcome. The point of the offer is to give you something useful, not to manufacture a sales
        conversation.
      </p>
      <p class="mt-5 text-base leading-[var(--aw-leading-body,1.7)] text-default">
        Where teams do want to take next steps with us, the most common routes are a single targeted workshop (for
        example, AI Foundations and Responsible Use for all staff, or a role-specific session for academics,
        researchers, or professional services), a phased twelve-workshop programme mapped to the hierarchy, or, for
        senior leaders, an institutional-level engagement through our AI Leadership Clarity Programme. Pricing and
        structure for all of these can be discussed if and when it is useful.
      </p>
      <p class="mt-5 text-base leading-[var(--aw-leading-body,1.7)] text-default">
        You are under no obligation to do any of this. The Health Check stands on its own.
      </p>
    </div>
  </section>

  <!-- =========================================================
       MID-PAGE CTA
       ========================================================= -->
  <section class="bg-section px-6 py-20 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-3xl text-center" data-aos="fade-up">
      <p class="font-heading text-2xl font-bold text-heading sm:text-3xl">
        Ready to find out where your team really stands?
      </p>
      <div class="mt-8">
        <a
          href="/contact-us/"
          class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-accent bg-accent px-7 py-3.5 font-heading font-semibold text-white shadow-lg shadow-accent/25 transition hover:-translate-y-0.5 hover:border-accent-hover hover:bg-accent-hover focus:outline-none focus:ring-2 focus:ring-focus focus:ring-offset-2"
        >
          <Icon name="tabler:stethoscope" class="h-5 w-5 shrink-0" aria-hidden="true" />
          Book your free AI Health Check
        </a>
      </div>
    </div>
  </section>

  <!-- =========================================================
       SECTION 6 - FAQ
       ========================================================= -->
  <section class="bg-page px-6 py-20 sm:px-8 lg:px-12" aria-labelledby="faq-heading">
    <div class="mx-auto max-w-3xl">
      <div class="text-center" data-aos="fade-up">
        <p class="font-heading text-sm font-bold uppercase tracking-[0.22em] text-accent">Common questions</p>
        <h2 id="faq-heading" class="mt-4 font-heading text-3xl font-bold text-heading sm:text-4xl">
          Frequently asked questions
        </h2>
      </div>

      <div class="mt-10 space-y-3">
        {
          faqs.map((item, i) => (
            <details
              class="group rounded-xl border border-slate-200/90 bg-white px-5 py-4 shadow-[0_2px_16px_-4px_rgba(0,36,56,0.08)] transition open:shadow-[0_8px_28px_-8px_rgba(0,36,56,0.12)]"
              data-aos="fade-up"
              data-aos-delay={i * 60}
            >
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-heading text-base font-semibold text-heading">
                <span>{item.q}</span>
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-slate-200 text-slate-500 transition group-open:rotate-180">
                  <Icon name="tabler:chevron-down" class="h-4 w-4" aria-hidden="true" />
                </span>
              </summary>
              <p class="mt-3 border-t border-slate-100 pt-3 text-base leading-relaxed text-muted">{item.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- =========================================================
       FINAL CTA
       ========================================================= -->
  <section class="bg-brand px-6 py-20 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-3xl text-center text-white" data-aos="fade-up">
      <h2 class="font-heading text-3xl font-bold sm:text-4xl">Find out where your team really stands.</h2>
      <p class="mt-5 text-base leading-[var(--aw-leading-body,1.7)] text-white/90">
        45 minutes. A written summary in your inbox. No obligation, no sales pitch, no jargon. Just a clear,
        evidence-based view of where your team is today and what credible next steps look like.
      </p>
      <div class="mt-8">
        <a
          href="/contact-us/"
          class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-accent bg-accent px-7 py-3.5 font-heading font-semibold text-white shadow-lg shadow-accent/25 transition hover:-translate-y-0.5 hover:border-accent-hover hover:bg-accent-hover focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-brand"
        >
          <Icon name="tabler:stethoscope" class="h-5 w-5 shrink-0" aria-hidden="true" />
          Book your free AI Health Check
        </a>
      </div>
      <p class="mt-5 text-sm text-white/70">
        Or email <a
          href="mailto:hello@worksmart-ai.co.uk"
          class="font-semibold text-accent underline-offset-2 hover:underline">hello@worksmart-ai.co.uk</a
        > with any questions before you book.
      </p>
    </div>
  </section>

  <style>
    html {
      scroll-behavior: smooth;
    }
  </style>
</Layout>
