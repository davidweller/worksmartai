---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Training - WorkSmart-AI',
  description: 'Build the AI confidence and capability your organisation needs.',
  canonical: '/training/',
};

const includedItems = [
  { title: 'Free Initial Consultation', description: "A collaborative discussion to understand your institution's goals and challenges and see where you are on your AI journey.", icon: 'tabler:messages' },
  { title: 'On-Demand Access to Online Courses', description: 'On-demand access to asynchronous courses that reinforce and extend the learning from our live workshops, for up to 100 staff per package.', icon: 'tabler:device-laptop' },
  { title: 'AI Literacy & Needs Analysis', description: 'We pinpoint knowledge gaps and confidence levels across your team(s) to ensure our training is targeted and effective.', icon: 'tabler:chart-dots' },
  { title: 'Strategic Roadmap Session', description: 'A high-level session with your leadership to translate training insights into a clear action plan for sustaining momentum.', icon: 'tabler:route' },
  { title: 'Personalised Workshops', description: 'Choose which of our workshops for us to personalise and deliver. Expert-led, hands-on training sessions (F2F or online) tailored to your institution.', icon: 'tabler:presentation' },
  { title: 'Ongoing Support for Staff and SLT', description: 'Continuous access to resources and our ?AI Cafe? drop-in sessions to keep momentum strong as AI evolves. Follow up calls with SLT.', icon: 'tabler:lifebuoy' },
];

const workshopGroups = [
  { title: 'All-Staff Workshops', rows: [['W1. AI Foundations & Responsible Use', 'Foundation', ''], ['W2. AI for Daily Workflows (Email, Meetings, and Comms)', 'Foundation', 'W1 or similar'], ['W3. AI for Summarising and Analysing (Word & Excel)', 'Foundation', 'W1 or similar'], ['W4. Building Custom AI Agents', 'Intermediate', 'W2 or W3']] },
  { title: 'Academic Workshops', rows: [['W5. AI for Academic Content Creation (AI Before Class)', 'Intermediate', 'W1 or similar'], ['W6. The AI-Enabled Classroom: Pedagogy & Practice (AI During Class)', 'Intermediate', 'W1 or similar'], ['W7. AI for Academic Assessments (AI after Class)', 'Intermediate', 'W1 or similar'], ['W8. AI for Researchers', 'Foundation', '']] },
  { title: 'Professional Services Workshops', rows: [['W9. AI for Process Improvement', 'Intermediate', 'W2 or similar'], ['W10. AI for Comms and Engagement', 'Intermediate', 'W2 or similar']] },
  { title: 'Leadership Planning Workshops', rows: [['W11. The AI Leadership Briefing (3-hour)', 'Strategic', ''], ['W12. The AI Strategic Roadmap (Full day)', 'Strategic', 'W11']] },
];

const whyItems = [
  { title: 'Higher Ed Specialists', description: 'We have been working with Universities for over a decade, supporting senior leaders and their staff to feel confident in making effective technological change. Understanding the business needs, whilst appreciating people?s concerns and anxieties when it comes to new digital and AI technologies, underpins everything that we do.', icon: 'tabler:school' },
  { title: 'Data-Driven ROI', description: 'We understand the importance of being able to prove ROI whenever key decisions are made. That?s why everything we do is underpinned by data. From the initial consultation, right through to training and delivery, we use cutting-edge technology to support our approach, evidence impact and drive the returns.', icon: 'tabler:chart-bar' },
  { title: 'Bespoke Workshops', description: 'Evidence proves that one-off workshops don?t work when it comes to enabling effective digital transformation to happen in the workplace. That?s why we offer personalised consultancy, training and support packages - working with you to meet the specific needs of your institution and your budget.', icon: 'tabler:users' },
];

const faqItems = [
  { title: 'What makes WorkSmart-AI different from other AI training providers?', description: 'We focus on people-first adoption - helping staff feel confident and productive with AI and supporting leadership teams to make strategic data-driven implementation decisions. As AI specialists within higher education, we understand the needs and challenges experienced by staff, and are here to support you in overcoming them. Rather than just demonstrating tools, our training connects AI use to real measurable outcomes, like time saved, improved productivity, and better policy alignment. We also personalise our training to adhere to individual institutions AI and data policies.' },
  { title: 'Who are your services designed for?', description: 'Our core audience is universities and education providers - supporting both academic and professional services staff. We also work with local councils, public sector bodies, and SMEs across the South West who want to build practical AI capability and confidence.' },
  { title: 'How do you personalise training for each organisation?', description: 'Every project begins with a free consultation. We then continue with a needs analysis to identify your current use of AI, challenges, and goals. From there, we design a tailored roadmap that ensures all workshops, online courses, and resources address your specific context, policies and priorities. Through regular data-monitoring, we?re able to iterate training to ensure that outcomes are fully achieved.' },
  { title: 'What topics do you cover in training?', description: 'Our training covers AI for research and academic workflows, AI fundamentals and safe ethical use, productivity and process improvement, teaching and assessment with AI, policy development and governance, and environmental impact and sustainability considerations.' },
  { title: 'Can you deliver training in person as well as online?', description: 'Yes. We offer a mix of in-person workshops, live online webinars, and asynchronous on-demand courses. Most clients choose a blended approach so staff can learn flexibly and apply their learning right away.' },
  { title: 'How do you measure the impact of your training?', description: 'We track both staff engagement and tangible outcomes, such as hours saved, efficiency gains, and staff confidence. For larger partnerships, we provide dashboards and reports showing the value of AI adoption over time.' },
  { title: 'What?s included in your programmes?', description: 'All packages include free initial consultation, staff training needs analysis, personalised roadmap and action plan, access to online learning resources, expert-led workshops, pedagogical best practice guidance, ongoing support, monthly online drop-in sessions, follow-up review and next steps. If you?re interested in specific tools or training that you don?t see here, please let us know - we?ll be able to work with you to ensure your priorities are covered in our training.' },
  { title: 'Do you offer ongoing support?', description: 'Yes. Beyond one-off training, we provide Training-as-a-Service retainers for continuous AI upskilling, policy development, and impact measurement - ensuring progress and implementation doesn?t stop after the workshops.' },
  { title: 'How do we get started?', description: 'Book a free consultation to discuss your goals. We?ll help you assess your organisation?s AI readiness, identify the best training approach, and design a package that delivers measurable results.' },
];
---

<Layout metadata={metadata}>
  <Hero
    tagline="Training"
    title="Training Packages"
    subtitle="Build the AI confidence and capability your organisation needs. From foundational literacy to strategic leadership, our tailored training helps every member of your team adopt AI with confidence, responsibility, and measurable impact."
    actions={[{ variant: 'primary', text: 'Book a Call', href: '/book-a-call/' }, { text: 'Email Us', href: '/contact-us/' }]}
    image="<img src='https://worksmart-ai.co.uk/wp-content/uploads/2025/10/medium-shot-people-learning-job-1024x683.jpg' alt='' class='mx-auto w-full rounded-2xl shadow-sm' />"
  />

  <Features2 title="All-Inclusive Training Package" subtitle="Our all-inclusive training package gives you the opportunity to personalise your training needs - selecting which workshops your staff require, dependant on roles and experience. All in-person/ online workshops are supported by asynchronous courses, to help reinforce and further embed learning. Monthly ?AI Cafe?s? are also included, to help learners with their application and exploration journey. Throughout, we regularly update you and run a data-driven strategic roadmap session at the end to support your future developments." columns={3} items={includedItems} />

  <section id="workshops" class="bg-[#f8f8f8] px-6 py-16 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="font-heading text-3xl font-bold text-[#015887] sm:text-4xl">Choose Your Workshops</h2>
        <p class="mt-4 text-base text-[#1b0101]/75">All packages include a three-hour long workshop, which you can choose from the list below. We?re always keen to personalise our offering, so if you?d like additional or different workshops, or you?d like to include additional people, then please give us a call.</p>
      </div>
      <div class="mt-10 grid gap-6">
        {workshopGroups.map((group) => (
          <article class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-[#015887]/10">
            <div class="border-b border-[#015887]/10 bg-[#015887] px-5 py-4"><h3 class="font-heading text-xl font-bold text-white">{group.title}</h3></div>
            <div class="overflow-x-auto">
              <table class="w-full min-w-[700px] text-left text-sm">
                <thead class="bg-[#86bfe2]/20 text-[#015887]"><tr><th class="px-5 py-3">Workshop</th><th class="px-5 py-3">Level</th><th class="px-5 py-3">Prerequisite</th></tr></thead>
                <tbody>{group.rows.map((row) => <tr class="border-t border-[#015887]/10"><td class="px-5 py-3 font-medium text-[#1b0101]">{row[0]}</td><td class="px-5 py-3 text-[#1b0101]/75">{row[1]}</td><td class="px-5 py-3 text-[#1b0101]/75">{row[2]}</td></tr>)}</tbody>
              </table>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white px-6 py-16 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-4xl rounded-2xl bg-[#f8f8f8] p-8 ring-1 ring-[#015887]/10">
      <h2 class="font-heading text-3xl font-bold text-[#015887]">Senior Leader Consulting</h2>
      <p class="mt-4 text-base leading-[var(--aw-leading-body,1.7)] text-[#1b0101]/75">This highly interactive and personalised consulting helps strategic leaders identify opportunities and overcome challenges that AI poses to their teams. Designed entirely around your institution?s AI and Data policies, this in-person workshop is focused on supporting leaders to be able to make informed decisions when it comes to the next steps in their AI journey.</p>
    </div>
  </section>

  <Features2 title="Why choose WorkSmart-AI?" columns={3} items={whyItems} />
  <FAQs title="Frequently Asked Questions" columns={1} items={faqItems} />
  <CallToAction title="Ready to upskill with AI?" subtitle="Book a call at a time that suits you, or email us and we?ll reach out." actions={[{ variant: 'primary', text: 'Book a Call', href: '/book-a-call/' }, { text: 'Email Us', href: '/contact-us/' }]} />
</Layout>
