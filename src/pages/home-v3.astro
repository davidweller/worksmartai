---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import Features2 from '~/components/widgets/Features2.astro';
import ROICalculator from '~/components/widgets/ROICalculator.astro';
import Button from '~/components/ui/Button.astro';
import HomeFooter from '~/components/home/HomeFooter.astro';

const metadata = {
  title: 'AI Capability Built for Higher Education | WorkSmart-AI',
  description:
    'AI training and consultancy built for UK higher education. We help institutions move staff from anxious bystanders to confident, capable practitioners - with hours saved tracked and reported, not estimated.',
  canonical: 'https://worksmart-ai.co.uk/home-v3/',
  robots: {
    index: false,
    follow: false,
  },
};

const previewHeaderData = {
  links: [
    { text: 'Services', href: '/services/' },
    { text: 'About', href: '/about-us/' },
    { text: 'News', href: '/news/' },
  ],
  actions: [
    {
      text: 'Book a call',
      href: '/contact/',
      variant: 'primary' as const,
      class: '!border-[#FF7700] !bg-[#FF7700] font-heading font-bold hover:!border-[#e55f00] hover:!bg-[#e55f00]',
    },
  ],
};

const serviceItems = [
  {
    title: 'Staff capability',
    description:
      'Role-specific AI training for professional services, academic and research staff. Designed to embed, not just to demonstrate.',
    icon: 'tabler:users',
    callToAction: { text: 'Learn more →', href: '/services/staff-training/', variant: 'link' as const },
  },
  {
    title: 'Student programmes',
    description:
      'Structured AI literacy that equips students with the skills, judgement and ethics to use AI confidently in their studies and careers.',
    icon: 'tabler:school',
    callToAction: { text: 'Learn more →', href: '/services/student-training/', variant: 'link' as const },
  },
  {
    title: 'Leadership advisory',
    description:
      'Practical AI consulting for SLT, deans and HoDs translating strategy into action without losing academic confidence.',
    icon: 'tabler:crown',
    callToAction: { text: 'Learn more →', href: '/services/senior-consulting/', variant: 'link' as const },
  },
  {
    title: 'Talks and away days',
    description:
      'Single-engagement sessions for conferences, leadership days or team events. A confident, sector-aware introduction.',
    icon: 'tabler:presentation',
    callToAction: { text: 'Learn more →', href: '/services/talks-workshops/', variant: 'link' as const },
  },
];

const partnershipIncludes = [
  'Free initial consultation',
  'AI literacy and needs analysis',
  'Personalised workshops, in-person or online',
  'On-demand courses for up to 100 staff',
  'Strategic roadmap session with your SLT',
  'Ongoing AI Café drop-in sessions',
  'Follow-up calls with leadership',
];

const journeyStages = [
  {
    num: '01',
    title: 'Recognising the strategic priority',
    body: 'AI is on every board agenda. You know you need a coordinated response, not a series of individual experiments.',
  },
  {
    num: '02',
    title: 'Understanding your starting point',
    body: 'Before you build a plan, you need an honest picture of staff capability, current usage and risk exposure across the institution.',
  },
  {
    num: '03',
    title: 'Building the institutional plan',
    body: 'Translating insight into a board-ready roadmap with measurable outcomes, accountable owners and a realistic timeline.',
  },
  {
    num: '04',
    title: 'Equipping staff with confidence and capability',
    body: 'Role-specific training that respects the difference between an academic, a finance officer and a student services lead.',
  },
  {
    num: '05',
    title: 'Embedding and sustaining',
    body: 'AI evolves quickly. Your institution needs structures that keep momentum after the initial push.',
  },
];

const guideBullets = [
  'Real examples from teaching, research and professional services',
  'Time-saved estimates for common tasks',
  'Practical prompts your staff can use today',
  'Honest notes on what works and what doesn\u2019t in an HE context',
];
---

<Layout metadata={metadata}>
  <Header slot="header" {...previewHeaderData} isSticky showToggleTheme />

  <!-- 1. Hero -->
  <section class="relative md:-mt-[76px] not-prose bg-[#015887]" no-intersect>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6">
      <div class="pointer-events-none pt-0 md:pt-[24px]"></div>
      <div class="flex flex-col items-center gap-10 py-12 md:py-20 lg:flex-row lg:items-center lg:gap-8 lg:py-20">
        <div class="w-full basis-1/2 pb-4 text-center lg:pb-0 lg:text-left">
          <h1 class="mb-4 font-heading text-4xl font-bold leading-tight tracking-tight text-white md:text-[2.5rem]">
            AI Capability Built for Higher Education
          </h1>
          <p class="mb-4 max-w-xl font-sans text-base text-white/75 lg:max-w-none">
            Your staff move from anxious bystanders to confident, capable practitioners. Hours saved, tracked and
            reported - not estimated.
          </p>
          <p class="mb-8 max-w-xl font-sans text-sm text-[#86BFE2] lg:max-w-none">
            Built by people who worked inside universities, not consultants who studied it from the outside.
          </p>
          <div class="mx-auto flex max-w-md flex-col gap-4 lg:mx-0 lg:max-w-none lg:items-start">
            <Button
              variant="primary"
              text="Book a free call"
              href="/contact/"
              class="w-full !border-[#FF7700] !bg-[#FF7700] font-heading font-bold hover:!border-[#e55f00] hover:!bg-[#e55f00] sm:w-auto"
            />
            <a href="/services/" class="font-heading text-sm font-bold text-white transition hover:text-[#86BFE2]">
              View our services &rarr;
            </a>
          </div>
          <p class="mt-6 max-w-xl font-sans text-xs text-white/55 lg:max-w-none">
            No obligation, no slides, no pitch deck. Just a conversation about where you are.
          </p>
        </div>
        <div class="w-full basis-1/2">
          <img
            src="/images/home-hero-photo.png"
            alt="Team collaborating around a table with sticky notes during a planning session"
            width={1200}
            height={800}
            loading="eager"
            decoding="async"
            class="mx-auto w-full rounded-2xl"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- 2. The HE context -->
  <section class="bg-white px-6 py-16 sm:px-8 lg:px-12" no-intersect aria-labelledby="he-context-heading">
    <div class="mx-auto max-w-3xl text-center">
      <p class="font-heading text-[11px] font-bold uppercase tracking-[0.2em] text-[#FF7700]">
        Where higher education is today
      </p>
      <h2 id="he-context-heading" class="mt-3 font-heading text-3xl font-bold text-[#015887] sm:text-4xl">
        A capability gap that students notice.
      </h2>
    </div>
    <blockquote class="mx-auto mt-12 max-w-[640px] rounded-xl bg-[#013A5A] px-8 py-10 text-center">
      <p class="font-heading text-[40px] font-bold leading-none text-[#FF7700]" aria-hidden="true">&ldquo;</p>
      <p class="-mt-4 font-sans text-sm italic leading-[1.7] text-white/85">
        Students see AI skills as essential, but institutional support lags behind. While over two-thirds of students
        believe AI skills are essential to thrive in today&rsquo;s world, fewer than half feel their teaching staff are
        helping them develop those skills.
      </p>
      <footer class="mt-6 font-sans text-[11px] text-[#86BFE2]">
        HEPI / Kortext Student Generative AI Survey, 2026
      </footer>
    </blockquote>
  </section>

  <!-- 3. What we do for higher education -->
  <div no-intersect>
    <Features2
      columns={4}
      items={serviceItems}
      classes={{
        container: 'max-w-6xl',
        headline: {
          tagline: 'font-heading text-[11px] font-bold uppercase tracking-[0.2em] text-[#FF7700]',
          title: 'font-heading text-3xl font-bold text-[#015887] sm:text-4xl',
          subtitle: 'mt-4 font-sans text-sm text-[#1B0101]',
          container: 'max-w-3xl',
        },
        items: {
          container: 'gap-4 md:gap-6 md:grid-cols-2 lg:grid-cols-4',
          panel:
            'rounded-xl border border-[#E0E0E0] bg-white p-6 shadow-none [border-width:0.5px] flex-col items-start',
          icon: 'mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-[#E6F1FB] p-2 text-[#015887]',
          title: 'font-heading text-lg font-bold text-[#015887]',
          description: 'font-sans text-sm text-[#1B0101]',
        },
      }}
    >
      <Fragment slot="tagline">Services</Fragment>
      <Fragment slot="title">AI support designed for every part of the institution.</Fragment>
      <Fragment slot="subtitle">
        Whether you need to lift staff capability, equip students for an AI-shaped workplace, or give your leadership
        team a confident strategic position, we have a programme that fits.
      </Fragment>
    </Features2>
    <div class="mx-auto max-w-6xl -mt-4 pb-16 text-center">
      <a href="/services/" class="font-heading text-sm font-bold text-[#015887] transition hover:text-[#FF7700]">
        See all our services &rarr;
      </a>
    </div>
  </div>

  <!-- 4. The AI Partnership -->
  <section class="bg-[#015887] px-6 py-16 sm:px-8 lg:px-12" no-intersect aria-labelledby="partnership-heading">
    <div class="mx-auto max-w-6xl">
      <p class="font-heading text-[11px] font-bold uppercase tracking-[0.2em] text-[#86BFE2]">Our flagship offering</p>
      <h2 id="partnership-heading" class="mt-3 font-heading text-3xl font-bold text-white sm:text-4xl">
        The AI Partnership
      </h2>
      <p class="mt-4 max-w-3xl font-sans text-sm leading-[1.7] text-white/75">
        A wrap-around programme that takes your institution from scattered AI experimentation to a coordinated,
        evidenced approach. Built around your roles, your policies, and your academic calendar.
      </p>
      <ul class="mt-10 grid gap-3 sm:grid-cols-2" aria-label="What's included in the AI Partnership">
        {
          partnershipIncludes.map((item) => (
            <li class="flex items-start gap-3 font-sans text-sm text-white/90">
              <span
                class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[#FF7700] text-xs font-bold text-white"
                aria-hidden="true"
              >
                &#10003;
              </span>
              {item}
            </li>
          ))
        }
      </ul>
      <div class="mt-10">
        <Button
          variant="primary"
          text="Discuss the AI Partnership"
          href="/contact/"
          class="!border-[#FF7700] !bg-[#FF7700] font-heading font-bold hover:!border-[#e55f00] hover:!bg-[#e55f00]"
        />
      </div>
    </div>
  </section>

  <!-- 5. Where are you on the AI journey? -->
  <section class="bg-[#F8F8F8] px-6 py-20 sm:px-8 lg:px-12" no-intersect aria-labelledby="journey-heading">
    <div class="mx-auto max-w-6xl">
      <p class="text-center font-heading text-[11px] font-bold uppercase tracking-[0.2em] text-[#FF7700]">
        Your journey
      </p>
      <h2 id="journey-heading" class="mt-3 text-center font-heading text-3xl font-bold text-[#015887] sm:text-4xl">
        Wherever you are, we meet you there.
      </h2>
      <p class="mx-auto mt-4 max-w-3xl text-center font-sans text-sm text-[#1B0101]">
        AI adoption isn&rsquo;t a single moment, it&rsquo;s a path. These are the stages most institutions move through.
        We support you at every one.
      </p>
      <ol class="mt-12 flex flex-col gap-6">
        {
          journeyStages.map(({ num, title, body }) => (
            <li class="flex gap-6 rounded-xl border border-[#E0E0E0] bg-white p-6" style="border-width: 0.5px">
              <span
                class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-[#E6F1FB] font-heading text-sm font-bold text-[#015887]"
                aria-hidden="true"
              >
                {num}
              </span>
              <div>
                <h3 class="font-heading text-xl font-bold text-[#015887]">{title}</h3>
                <p class="mt-2 font-sans text-sm leading-[1.7] text-[#1B0101]">{body}</p>
              </div>
            </li>
          ))
        }
      </ol>
      <div class="mt-12 text-center">
        <a href="/contact/" class="font-heading text-sm font-bold text-[#015887] transition hover:text-[#FF7700]">
          Talk to us about your stage &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- 6. Built from inside higher education -->
  <section class="bg-white px-6 py-16 sm:px-8 lg:px-12" no-intersect aria-labelledby="inside-he-heading">
    <div class="mx-auto flex max-w-6xl flex-col-reverse gap-10 md:flex-row md:items-center md:gap-16">
      <div class="md:basis-1/2">
        <h2 id="inside-he-heading" class="font-heading text-3xl font-bold text-[#015887] sm:text-4xl">
          We&rsquo;ve worked inside the buildings we&rsquo;re trying to help.
        </h2>
        <p class="mt-6 font-sans text-sm leading-[1.7] text-[#1B0101]">
          Our team brings over a decade of direct experience inside UK higher education, and more than four decades
          combined across learning, educational technology, and learning and development. That context shapes every
          workshop we design and every conversation we have with your team.
        </p>
        <p class="mt-4 font-sans text-sm leading-[1.7] text-[#1B0101]">
          We know about Clearing pressures. NSS reporting cycles. OfS conditions and condition B. Academic integrity
          policy at programme level. The gap between schools and professional services. The honest reasons why
          &ldquo;just send them an email&rdquo; doesn&rsquo;t get staff engagement. The reality of academic scepticism
          when something new feels imposed.
        </p>
        <p class="mt-6 font-heading text-sm font-bold text-[#FF7700]">
          This isn&rsquo;t theory for us. It&rsquo;s the world we came from.
        </p>
        <a
          href="/about-us/"
          class="mt-8 inline-flex font-heading text-sm font-bold text-[#015887] transition hover:text-[#FF7700]"
        >
          Meet the team &rarr;
        </a>
      </div>
      <div class="md:basis-1/2">
        <!-- Replace this placeholder with <img src="/images/team-photo.jpg" ...> when the asset is ready -->
        <div
          class="flex aspect-[4/3] w-full items-center justify-center rounded-lg border border-dashed border-[#86BFE2] bg-[#E6F1FB] px-6 text-center"
          role="img"
          aria-label="The WorkSmart-AI team"
        >
          <p class="font-sans text-sm text-[#015887]/60">
            Team photo placeholder &mdash; replace with /images/team-photo.jpg
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. Lead magnet teaser -->
  <section class="bg-[#F8F8F8] px-6 py-16 sm:px-8 lg:px-12" no-intersect aria-labelledby="guide-heading">
    <div class="mx-auto max-w-3xl">
      <p class="font-heading text-[11px] font-bold uppercase tracking-[0.2em] text-[#FF7700]">Free resource</p>
      <h2 id="guide-heading" class="mt-3 font-heading text-3xl font-bold text-[#015887] sm:text-4xl">
        AI use cases for higher education staff.
      </h2>
      <p class="mt-4 font-sans text-sm text-[#1B0101]">
        A practical guide showing how staff across academic and professional services are using AI to save hours every
        week. Useful as a conversation starter for your own teams.
      </p>
      <ul class="mt-6 list-disc space-y-2 pl-5 font-sans text-sm text-[#1B0101]">
        {guideBullets.map((item) => <li>{item}</li>)}
      </ul>
      <div class="mt-8">
        <Button
          variant="primary"
          text="Download the free guide"
          href="/higher-education-guide/"
          class="!border-[#FF7700] !bg-[#FF7700] font-heading font-bold hover:!border-[#e55f00] hover:!bg-[#e55f00]"
        />
      </div>
    </div>
  </section>

  <!-- 8. ROI calculator -->
  <section class="bg-white px-6 py-16 sm:px-8 lg:px-12" no-intersect aria-labelledby="roi-heading">
    <div class="mx-auto max-w-6xl">
      <p class="font-heading text-[11px] font-bold uppercase tracking-[0.2em] text-[#FF7700]">ROI calculator</p>
      <h2 id="roi-heading" class="mt-3 font-heading text-3xl font-bold text-[#015887] sm:text-4xl">
        How much is the status quo costing you?
      </h2>
      <p class="mt-4 max-w-3xl font-sans text-sm text-[#1B0101]">
        Inconsistent, unreviewed AI use has a hidden cost. This calculator shows what a structured approach could
        reclaim for your institution.
      </p>
      <div class="home-v3-roi-calculator mt-10">
        <ROICalculator rootId="roi-calculator-home-v3" />
      </div>
    </div>
  </section>

  <!-- 9. Retention reframe callout -->
  <section class="bg-[#FF7700] px-6 py-12 sm:px-8 lg:px-12" no-intersect aria-label="Retention statistic">
    <div class="mx-auto grid max-w-6xl items-center gap-8 lg:grid-cols-[auto_1fr_auto] lg:gap-10">
      <p class="font-heading text-5xl font-bold text-white">34%</p>
      <div class="text-center lg:text-left">
        <p class="font-sans text-sm text-white">
          of HE staff say their institution&rsquo;s stance on AI affects their likelihood to stay. That&rsquo;s a
          retention question, not a training question.
        </p>
        <p class="mt-2 font-sans text-[11px] text-white/70">Jisc Digital Experience Insights, 2024</p>
      </div>
      <div class="flex justify-center lg:justify-end">
        <a
          href="/contact/"
          class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 font-heading text-sm font-bold text-[#FF7700] transition hover:bg-white/90"
        >
          Talk to us about retention
        </a>
      </div>
    </div>
  </section>

  <!-- 10. Final CTA -->
  <section class="bg-[#015887] px-6 py-16 sm:px-8 lg:px-12" no-intersect aria-labelledby="final-cta-heading">
    <div class="mx-auto max-w-3xl text-center">
      <h2 id="final-cta-heading" class="font-heading text-2xl font-bold text-white sm:text-3xl">
        Ready to give your institution a structured approach to AI?
      </h2>
      <p class="mt-4 font-sans text-sm text-white/65">
        Book a free 45-minute consultation. No pitch, no slides, no obligation - just a clear picture of where you stand
        and where you could go.
      </p>
      <a
        href="/contact/"
        class="mt-8 inline-flex items-center justify-center rounded-full border border-[#FF7700] bg-[#FF7700] px-6 py-3 font-heading font-bold text-white transition hover:border-[#e55f00] hover:bg-[#e55f00]"
      >
        Book a free call
      </a>
    </div>
  </section>

  <HomeFooter slot="footer" />
</Layout>

<style>
  .home-v3-roi-calculator :global(.wsai-hero) {
    display: none;
  }
</style>
