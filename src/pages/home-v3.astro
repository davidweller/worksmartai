---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import { Icon } from 'astro-icon/components';
import ROICalculator from '~/components/widgets/ROICalculator.astro';
import logo from '~/assets/images/Logo Title.png';

const metadata = {
  title: 'AI Capability Built for Higher Education | WorkSmart-AI',
  description:
    'AI training and consultancy built for UK higher education. We help institutions move staff from anxious bystanders to confident, capable practitioners - with hours saved tracked and reported.',
  canonical: 'https://worksmart-ai.co.uk/home-v3/',
  robots: {
    index: false,
    follow: false,
  },
};

const homeV3HeaderData = {
  links: [
    { text: 'Home', href: '/' },
    {
      text: 'Services',
      links: [
        { text: 'Staff Training', href: '/services/staff-training/' },
        { text: 'Student Programmes', href: '/services/student-training/' },
        { text: 'Leadership and Manager Consulting', href: '/services/senior-consulting/' },
        { text: 'Academic Coaching', href: '/services/academic-coaching/' },
        { text: 'Talks and Away Days', href: '/services/talks-workshops/' },
      ],
    },
    {
      text: 'Resources',
      links: [
        { text: 'AI Savings Calculator', href: '/roi-calculator/' },
        { text: 'AI Use Cases Guide', href: '/higher-education-guide/' },
      ],
    },
    { text: 'About', href: '/about-us/' },
    { text: 'News', href: '/news/' },
    { text: 'Contact', href: '/contact-us/' },
  ],
  actions: [
    {
      text: 'Login',
      href: '/login/',
      variant: 'primary' as const,
    },
  ],
};

const trustLogos = ['SDF', 'HE partner', 'Next logo'];

const personas = [
  {
    title: 'HR and People Directors',
    body: 'You need staff to feel supported, not left alone with tools that change every week.',
  },
  {
    title: 'Learning and Development Leads',
    body: 'You need practical capability building that reaches academic and professional services teams.',
  },
  {
    title: 'Digital Transformation Leads',
    body: 'You need visible progress that connects tools, policy, adoption and measurable value.',
  },
  {
    title: 'Professional Services Leaders',
    body: 'You need teams to reclaim time from repeatable work without compromising quality or judgement.',
  },
  {
    title: 'Academic Leaders',
    body: 'You need staff confidence on AI that respects academic integrity, research practice and teaching reality.',
  },
];

const serviceItems = [
  {
    title: 'Staff Training',
    description:
      'Your professional services and academic staff using AI confidently in real work, not just nodding through a session. Role by role, with time savings tracked.',
    icon: 'tabler:users',
    href: '/services/staff-training/',
  },
  {
    title: 'Student Programmes',
    description:
      'Students who graduate able to use AI well and explain how. Programmes that satisfy your academic integrity policy and your employability strategy at the same time.',
    icon: 'tabler:school',
    href: '/services/student-training/',
  },
  {
    title: 'Leadership and Manager Consulting',
    description:
      'A confident institutional position on AI, not a deck of slides. Strategic clarity for SLT, deans and heads of department.',
    icon: 'tabler:crown',
    href: '/services/senior-consulting/',
  },
  {
    title: 'Academic Coaching',
    description:
      'One-to-one and small-group coaching for academics who want to develop their own AI practice, in research, teaching and admin. Confidential, paced to fit a teaching schedule.',
    icon: 'tabler:book',
    href: '/services/academic-coaching/',
  },
  {
    title: 'Talks and Away Days',
    description:
      'A confident, sector-aware introduction to AI for conferences, leadership days and team events. Single-engagement sessions that leave a room thinking differently.',
    icon: 'tabler:presentation',
    href: '/services/talks-workshops/',
  },
];

const partnershipIncludes = [
  'Free initial consultation',
  'AI literacy and needs analysis',
  'Personalised workshops, in-person or online',
  'On-demand courses for up to 100 staff',
  'Strategic roadmap session with your SLT',
  'Ongoing AI Café drop-in sessions',
  'Follow-up calls with leadership',
];

const maturityStages = [
  {
    num: '01',
    title: 'Recognising the strategic priority',
    body: 'AI is on every board agenda. You know you need a coordinated response, not a series of individual experiments.',
  },
  {
    num: '02',
    title: 'Understanding your starting point',
    body: 'Before you build a plan, you need an honest picture of staff capability, current usage and risk exposure across the institution.',
  },
  {
    num: '03',
    title: 'Building the institutional plan',
    body: 'Translating insight into a board-ready roadmap with measurable outcomes, accountable owners and a realistic timeline.',
  },
  {
    num: '04',
    title: 'Equipping staff with confidence and capability',
    body: 'Role-specific training that respects the difference between an academic, a finance officer and a student services lead.',
  },
  {
    num: '05',
    title: 'Embedding and sustaining',
    body: 'AI evolves quickly. Your institution needs structures that keep momentum after the initial push.',
  },
];

const footerColumns = [
  {
    title: 'Services',
    links: [
      { text: 'Staff Training', href: '/services/staff-training/' },
      { text: 'Student Programmes', href: '/services/student-training/' },
      { text: 'Leadership and Manager Consulting', href: '/services/senior-consulting/' },
      { text: 'Academic Coaching', href: '/services/academic-coaching/' },
      { text: 'Talks and Away Days', href: '/services/talks-workshops/' },
      { text: 'The AI Partnership', href: '#ai-partnership' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { text: 'AI Savings Calculator', href: '/roi-calculator/' },
      { text: 'AI Use Cases Guide', href: '/higher-education-guide/' },
      { text: 'How our Calculator Works', href: '/how-our-calculator-works/' },
      { text: 'News', href: '/news/' },
    ],
  },
  {
    title: 'About',
    links: [
      { text: 'About Us', href: '/about-us/' },
      { text: 'Meet the Team', href: '/about-us/' },
      { text: 'Contact', href: '/contact-us/' },
      { text: 'Login', href: '/login/' },
    ],
  },
];

const legalLinks = [
  { text: 'Privacy Policy', href: '/privacy-policy/' },
  { text: 'Cookie Policy', href: '/cookie-policy/' },
  { text: 'Terms of Service', href: '/terms-of-service/' },
  { text: 'Accessibility Statement', href: '/accessibility-statement/' },
  { text: 'Modern Slavery', href: '/modern-slavery/' },
  { text: 'EDI', href: '/equality-diversity-inclusion/' },
  { text: 'Sustainability', href: '/sustainability/' },
  { text: 'Insurance', href: '/insurance-statement/' },
];
---

<Layout metadata={metadata}>
  <Header slot="header" {...homeV3HeaderData} isSticky />

  <!-- 1. Hero -->
  <section class="relative overflow-hidden bg-[#015887] px-6 py-12 sm:px-8 md:py-20 lg:px-12" no-intersect>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6">
      <div class="flex flex-col items-center gap-10 lg:flex-row lg:items-center lg:gap-12">
        <div class="w-full basis-1/2 pb-4 text-center lg:pb-0 lg:text-left">
          <h1
            class="mb-5 font-heading text-4xl font-bold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl"
          >
            AI Capability Built for <span class="text-[#FF7700]">Higher Education</span>
          </h1>
          <p class="mb-4 max-w-xl font-sans text-lg leading-[1.7] text-white/85 lg:max-w-none">
            Move your staff and students to confident, capable and compliant AI practitioners.<br />
            Hours saved, tracked and reported.
          </p>
          <p class="mb-8 max-w-xl font-sans text-base text-[#B6DCF4] lg:max-w-none">
            AI adoption by those who fully understand universities.
          </p>
          <div
            class="mx-auto flex max-w-md flex-col gap-4 sm:flex-row sm:justify-center lg:mx-0 lg:max-w-none lg:justify-start"
          >
            <a
              href="/health-check/"
              class="inline-flex items-center justify-center rounded-lg border border-[#FF7700] bg-[#FF7700] px-7 py-3 font-heading text-sm font-bold text-white transition hover:-translate-y-0.5 hover:border-[#e55f00] hover:bg-[#e55f00]"
            >
              Book Your AI Health Check
            </a>
          </div>
          <p class="mt-6 max-w-xl font-sans text-sm text-white/65 lg:max-w-none">
            A free, confidential 45-minute call followed by a written summary report.
          </p>
        </div>
        <div class="w-full basis-1/2">
          <img
            src="/images/home-hero-photo.png"
            alt="Team collaborating around a table with sticky notes during a planning session"
            width={1200}
            height={800}
            loading="eager"
            decoding="async"
            class="mx-auto w-full rounded-2xl"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Trust strip -->
  <section class="bg-[#F8F8F8] px-6 py-6 sm:px-8 lg:px-12" no-intersect aria-label="Credibility and memberships">
    <div class="mx-auto flex max-w-6xl flex-col gap-5 md:flex-row md:items-center md:justify-between">
      <p class="max-w-3xl font-sans text-sm font-medium leading-[1.7] text-[#015887]">
        Built by former Digital Skills Leads from UK universities.<br />
        Proud members of the Staff Development Forum.
      </p>
      <ul class="flex flex-wrap gap-3" aria-label="Credibility logos">
        {
          trustLogos.map((item) => (
            <li class="flex h-10 min-w-28 items-center justify-center rounded-md border border-[#E0E0E0] bg-white px-4 font-heading text-xs font-bold uppercase tracking-[0.16em] text-[#015887]/55 grayscale">
              {item}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- 3. Who we work with -->
  <section class="bg-white px-6 py-12 sm:px-8 md:py-20 lg:px-12" no-intersect aria-labelledby="personas-heading">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="font-heading text-[11px] font-bold uppercase tracking-[0.2em] text-[#FF7700]">Who we work with</p>
        <h2 id="personas-heading" class="mt-3 font-heading text-3xl font-bold text-[#015887] sm:text-4xl">
          Designed for those responsible<br class="hidden sm:block" />
          for AI adoption
        </h2>
        <p class="mt-4 font-sans text-base leading-[1.7] text-[#1B0101]">
          We work with those who are responsible for turning AI curiosity and AI pilots<br class="hidden sm:block" />
          into institution-wide confidence, capability and compliance.
        </p>
      </div>
      <div class="mt-12 grid gap-4 md:grid-cols-2 lg:grid-cols-5">
        {
          personas.map((persona) => (
            <article class="rounded-xl border border-[#E0E0E0] bg-white p-5 shadow-[0_6px_28px_-18px_rgba(1,88,135,0.25)]">
              <h3 class="font-heading text-lg font-bold leading-tight text-[#015887]">{persona.title}</h3>
              <p class="mt-3 font-sans text-sm leading-[1.65] text-[#1B0101]">{persona.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 4. Services -->
  <section class="bg-[#F8F8F8] px-6 py-12 sm:px-8 md:py-20 lg:px-12" no-intersect aria-labelledby="services-heading">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="font-heading text-[11px] font-bold uppercase tracking-[0.2em] text-[#FF7700]">Services</p>
        <h2 id="services-heading" class="mt-3 font-heading text-3xl font-bold text-[#015887] sm:text-4xl">
          AI support designed for every part of the institution
        </h2>
        <p class="mt-4 font-sans text-base leading-[1.7] text-[#1B0101]">
          Whether you need to lift staff capability, equip students for an AI-shaped workplace, coach an individual
          academic, or give your leadership team a confident strategic position, we have something built for it.
        </p>
      </div>
      <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-5">
        {
          serviceItems.map((service) => (
            <a
              href={service.href}
              class="group flex h-full flex-col rounded-xl border border-[#E0E0E0] bg-white p-6 shadow-[0_6px_28px_-18px_rgba(1,88,135,0.25)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_18px_40px_-22px_rgba(1,88,135,0.45)]"
            >
              <span class="flex h-12 w-12 items-center justify-center rounded-lg bg-[#E6F1FB] text-[#015887]">
                <Icon name={service.icon} class="h-6 w-6" aria-hidden="true" />
              </span>
              <h3 class="mt-5 font-heading text-xl font-bold leading-tight text-[#015887]">{service.title}</h3>
              <p class="mt-3 flex-1 font-sans text-sm leading-[1.65] text-[#1B0101]">{service.description}</p>
              <span class="mt-6 inline-flex items-center font-heading text-sm font-bold text-[#FF7700]">
                Learn more{' '}
                <span class="ml-1 transition-transform group-hover:translate-x-1" aria-hidden="true">
                  &rarr;
                </span>
              </span>
            </a>
          ))
        }
      </div>
      <div class="mt-10 text-center">
        <a href="/services/" class="font-heading text-sm font-bold text-[#015887] transition hover:text-[#FF7700]">
          See all our services <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 5. Founder credibility -->
  <section class="bg-white px-6 py-12 sm:px-8 md:py-20 lg:px-12" no-intersect aria-labelledby="inside-he-heading">
    <div class="mx-auto flex max-w-6xl flex-col-reverse gap-10 md:flex-row md:items-center md:gap-16">
      <div class="md:basis-1/2">
        <h2 id="inside-he-heading" class="font-heading text-3xl font-bold text-[#015887] sm:text-4xl">
          We&rsquo;ve worked inside the buildings we&rsquo;re trying to help.
        </h2>
        <p class="mt-6 font-sans text-sm leading-[1.7] text-[#1B0101]">
          Our team brings over a decade of direct experience inside UK higher education, and more than four decades
          combined across learning, educational technology, and learning and development. That context shapes every
          workshop we design and every conversation we have with your team.
        </p>
        <p class="mt-4 font-sans text-sm leading-[1.7] text-[#1B0101]">
          We know about Clearing pressures. NSS reporting cycles. OfS conditions and condition B. Academic integrity
          policy at programme level. The gap between schools and professional services. The honest reasons why
          &ldquo;just send them an email&rdquo; doesn&rsquo;t get staff engagement. The reality of academic scepticism
          when something new feels imposed.
        </p>
        <p class="mt-6 font-heading text-sm font-bold text-[#FF7700]">
          This isn&rsquo;t theory for us. It&rsquo;s the world we came from.
        </p>
        <a
          href="/about-us/"
          class="mt-8 inline-flex font-heading text-sm font-bold text-[#015887] transition hover:text-[#FF7700]"
        >
          Meet the team &rarr;
        </a>
      </div>
      <div class="md:basis-1/2">
        <!-- Replace this placeholder with <img src="/images/team-photo.jpg" ...> when the asset is ready -->
        <div
          class="flex aspect-[4/3] w-full items-center justify-center rounded-lg border border-dashed border-[#86BFE2] bg-[#E6F1FB] px-6 text-center"
          role="img"
          aria-label="The WorkSmart-AI team"
        >
          <p class="font-sans text-sm text-[#015887]/60">
            Team photo placeholder - replace with /images/team-photo.jpg
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. The AI Partnership -->
  <section
    id="ai-partnership"
    class="scroll-mt-24 bg-[#015887] px-6 py-12 sm:px-8 md:py-20 lg:px-12"
    no-intersect
    aria-labelledby="partnership-heading"
  >
    <div class="mx-auto max-w-6xl">
      <p class="font-heading text-[11px] font-bold uppercase tracking-[0.2em] text-[#FF7700]">Our flagship offering</p>
      <h2 id="partnership-heading" class="mt-3 font-heading text-3xl font-bold text-white sm:text-4xl">
        The AI Partnership
      </h2>
      <p class="mt-4 max-w-3xl font-sans text-base leading-[1.7] text-white/80">
        For institutions that want to stop running pilots and start running an approach. A wrap-around programme
        delivered across an academic year, built around your roles, your policies and your calendar.
      </p>
      <ul class="mt-10 grid gap-3 sm:grid-cols-2" aria-label="What's included in the AI Partnership">
        {
          partnershipIncludes.map((item) => (
            <li class="flex items-start gap-3 font-sans text-sm text-white/90">
              <span
                class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[#FF7700] text-xs font-bold text-white"
                aria-hidden="true"
              >
                &#10003;
              </span>
              {item}
            </li>
          ))
        }
      </ul>
      <div class="mt-10">
        <a
          href="/contact-us/"
          class="inline-flex items-center justify-center rounded-lg border border-[#FF7700] bg-[#FF7700] px-7 py-3 font-heading text-sm font-bold text-white transition hover:-translate-y-0.5 hover:border-[#e55f00] hover:bg-[#e55f00]"
        >
          Discuss the AI Partnership
        </a>
      </div>
      <p class="mt-6 max-w-3xl font-sans text-sm italic leading-[1.7] text-white/65">
        Every partnership is scoped to the institution. Book an AI Health Check to start that conversation.
      </p>
    </div>
  </section>

  <!-- 7. Five stages of AI maturity -->
  <section class="bg-[#F8F8F8] px-6 py-12 sm:px-8 md:py-20 lg:px-12" no-intersect aria-labelledby="maturity-heading">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="font-heading text-[11px] font-bold uppercase tracking-[0.2em] text-[#FF7700]">AI maturity</p>
        <h2 id="maturity-heading" class="mt-3 font-heading text-3xl font-bold text-[#015887] sm:text-4xl">
          Five stages of AI maturity in higher education
        </h2>
        <p class="mt-4 font-sans text-base leading-[1.7] text-[#1B0101]">
          AI adoption happens in stages. These are the five we see most often. We support you at each.
        </p>
      </div>
      <ol class="home-v3-timeline mt-12 grid gap-5 lg:grid-cols-5">
        {
          maturityStages.map(({ num, title, body }) => (
            <li class="relative rounded-xl border border-[#E0E0E0] bg-white p-6 shadow-[0_6px_28px_-18px_rgba(1,88,135,0.25)]">
              <span class="font-heading text-3xl font-bold text-[#FF7700]">{num}</span>
              <h3 class="mt-4 font-heading text-lg font-bold leading-tight text-[#015887]">{title}</h3>
              <p class="mt-3 font-sans text-sm leading-[1.65] text-[#1B0101]">{body}</p>
            </li>
          ))
        }
      </ol>
      <div class="mt-10 text-center">
        <a href="/health-check/" class="font-heading text-sm font-bold text-[#015887] transition hover:text-[#FF7700]">
          Not sure which stage you&rsquo;re at? Book your AI Health Check <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 8. Retention feature -->
  <section class="bg-[#F8F8F8] px-6 py-12 sm:px-8 md:py-20 lg:px-12" no-intersect aria-labelledby="retention-heading">
    <div
      class="mx-auto grid max-w-6xl gap-10 rounded-2xl bg-white p-8 shadow-[0_18px_60px_-36px_rgba(1,88,135,0.4)] md:grid-cols-[0.75fr_1.25fr] md:p-12"
    >
      <div>
        <h2 id="retention-heading" class="font-heading text-3xl font-bold leading-tight text-[#015887] sm:text-4xl">
          The retention angle most institutions are missing.
        </h2>
        <p class="mt-6 font-heading text-7xl font-bold leading-none text-[#FF7700] sm:text-8xl">34%</p>
        <p class="mt-4 font-sans text-sm text-[#1B0101]/60">Jisc Digital Experience Insights, 2024</p>
      </div>
      <div class="flex flex-col justify-center">
        <p class="font-sans text-xl font-medium leading-[1.6] text-[#015887]">
          of HE staff say their institution&rsquo;s stance on AI affects their likelihood to stay.
        </p>
        <p class="mt-5 font-sans text-base leading-[1.7] text-[#1B0101]">
          That isn&rsquo;t a training problem. It&rsquo;s a retention problem. Every month without a structured approach
          is a month of inconsistent, unreviewed AI use across your institution, and a month of capable staff watching
          to see whether you&rsquo;re serious.
        </p>
        <a
          href="/contact-us/?topic=retention"
          class="mt-8 inline-flex w-fit items-center justify-center rounded-lg border border-[#FF7700] bg-[#FF7700] px-7 py-3 font-heading text-sm font-bold text-white transition hover:-translate-y-0.5 hover:border-[#e55f00] hover:bg-[#e55f00]"
        >
          Talk to us about retention
        </a>
      </div>
    </div>
  </section>

  <!-- 9. ROI calculator -->
  <section class="bg-white px-6 py-12 sm:px-8 md:py-20 lg:px-12" no-intersect aria-labelledby="roi-heading">
    <div class="mx-auto max-w-6xl">
      <p class="font-heading text-[11px] font-bold uppercase tracking-[0.2em] text-[#FF7700]">ROI calculator</p>
      <h2 id="roi-heading" class="mt-3 font-heading text-3xl font-bold text-[#015887] sm:text-4xl">
        What does the status quo cost you?
      </h2>
      <p class="mt-4 max-w-3xl font-sans text-base leading-[1.7] text-[#1B0101]">
        Unstructured AI use isn&rsquo;t free. Staff are spending hours working out tools and prompts that someone else
        has already worked out. This calculator shows what a coordinated approach could reclaim.
      </p>
      <div class="home-v3-roi-calculator mt-10">
        <ROICalculator rootId="roi-calculator-home-v3" />
      </div>
    </div>
  </section>

  <!-- 10. Free guide -->
  <section class="bg-[#F8F8F8] px-6 py-12 sm:px-8 md:py-20 lg:px-12" no-intersect aria-labelledby="guide-heading">
    <div class="mx-auto grid max-w-6xl items-center gap-10 md:grid-cols-[0.8fr_1.2fr]">
      <div class="mx-auto max-w-xs md:max-w-none">
        <img
          src="/images/guide-from-chatbot-to-workflow-cover.png"
          alt="Cover of the AI use cases guide"
          width={800}
          height={1035}
          loading="lazy"
          decoding="async"
          class="rounded-xl shadow-[0_20px_60px_-32px_rgba(1,88,135,0.65)]"
        />
      </div>
      <div>
        <p class="font-heading text-[11px] font-bold uppercase tracking-[0.2em] text-[#FF7700]">Free resource</p>
        <h2 id="guide-heading" class="mt-3 font-heading text-3xl font-bold text-[#015887] sm:text-4xl">
          From chatbot to agent in one task.
        </h2>
        <p class="mt-4 font-sans text-base leading-[1.7] text-[#1B0101]">
          A short guide that takes a single task most staff already do, and shows how it can be improved with AI - from
          a quick AI prompt to a full agentic workflow. See how AI capability works at different levels, depending on
          workforce capability.
        </p>
        <a
          href="/higher-education-guide/"
          class="mt-8 inline-flex items-center justify-center rounded-lg border border-[#FF7700] bg-[#FF7700] px-7 py-3 font-heading text-sm font-bold text-white transition hover:-translate-y-0.5 hover:border-[#e55f00] hover:bg-[#e55f00]"
        >
          Download the guide
        </a>
      </div>
    </div>
  </section>

  <!-- 11. Final CTA -->
  <section class="bg-[#015887] px-6 py-12 sm:px-8 md:py-20 lg:px-12" no-intersect aria-labelledby="final-cta-heading">
    <div class="mx-auto max-w-3xl text-center">
