---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Academy Dashboard | WorkSmart-AI',
  description: 'Track your course progress in the WorkSmart-AI Academy.',
  canonical: '/academy/dashboard/',
  robots: {
    index: false,
    follow: false,
  },
};

const staffTrainingCourseGroups = [
  {
    staffType: 'All-Staff Workshops',
    courses: [
      {
        code: 'W1',
        title: 'AI Foundations & Responsible Use',
        level: 'Foundation',
        summary: 'Core principles, safe use patterns, and practical prompting for teams.',
        isLive: true,
        courseId: 'ai-foundations',
        ctaLabel: 'Continue course',
      },
      {
        code: 'W2',
        title: 'AI for Daily Workflows (Email, Meetings, and Comms)',
        level: 'Foundation',
        summary: 'Apply AI assistants to day-to-day communication and coordination tasks.',
        isLive: false,
        ctaLabel: 'Start course',
      },
      {
        code: 'W3',
        title: 'AI for Summarising and Analysing (Word & Excel)',
        level: 'Foundation',
        summary: 'Use AI support to summarise information and speed up data-focused work.',
        isLive: false,
        ctaLabel: 'Start course',
      },
      {
        code: 'W4',
        title: 'Building Custom AI Agents',
        level: 'Intermediate',
        summary: 'Design practical agents that automate recurring team processes.',
        isLive: false,
        ctaLabel: 'Start course',
      },
    ],
  },
  {
    staffType: 'Academic Workshops',
    courses: [
      {
        code: 'W5',
        title: 'AI for Academic Content Creation (AI Before Class)',
        level: 'Intermediate',
        summary: 'Plan and prepare teaching materials with structured AI support.',
        isLive: false,
        ctaLabel: 'Start course',
      },
      {
        code: 'W6',
        title: 'The AI-Enabled Classroom: Pedagogy & Practice (AI During Class)',
        level: 'Intermediate',
        summary: 'Use AI during delivery while maintaining sound pedagogy and student trust.',
        isLive: false,
        ctaLabel: 'Start course',
      },
      {
        code: 'W7',
        title: 'AI for Academic Assessments (AI after Class)',
        level: 'Intermediate',
        summary: 'Create and review assessment workflows with reliable academic safeguards.',
        isLive: false,
        ctaLabel: 'Start course',
      },
      {
        code: 'W8',
        title: 'AI for Researchers',
        level: 'Foundation',
        summary: 'Support literature, synthesis, and workflow efficiency for research teams.',
        isLive: false,
        ctaLabel: 'Start course',
      },
    ],
  },
  {
    staffType: 'Professional Services Workshops',
    courses: [
      {
        code: 'W9',
        title: 'AI for Process Improvement',
        level: 'Intermediate',
        summary: 'Identify bottlenecks and redesign services with practical AI methods.',
        isLive: false,
        ctaLabel: 'Start course',
      },
      {
        code: 'W10',
        title: 'AI for Comms and Engagement',
        level: 'Intermediate',
        summary: 'Improve engagement and communications output across professional services.',
        isLive: false,
        ctaLabel: 'Start course',
      },
    ],
  },
];
---

<Layout metadata={metadata}>
  <section class="bg-page px-6 py-16 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-6xl">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="font-heading text-xs font-bold uppercase tracking-[0.2em] text-accent">Academy</p>
          <h1 class="mt-2 font-heading text-3xl font-bold text-heading sm:text-4xl">Your course dashboard</h1>
          <p class="mt-2 text-sm text-muted">Resume where you left off and track progress across your learning path.</p>
        </div>
        <button
          id="academy-signout-button"
          class="inline-flex items-center justify-center rounded-full border border-default bg-card px-5 py-2.5 text-sm font-semibold text-default transition hover:border-brand hover:text-brand"
        >
          Sign out
        </button>
      </div>

      <p id="academy-dashboard-feedback" class="mt-6 hidden rounded-lg px-3 py-2 text-sm" role="alert"></p>

      <section class="mt-8 rounded-2xl border border-default bg-card p-6 shadow-card sm:p-8">
        <p class="font-heading text-xs font-bold uppercase tracking-[0.2em] text-accent">Staff training</p>
        <h2 class="mt-2 font-heading text-2xl font-bold text-heading sm:text-3xl">Our staff training courses</h2>
        <p class="mt-2 max-w-3xl text-sm leading-relaxed text-muted">
          A practical workshop suite covering foundation skills and role-specific applications for higher education
          teams.
        </p>

        <div class="mt-8 space-y-8">
          {
            staffTrainingCourseGroups.map((group) => (
              <div>
                <h3 class="font-heading text-xl font-bold text-heading">{group.staffType}</h3>
                <div class="mt-4 grid gap-4 md:grid-cols-2">
                  {group.courses.map((course) => (
                    <article class="rounded-xl border border-default bg-page p-5">
                      <h4 class="text-base font-semibold text-heading">{course.title}</h4>
                      <p class="mt-2 text-sm leading-relaxed text-muted">{course.summary}</p>
                      <p class="mt-3 inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">
                        {course.level}
                      </p>
                      {course.isLive ? (
                        <>
                          <div class="mt-5">
                            <div class="mb-1.5 flex items-center justify-between text-xs font-semibold uppercase tracking-wide text-muted">
                              <span>Progress</span>
                              <span data-progress-label={course.courseId}>0%</span>
                            </div>
                            <div class="h-2 rounded-full bg-slate-200">
                              <div
                                class="h-full rounded-full bg-accent transition-all"
                                style="width: 0%"
                                data-progress-bar={course.courseId}
                              />
                            </div>
                          </div>
                          <a
                            href={`/academy/view/${course.courseId}/`}
                            class="mt-4 inline-flex items-center justify-center rounded-full border-2 border-brand bg-brand px-4 py-2 text-sm font-semibold text-white transition hover:border-accent hover:bg-accent"
                          >
                            {course.ctaLabel}
                          </a>
                        </>
                      ) : (
                        <>
                          <p class="mt-5 inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-slate-700">
                            Coming soon
                          </p>
                          <button
                            type="button"
                            class="mt-4 inline-flex items-center justify-center rounded-full border-2 border-default bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-500"
                          >
                            {course.ctaLabel}
                          </button>
                        </>
                      )}
                    </article>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </section>
    </div>
  </section>
</Layout>

<script>
  import { academySupabase, hasAcademySupabaseConfig, requireAuth } from '~/lib/academy';

  const feedback = document.getElementById('academy-dashboard-feedback') as HTMLParagraphElement | null;
  const signOutButton = document.getElementById('academy-signout-button') as HTMLButtonElement | null;

  const setFeedback = (message: string, isError: boolean = true) => {
    if (!feedback) return;
    feedback.textContent = message;
    feedback.className = isError
      ? 'mt-6 rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800'
      : 'mt-6 rounded-lg border border-green-200 bg-green-50 px-3 py-2 text-sm text-green-800';
  };

  const renderLiveCourseProgress = (progressByCourseId: Record<string, number> = {}) => {
    const liveCourseId = 'ai-foundations';
    const progress = Number(progressByCourseId[liveCourseId] ?? 0);
    const clampedProgress = Number.isFinite(progress) ? Math.max(0, Math.min(100, Math.round(progress))) : 0;
    const progressLabels = document.querySelectorAll(`[data-progress-label="${liveCourseId}"]`);
    const progressBars = document.querySelectorAll(`[data-progress-bar="${liveCourseId}"]`);

    progressLabels.forEach((label) => {
      label.textContent = `${clampedProgress}%`;
    });

    progressBars.forEach((bar) => {
      if (!(bar instanceof HTMLElement)) return;
      bar.style.width = `${clampedProgress}%`;
    });
  };

  if (!hasAcademySupabaseConfig || !academySupabase) {
    setFeedback('Dashboard is unavailable. Missing Supabase configuration.');
  } else {
    const authState = await requireAuth('/academy/login/');
    const user = authState?.user;

    if (user) {
      const { data: progressRows, error } = await academySupabase
        .from('progress_compat')
        .select('course_id, progress_percent')
        .eq('user_id', user.id);

      if (error) {
        setFeedback('We could not load your progress yet. Please refresh and try again.');
      } else {
        const progressByCourseId = Object.fromEntries(
          (progressRows || []).map((row) => [String(row.course_id), Number(row.progress_percent || 0)])
        );
        renderLiveCourseProgress(progressByCourseId);
      }

      if (signOutButton) {
        signOutButton.addEventListener('click', async () => {
          const supabase = academySupabase;
          if (!supabase) {
            setFeedback('Sign out is unavailable right now. Please refresh and try again.');
            return;
          }
          await supabase.auth.signOut();
          window.location.replace('/academy/login/');
        });
      }
    }
  }
</script>
