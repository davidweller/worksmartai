---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Academy Login | WorkSmart-AI',
  description: 'Sign in to your WorkSmart-AI Academy account to access your courses and progress.',
  canonical: '/academy/login/',
  robots: {
    index: false,
    follow: false,
  },
};

const supabaseUrl = (import.meta.env.PUBLIC_SUPABASE_URL ?? import.meta.env.SUPABASE_URL ?? '').trim();
const supabaseAnonKey = (import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? import.meta.env.SUPABASE_ANON_KEY ?? '').trim();
---

<Layout metadata={metadata}>
  <section class="relative overflow-hidden bg-brand px-6 py-20 sm:px-8 lg:px-12">
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-brand via-brand to-[#013a5c] opacity-95">
    </div>
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.08]"
      style="background-image:radial-gradient(rgba(255,255,255,0.9) 1px, transparent 1px);background-size:20px 20px;"
      aria-hidden="true"
    >
    </div>
    <div class="relative mx-auto max-w-5xl">
      <div class="mx-auto max-w-md rounded-2xl border border-white/20 bg-white p-8 shadow-2xl ring-1 ring-slate-900/5">
        <p class="font-heading text-xs font-bold uppercase tracking-[0.2em] text-accent">Academy access</p>
        <h1 class="mt-3 font-heading text-3xl font-bold text-heading">Welcome back</h1>
        <p class="mt-2 text-sm text-muted">Sign in to continue your WorkSmart-AI Academy learning journey.</p>

        <form
          id="academy-login-form"
          class="mt-8 space-y-4"
          data-supabase-url={supabaseUrl}
          data-supabase-anon-key={supabaseAnonKey}
        >
          <div>
            <label for="academy-email" class="block text-sm font-semibold text-heading">Email</label>
            <input
              id="academy-email"
              name="email"
              type="email"
              autocomplete="email"
              required
              class="mt-1.5 block w-full rounded-xl border border-default bg-card px-4 py-3 text-default shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
              placeholder="you@organisation.com"
            />
          </div>

          <div>
            <label for="academy-password" class="block text-sm font-semibold text-heading">Password</label>
            <input
              id="academy-password"
              name="password"
              type="password"
              autocomplete="current-password"
              required
              class="mt-1.5 block w-full rounded-xl border border-default bg-card px-4 py-3 text-default shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
              placeholder="Enter your password"
            />
          </div>

          <p id="academy-login-feedback" class="hidden rounded-lg px-3 py-2 text-sm" role="alert"></p>

          <button
            type="submit"
            class="inline-flex w-full items-center justify-center rounded-full border-2 border-brand bg-brand px-5 py-3 font-heading font-semibold text-white transition hover:bg-accent hover:border-accent focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2"
          >
            Sign in
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script type="module" is:inline>
  import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';

  const form = document.getElementById('academy-login-form');
  const feedback = document.getElementById('academy-login-feedback');

  if (!form) {
    throw new Error('Academy login form not found');
  }

  const supabaseUrl = (form.getAttribute('data-supabase-url') || '').trim();
  const supabaseAnonKey = (form.getAttribute('data-supabase-anon-key') || '').trim();

  const setFeedback = (message, isError = true) => {
    if (!feedback) return;
    feedback.textContent = message;
    feedback.className = isError
      ? 'rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800'
      : 'rounded-lg border border-green-200 bg-green-50 px-3 py-2 text-sm text-green-800';
  };

  if (!supabaseUrl || !supabaseAnonKey) {
    setFeedback('Login is unavailable right now. Please contact support.');
  } else {
    const supabase = createClient(supabaseUrl, supabaseAnonKey);

    const { data: sessionData } = await supabase.auth.getSession();
    if (sessionData?.session) {
      window.location.replace('/academy/dashboard/');
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const submitButton = form.querySelector('button[type="submit"]');
      const formData = new FormData(form);
      const email = String(formData.get('email') || '').trim();
      const password = String(formData.get('password') || '');

      if (!email || !password) {
        setFeedback('Please provide both email and password.');
        return;
      }

      if (submitButton instanceof HTMLButtonElement) submitButton.disabled = true;
      if (feedback) feedback.className = 'hidden';

      const { error } = await supabase.auth.signInWithPassword({ email, password });

      if (submitButton instanceof HTMLButtonElement) submitButton.disabled = false;

      if (error) {
        setFeedback(error.message || 'Login failed. Please check your credentials.');
        return;
      }

      setFeedback('Login successful. Redirecting...', false);
      window.location.replace('/academy/dashboard/');
    });
  }
</script>
