---
import Layout from '~/layouts/PageLayout.astro';

export function getStaticPaths() {
  const academyCourseIds = ['ai-foundations', 'copilot-workflows', 'agentic-automation'];
  return academyCourseIds.map((courseId) => ({
    params: { courseId },
  }));
}

const courseId = Astro.params.courseId ?? '';
const courseContentPathById: Record<string, string> = {
  'ai-foundations': 'ai_fundamentals',
  'copilot-workflows': 'copilot-workflows',
  'agentic-automation': 'agentic-automation',
};
const courseContentPath = courseContentPathById[courseId] ?? courseId;

const metadata = {
  title: 'Academy Course Player | WorkSmart-AI',
  description: 'Launch your WorkSmart-AI Academy course and continue from your saved progress.',
  canonical: `/academy/view/${courseId}/`,
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <section class="academy-player-page" data-course-id={courseId} data-content-path={courseContentPath}>
    <div class="academy-player-shell">
      <aside
        id="academy-sidebar"
        class="academy-sidebar"
        style="width: 280px !important; min-width: 280px !important; flex-shrink: 0 !important"
        aria-label="Course navigation"
      >
        <div class="academy-sidebar-header">
          <p id="academy-course-code" class="academy-course-code" style="font-size: 12px !important">
            W1 - AI FOUNDATIONS
          </p>
          <h1
            id="academy-course-title"
            class="academy-course-title"
            style="font-size: 16px !important; line-height: 1.35 !important"
          >
            Course: {courseId}
          </h1>
          <div class="academy-sidebar-progress-track" role="presentation">
            <div id="academy-sidebar-progress-fill" class="academy-sidebar-progress-fill"></div>
          </div>
          <p
            id="academy-sidebar-progress-label"
            class="academy-sidebar-progress-label"
            style="font-size: 13px !important"
          >
            0 of 0 pages complete
          </p>
        </div>

        <nav id="academy-sidebar-nav" class="academy-sidebar-nav" aria-label="Course pages"></nav>

        <div class="academy-sidebar-footer">
          <a href="/academy/dashboard/" class="academy-back-link" aria-label="Back to dashboard">
            <span aria-hidden="true">&#8592;</span>
            Back to dashboard
          </a>
        </div>
      </aside>

      <div class="academy-content-shell">
        <header class="academy-content-topbar">
          <button
            id="academy-mobile-menu-button"
            class="academy-mobile-menu-button"
            type="button"
            aria-label="Open course navigation"
            aria-expanded="false"
            aria-controls="academy-sidebar-overlay"
          >
            <span aria-hidden="true">&#9776;</span>
          </button>
          <p class="academy-breadcrumb">
            <span id="academy-breadcrumb-module">Module</span>
            <span class="academy-breadcrumb-separator">-</span>
            <span id="academy-breadcrumb-page">Page 1</span>
          </p>
          <p id="academy-page-pill" class="academy-page-pill">Page 1 of 1</p>
        </header>

        <p id="academy-player-feedback" class="academy-player-feedback hidden" role="alert"></p>

        <div class="academy-content-scroll">
          <div class="academy-content-inner">
            <div class="academy-iframe-wrap">
              <iframe
                id="academy-scorm-frame"
                src="about:blank"
                title={`SCORM course player for ${courseId}`}
                class="academy-scorm-frame"
                loading="eager"
                allow="fullscreen"></iframe>
            </div>
          </div>
        </div>

        <footer class="academy-content-bottombar">
          <button
            id="academy-prev-button"
            class="btn font-semibold shadow-none text-sm w-auto py-2.5 px-5.5 md:px-6 academy-nav-button academy-nav-button-prev"
            style="background: #ffffff; border: 1px solid #015887; color: #015887"
            type="button"
          >
            <span aria-hidden="true">&#8249;</span>
            Previous
          </button>
          <button
            id="academy-next-button"
            class="btn font-semibold shadow-none text-sm w-auto py-2.5 px-5.5 md:px-6 academy-nav-button academy-nav-button-next"
            style="background: #ff7700; border: 1px solid #ff7700; color: #ffffff"
            type="button"
          >
            Next
            <span aria-hidden="true">&#8250;</span>
          </button>
        </footer>
      </div>
    </div>

    <div id="academy-sidebar-overlay" class="academy-sidebar-overlay" hidden>
      <button
        id="academy-overlay-close"
        class="academy-sidebar-overlay-backdrop"
        type="button"
        aria-label="Close navigation"></button>
      <aside
        class="academy-sidebar academy-sidebar-mobile"
        style="width: 280px !important; min-width: 280px !important; flex-shrink: 0 !important"
        aria-label="Course navigation mobile"
      >
        <div class="academy-sidebar-header">
          <p id="academy-course-code-mobile" class="academy-course-code" style="font-size: 12px !important">
            W1 - AI FOUNDATIONS
          </p>
          <h2
            id="academy-course-title-mobile"
            class="academy-course-title"
            style="font-size: 16px !important; line-height: 1.35 !important"
          >
            Course: {courseId}
          </h2>
          <div class="academy-sidebar-progress-track" role="presentation">
            <div id="academy-sidebar-progress-fill-mobile" class="academy-sidebar-progress-fill"></div>
          </div>
          <p
            id="academy-sidebar-progress-label-mobile"
            class="academy-sidebar-progress-label"
            style="font-size: 13px !important"
          >
            0 of 0 pages complete
          </p>
        </div>

        <nav id="academy-sidebar-nav-mobile" class="academy-sidebar-nav" aria-label="Course pages mobile"></nav>

        <div class="academy-sidebar-footer">
          <a href="/academy/dashboard/" class="academy-back-link" aria-label="Back to dashboard">
            <span aria-hidden="true">&#8592;</span>
            Back to dashboard
          </a>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<script is:inline src="https://cdn.jsdelivr.net/gh/gabrieldoty/simplify-scorm@master/src/init.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/gh/gabrieldoty/simplify-scorm@master/src/constants.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/gh/gabrieldoty/simplify-scorm@master/src/baseAPI.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/gh/gabrieldoty/simplify-scorm@master/src/jsonFormatter.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/gh/gabrieldoty/simplify-scorm@master/src/scormAPI.js"></script>

<script>
  import { academySupabase, hasAcademySupabaseConfig, requireAuth } from '~/lib/academy';

  type JsonObject = Record<string, unknown>;
  type InitResponse = {
    sessionId?: string;
    resume?: JsonObject;
  };
  type PageState = 'complete' | 'current' | 'locked';

  const section = document.querySelector<HTMLElement>('section[data-course-id]');
  const feedback = document.getElementById('academy-player-feedback') as HTMLParagraphElement | null;
  const iframe = document.getElementById('academy-scorm-frame') as HTMLIFrameElement | null;
  const sidebarNav = document.getElementById('academy-sidebar-nav') as HTMLElement | null;
  const sidebarNavMobile = document.getElementById('academy-sidebar-nav-mobile') as HTMLElement | null;
  const progressFill = document.getElementById('academy-sidebar-progress-fill') as HTMLElement | null;
  const progressFillMobile = document.getElementById('academy-sidebar-progress-fill-mobile') as HTMLElement | null;
  const progressLabel = document.getElementById('academy-sidebar-progress-label') as HTMLElement | null;
  const progressLabelMobile = document.getElementById('academy-sidebar-progress-label-mobile') as HTMLElement | null;
  const breadcrumbModule = document.getElementById('academy-breadcrumb-module') as HTMLElement | null;
  const breadcrumbPage = document.getElementById('academy-breadcrumb-page') as HTMLElement | null;
  const pagePill = document.getElementById('academy-page-pill') as HTMLElement | null;
  const prevButton = document.getElementById('academy-prev-button') as HTMLButtonElement | null;
  const nextButton = document.getElementById('academy-next-button') as HTMLButtonElement | null;
  const sidebarOverlay = document.getElementById('academy-sidebar-overlay') as HTMLElement | null;
  const mobileMenuButton = document.getElementById('academy-mobile-menu-button') as HTMLButtonElement | null;
  const overlayCloseButton = document.getElementById('academy-overlay-close') as HTMLButtonElement | null;
  const courseCode = document.getElementById('academy-course-code') as HTMLElement | null;
  const courseCodeMobile = document.getElementById('academy-course-code-mobile') as HTMLElement | null;
  const courseTitle = document.getElementById('academy-course-title') as HTMLElement | null;
  const courseTitleMobile = document.getElementById('academy-course-title-mobile') as HTMLElement | null;

  if (!section || !iframe || !sidebarNav || !sidebarNavMobile || !prevButton || !nextButton) {
    throw new Error('Course player root not found');
  }

  const courseId = section.getAttribute('data-course-id') || '';
  const contentPath = section.getAttribute('data-content-path') || '';

  const scormDebug =
    typeof window !== 'undefined' && new URLSearchParams(window.location.search).get('scorm_debug') === '1';

  const postJson = async <T,>(url: string, body: unknown): Promise<T> => {
    const res = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify(body),
    });
    const text = await res.text();
    let data: unknown = null;
    try {
      data = text ? JSON.parse(text) : null;
    } catch {
      data = null;
    }
    if (!res.ok) {
      const msg =
        data && typeof data === 'object' && data !== null && 'error' in data
          ? String(data.error)
          : text || res.statusText;
      throw new Error(msg);
    }
    return data as T;
  };

  const syncPlayerViewportHeight = () => {
    const siteHeader = document.querySelector('header');
    const headerHeight = siteHeader instanceof HTMLElement ? siteHeader.offsetHeight : 0;
    section.style.setProperty('--academy-header-height', `${headerHeight}px`);
    const pageMain = section.closest('main');
    if (pageMain instanceof HTMLElement) {
      pageMain.style.margin = '0';
      pageMain.style.padding = '0';
      pageMain.style.maxWidth = 'none';
      pageMain.style.width = '100%';
    }
  };
  syncPlayerViewportHeight();
  window.addEventListener('resize', syncPlayerViewportHeight);

  const pageCountByCourseId = {
    'ai-foundations': 7,
    'copilot-workflows': 7,
    'agentic-automation': 7,
  };

  const courseMetaById: Record<string, { code: string; title: string; module: string; pages: string[] }> = {
    'ai-foundations': {
      code: 'W1 - AI FOUNDATIONS',
      title: 'AI Foundations & Responsible Use',
      module: 'Module 1',
      pages: [
        'You already use AI',
        'How AI actually works',
        'The AI use hierarchy',
        'Responsible use principles',
        'Green/amber/red decisions',
        'Your first AI task',
        'Reflection and next steps',
      ],
    },
    'copilot-workflows': {
      code: 'W2 - COPILOT WORKFLOWS',
      title: 'Copilot Workflows',
      module: 'Copilot Workflows',
      pages: [
        'Workflow overview',
        'Role-based setup',
        'Prompt chains',
        'Knowledge grounding',
        'Quality checks',
        'Team rollout',
        'Review and recap',
      ],
    },
    'agentic-automation': {
      code: 'W3 - AGENTIC AUTOMATION',
      title: 'Agentic Automation',
      module: 'Agentic Automation',
      pages: [
        'Automation fundamentals',
        'Agent boundaries',
        'Tool calling patterns',
        'Human-in-the-loop design',
        'Observability basics',
        'Common pitfalls',
        'Final checklist',
      ],
    },
  };

  const fallbackPageCount = pageCountByCourseId[courseId] ?? 7;
  const fallbackTitles = Array.from({ length: fallbackPageCount }, (_, idx) => `Page ${idx + 1}`);
  const courseMeta: { code: string; title: string; module: string; pages: string[] } = courseMetaById[courseId] ?? {
    code: 'W1 - COURSE',
    title: courseId || 'Course player',
    module: courseId || 'Course module',
    pages: fallbackTitles,
  };

  const totalPages = Math.max(1, courseMeta.pages.length);
  let currentPageIndex = 0;

  const parsePageIndexFromUrl = (value: string | null | undefined): number | null => {
    if (!value) return null;
    const match = String(value).match(/page_(\d+)\.html/i);
    if (!match) return null;
    const parsed = Number(match[1]);
    return Number.isInteger(parsed) ? parsed : null;
  };

  const setFeedback = (message: string, isError: boolean = true): void => {
    if (!feedback) return;
    feedback.textContent = message;
    feedback.className = isError
      ? 'academy-player-feedback academy-player-feedback-error'
      : 'academy-player-feedback academy-player-feedback-success';
  };

  const setOverlayOpen = (isOpen: boolean): void => {
    if (!sidebarOverlay || !mobileMenuButton) return;
    sidebarOverlay.hidden = !isOpen;
    mobileMenuButton.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  };

  const closeOverlay = () => setOverlayOpen(false);

  const getCompletionCount = () => currentPageIndex;

  const updateHeaderText = () => {
    const currentPageNumber = currentPageIndex + 1;
    const pageTitle = courseMeta.pages[currentPageIndex] ?? `Page ${currentPageNumber}`;
    if (breadcrumbModule) breadcrumbModule.textContent = courseMeta.module;
    if (breadcrumbPage) breadcrumbPage.textContent = pageTitle;
    if (pagePill) pagePill.textContent = `Page ${currentPageNumber} of ${totalPages}`;
  };

  const updateProgress = () => {
    const completed = Math.min(totalPages, Math.max(0, getCompletionCount()));
    const progressPercent = Math.round((completed / totalPages) * 100);
    const progressText = `${completed} of ${totalPages} pages complete`;
    if (progressLabel) progressLabel.textContent = progressText;
    if (progressLabelMobile) progressLabelMobile.textContent = progressText;
    if (progressFill) progressFill.style.width = `${progressPercent}%`;
    if (progressFillMobile) progressFillMobile.style.width = `${progressPercent}%`;
  };

  const getPageState = (index: number): PageState => {
    if (index < currentPageIndex) return 'complete';
    if (index === currentPageIndex) return 'current';
    return 'locked';
  };

  const goToPage = (index: number): void => {
    if (index < 0 || index >= totalPages) return;
    currentPageIndex = index;
    iframe.src = `/courses/${contentPath}/content/page_${index}.html`;
    updateUI();
    closeOverlay();
  };

  const renderNav = (targetNav: HTMLElement): void => {
    const navHtml = courseMeta.pages
      .map((title, index) => {
        const state = getPageState(index);
        const isCurrent = state === 'current';
        const markerText = state === 'complete' ? '&#10003;' : String(index + 1);
        return `
          <button
            class="academy-nav-item academy-nav-item-${state}"
            data-page-index="${index}"
            type="button"
            ${isCurrent ? 'aria-current="page"' : ''}
          >
            <span class="academy-nav-circle">${markerText}</span>
            <span class="academy-nav-title" style="font-size: 15px !important">${title}</span>
          </button>
        `;
      })
      .join('');
    targetNav.innerHTML = navHtml;
  };

  const bindNavHandlers = (targetNav: HTMLElement): void => {
    targetNav.querySelectorAll<HTMLElement>('[data-page-index]').forEach((item) => {
      item.addEventListener('click', () => {
        const pageIndex = Number(item.getAttribute('data-page-index'));
        goToPage(pageIndex);
      });
    });
  };

  const updateButtons = () => {
    const isFirstPage = currentPageIndex === 0;
    const isLastPage = currentPageIndex >= totalPages - 1;
    prevButton.disabled = isFirstPage;
    nextButton.disabled = isLastPage;
  };

  const updateUI = () => {
    renderNav(sidebarNav);
    renderNav(sidebarNavMobile);
    bindNavHandlers(sidebarNav);
    bindNavHandlers(sidebarNavMobile);
    updateHeaderText();
    updateButtons();
    updateProgress();
  };

  const syncCurrentPageFromIframe = () => {
    const directSrcIndex = parsePageIndexFromUrl(iframe.getAttribute('src') || iframe.src);
    let frameLocationIndex: number | null = null;
    try {
      frameLocationIndex = parsePageIndexFromUrl(iframe.contentWindow?.location?.pathname || '');
    } catch {
      frameLocationIndex = null;
    }
    const resolvedIndex = frameLocationIndex ?? directSrcIndex;
    if (resolvedIndex == null || resolvedIndex < 0 || resolvedIndex >= totalPages) return;
    if (resolvedIndex !== currentPageIndex) {
      currentPageIndex = resolvedIndex;
      updateUI();
    }
  };

  if (courseCode) courseCode.textContent = courseMeta.code;
  if (courseCodeMobile) courseCodeMobile.textContent = courseMeta.code;
  if (courseTitle) courseTitle.textContent = courseMeta.title;
  if (courseTitleMobile) courseTitleMobile.textContent = courseMeta.title;
  updateUI();

  prevButton.addEventListener('click', () => {
    goToPage(currentPageIndex - 1);
  });

  nextButton.addEventListener('click', () => {
    goToPage(currentPageIndex + 1);
  });

  iframe.addEventListener('load', () => {
    syncCurrentPageFromIframe();
  });

  mobileMenuButton?.addEventListener('click', () => {
    setOverlayOpen(true);
  });
  overlayCloseButton?.addEventListener('click', closeOverlay);
  sidebarOverlay?.addEventListener('click', (event) => {
    if (event.target === sidebarOverlay) closeOverlay();
  });

  if (!hasAcademySupabaseConfig || !academySupabase) {
    setFeedback('Course player is unavailable. Missing Supabase configuration.');
  } else if (!courseId) {
    setFeedback('Course not found.');
  } else {
    const authState = await requireAuth('/academy/login/');
    const user = authState?.user;

    if (user) {
      let sessionId = '';

      try {
        const init = await postJson<InitResponse>('/api/scorm/initialize/', { courseId });
        sessionId = typeof init.sessionId === 'string' ? init.sessionId : '';
        const resume = init.resume && typeof init.resume === 'object' ? init.resume : {};

        if (!sessionId) {
          throw new Error('Missing session from server.');
        }

        if (window.API && typeof window.API.loadFromJSON === 'function') {
          window.API.loadFromJSON(resume);
        }

        const basePath = `/courses/${contentPath}/content/`;
        let startIndex = 0;
        if (window.API?.cmi?.core?.lesson_location != null && window.API?.cmi?.core?.lesson_location !== '') {
          const lessonLocation = Number(window.API.cmi.core.lesson_location);
          if (Number.isInteger(lessonLocation) && lessonLocation >= 0 && lessonLocation < totalPages) {
            startIndex = lessonLocation;
          }
        }
        currentPageIndex = startIndex;
        iframe.src = `${basePath}page_${startIndex}.html`;
        updateUI();
      } catch (caught) {
        const message = caught instanceof Error ? caught.message : 'Could not start course session.';
        setFeedback(message);
      }

      const persistProgress = async () => {
        if (!sessionId) return;
        if (!window.API || !window.API.cmi || typeof window.API.cmi.toJSON !== 'function') return;

        const cmi = window.API.cmi.toJSON();

        try {
          await postJson('/api/scorm/commit/', { sessionId, cmi });
        } catch {
          setFeedback('Progress save failed. Your latest state may not be synced.');
        }
      };

      const finishSession = async () => {
        if (!sessionId) return;
        try {
          await postJson('/api/scorm/finish/', { sessionId });
        } catch {
          setFeedback('Could not mark the session complete.');
        }
      };

      let saveTimer: number | null = null;
      const queueSave = () => {
        if (saveTimer) window.clearTimeout(saveTimer);
        saveTimer = window.setTimeout(() => {
          void persistProgress();
        }, 300);
      };

      if (sessionId && window.API && typeof window.API.on === 'function') {
        window.API.on('LMSSetValue', () => {
          if (scormDebug && window.API?.cmi?.toJSON) {
            console.debug('[scorm_debug]', window.API.cmi.toJSON());
          }
          const location = Number(window.API?.cmi?.core?.lesson_location);
          if (Number.isInteger(location) && location >= 0 && location < totalPages) {
            currentPageIndex = location;
            updateUI();
          }
          queueSave();
        });
        window.API.on('LMSCommit', () => {
          queueSave();
        });
        window.API.on('LMSFinish', () => {
          void (async () => {
            await persistProgress();
            await finishSession();
          })();
        });
      }

      if (sessionId) {
        window.addEventListener('beforeunload', () => {
          void persistProgress();
        });
      }
    }
  }
</script>

<style is:global>
  .academy-player-page {
    --academy-header-height: 88px;
    width: 100%;
    max-width: none;
    margin: 0;
    padding: 0;
    height: calc(100vh - var(--academy-header-height));
    min-height: calc(100vh - var(--academy-header-height));
    background: #f4f5f7;
    overflow: hidden;
  }

  .academy-player-shell {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 0;
    width: 100%;
    max-width: none;
    height: 100%;
    margin: 0;
    min-height: 0;
    border-radius: 0;
    overflow: hidden;
    border: none;
    background: #ffffff;
    box-shadow: none;
  }

  .academy-sidebar {
    display: flex;
    flex-direction: column;
    height: 100%;
    width: 280px;
    min-width: 280px;
    background: #015887;
    color: #ffffff;
  }

  .academy-sidebar-header {
    padding: 20px 18px;
    border-bottom: 1px solid rgb(255 255 255 / 0.08);
    flex-shrink: 0;
  }

  .academy-course-code {
    margin: 0;
    font-family: 'Work Sans', sans-serif;
    color: #86bfe2;
    font-size: 12px;
    line-height: 1.2;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .academy-course-title {
    margin: 10px 0 12px;
    font-family: 'Work Sans', sans-serif;
    font-size: 17px;
    line-height: 1.35;
    color: #ffffff;
    font-weight: 700;
  }

  .academy-sidebar-progress-track {
    width: 100%;
    height: 3px;
    border-radius: 2px;
    background: rgb(255 255 255 / 0.15);
  }

  .academy-sidebar-progress-fill {
    width: 0;
    height: 100%;
    border-radius: 2px;
    background: #ff7700;
  }

  .academy-sidebar-progress-label {
    margin: 8px 0 0;
    font-size: 13px;
    color: rgb(255 255 255 / 0.5);
    font-family: 'Ubuntu', sans-serif;
  }

  .academy-sidebar-nav {
    flex: 1;
    overflow: visible;
    padding: 6px 0;
  }

  .academy-nav-item {
    width: 100%;
    border: none;
    border-left: 3px solid transparent;
    background: transparent;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 18px;
    text-align: left;
    cursor: pointer;
    transition: background-color 0.15s ease;
  }

  .academy-nav-item:hover:not(:disabled) {
    background: rgb(255 255 255 / 0.05);
  }

  .academy-nav-item:disabled {
    cursor: not-allowed;
  }

  .academy-nav-circle {
    width: 28px;
    min-width: 28px;
    height: 28px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-family: 'Ubuntu', sans-serif;
    color: rgb(255 255 255 / 0.45);
    border: 1.5px solid rgb(255 255 255 / 0.2);
    line-height: 1;
  }

  .academy-nav-title {
    font-family: 'Ubuntu', sans-serif;
    font-size: 15px;
    line-height: 1.4;
  }

  .academy-nav-item-current {
    border-left-color: #ff7700;
    background: rgb(255 119 0 / 0.15);
  }

  .academy-nav-item-current .academy-nav-circle {
    background: transparent;
    border: 1.5px solid #ff7700;
