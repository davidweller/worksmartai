---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Button from '~/components/ui/Button.astro';

const metadata = {
  title: 'Login - WorkSmart-AI',
  description: 'Sign in to your WorkSmart-AI account.',
  canonical: '/login/',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Account"
    title="Login"
    subtitle="Sign in with the email and password for your WorkSmart-AI account."
  />
  <section class="bg-section px-6 pb-16 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-md">
      <div class="rounded-2xl bg-card p-6 shadow-card ring-1 ring-border sm:p-8">
        <form id="login-form" class="space-y-6" method="post" action="#">
          <div>
            <label for="login-email" class="block text-sm font-medium">Email</label>
            <input
              id="login-email"
              name="email"
              type="email"
              autocomplete="email"
              required
              class="mt-1 py-3 px-4 block w-full text-md rounded-lg border border-default bg-card text-default focus:outline-none focus:ring-2 focus:ring-focus"
            />
          </div>
          <div>
            <label for="login-password" class="block text-sm font-medium">Password</label>
            <input
              id="login-password"
              name="password"
              type="password"
              autocomplete="current-password"
              required
              class="mt-1 py-3 px-4 block w-full text-md rounded-lg border border-default bg-card text-default focus:outline-none focus:ring-2 focus:ring-focus"
            />
          </div>
          <div>
            <Button variant="primary" type="submit" text="Sign in" class="w-full" />
          </div>
        </form>
        <p class="mt-6 text-center text-sm text-muted">
          Need help? <a class="text-primary underline hover:no-underline" href="/contact-us/">Contact us</a>.
        </p>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('login-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
  });
</script>
