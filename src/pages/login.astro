---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Button from '~/components/ui/Button.astro';

const metadata = {
  title: 'Sign In to Your WorkSmart-AI Training Account Online',
  description:
    'Sign in to your WorkSmart-AI account to access training resources, support materials and learning content for your organisation and team securely online.',
  canonical: '/login/',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Account"
    title="Login"
    subtitle="Sign in with the email and password for your WorkSmart-AI account."
  />
  <section class="bg-section px-6 pb-16 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-md">
      <div class="rounded-2xl bg-card p-6 shadow-card ring-1 ring-border sm:p-8">
        <form id="login-form" class="space-y-6" method="post" action="#">
          <div>
            <label for="login-email" class="block text-sm font-medium">Email</label>
            <input
              id="login-email"
              name="email"
              type="email"
              autocomplete="email"
              required
              class="mt-1 py-3 px-4 block w-full text-md rounded-lg border border-default bg-card text-default focus:outline-none focus:ring-2 focus:ring-focus"
            />
          </div>
          <div>
            <label for="login-password" class="block text-sm font-medium">Password</label>
            <input
              id="login-password"
              name="password"
              type="password"
              autocomplete="current-password"
              required
              class="mt-1 py-3 px-4 block w-full text-md rounded-lg border border-default bg-card text-default focus:outline-none focus:ring-2 focus:ring-focus"
            />
          </div>
          <div>
            <Button variant="primary" type="submit" text="Sign in" class="w-full" />
          </div>
        </form>
        <p class="mt-6 text-center text-sm text-muted">
          Need help? <a class="text-primary underline hover:no-underline" href="/contact-us/">Contact us</a>.
        </p>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { academySupabase, hasAcademySupabaseConfig } from '~/lib/academy';

  const form = document.getElementById('login-form');
  if (!(form instanceof HTMLFormElement)) {
    throw new Error('Login form not found');
  }

  const feedback = document.createElement('p');
  feedback.className = 'mt-4 hidden rounded-lg px-3 py-2 text-sm';
  feedback.setAttribute('role', 'alert');
  form.appendChild(feedback);

  const setFeedback = (message, isError = true) => {
    feedback.textContent = message;
    feedback.className = isError
      ? 'mt-4 rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800'
      : 'mt-4 rounded-lg border border-green-200 bg-green-50 px-3 py-2 text-sm text-green-800';
  };

  if (!hasAcademySupabaseConfig || !academySupabase) {
    setFeedback('Login is unavailable right now. Please contact support.');
  } else {
    const { data: sessionData, error: sessionError } = await academySupabase.auth.getSession();
    if (!sessionError && sessionData.session?.user) {
      window.location.replace('/academy/dashboard/');
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitButton = form.querySelector('button[type="submit"]');
      const formData = new FormData(form);
      const email = String(formData.get('email') || '').trim();
      const password = String(formData.get('password') || '');

      if (!email || !password) {
        setFeedback('Please provide both email and password.');
        return;
      }

      if (submitButton instanceof HTMLButtonElement) submitButton.disabled = true;
      feedback.className = 'hidden';

      try {
        const { error } = await academySupabase.auth.signInWithPassword({ email, password });
        if (error) {
          setFeedback(error.message || 'Login failed. Please check your credentials.');
          return;
        }

        setFeedback('Login successful. Redirecting...', false);
        window.location.replace('/academy/dashboard/');
      } catch (caughtError) {
        const message = caughtError instanceof Error ? caughtError.message : 'Unexpected login error.';
        setFeedback(`Login failed: ${message}`);
      } finally {
        if (submitButton instanceof HTMLButtonElement) submitButton.disabled = false;
      }
    });
  }
</script>
