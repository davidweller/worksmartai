---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Note from '~/components/widgets/Note.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { BOOK_A_CALL_URL } from '~/config/booking';

const metadata = {
  title: 'How the AI ROI Calculator Works for Teams | WorkSmart-AI',
  description:
    'See the research, formulas and assumptions behind the WorkSmart-AI calculator, from salary costs to productivity uplift and capacity created over time.',
  canonical: '/how-our-calculator-works/',
};

const modes = [
  {
    title: 'Standard Calculator',
    description: 'A quick, directional estimate for your whole department.',
    icon: 'tabler:calculator',
  },
  {
    title: 'Advanced Calculator',
    description: 'An optional detailed model that accounts for different academic and professional service roles.',
    icon: 'tabler:table-options',
  },
];

const standardItems = [
  {
    title: 'What it shows',
    description:
      'Annual savings (£), productivity increase (%), capacity created (FTEs), and five-year projection (£).',
  },
  {
    title: 'How it works',
    description:
      'You enter number of employees, average annual salary including typical on-costs such as NI and pensions, and target AI adoption level - basic, intermediate, or advanced.',
  },
  {
    title: 'Core assumptions',
    description:
      '1 FTE = 37.5 hours per week × 46 working weeks; on-cost factor is 1.25 × salary; AI-eligible tasks are around 50-55% of total workload; productivity uplift is 5-15% faster completion of eligible tasks depending on adoption level.',
  },
];

const advancedItems = [
  {
    title: 'What it adds',
    description:
      'The advanced calculator allows you to enter headcounts for different academic and professional service roles for a more precise result.',
  },
  {
    title: 'AI-eligible task share',
    description:
      "This is the proportion of a person's job made up of activities that AI can assist with directly, such as drafting or summarising text, writing communications or reports, preparing teaching materials, reviewing or analysing data and feedback, searching, referencing, collating information, and formatting or structuring content.",
  },
  {
    title: 'What it excludes',
    description:
      'It does not include work that requires in-person teaching, decision-making, or practical delivery that AI cannot (yet) perform reliably.',
  },
];

const kpis = [
  {
    title: 'Annual cost savings (£)',
    description: 'Annual savings = Number of staff × Average loaded salary × Productivity improvement.',
    icon: 'tabler:currency-pound',
  },
  {
    title: 'Productivity increase (%)',
    description: 'Productivity increase = Eligible work × Adoption rate × Efficiency gain.',
    icon: 'tabler:trending-up',
  },
  {
    title: 'Capacity created (FTEs)',
    description: 'Capacity created = Number of staff × Productivity increase.',
    icon: 'tabler:users-plus',
  },
  {
    title: 'Five-year projection (£)',
    description: 'Five-year savings = Annual savings × 5, or compounded annually if growth is added.',
    icon: 'tabler:calendar-stats',
  },
];

const roleRows = [
  [
    'Educators',
    'Teaching and learning',
    '55%',
    'Lesson prep, resource creation, and feedback benefit strongly from AI support.',
  ],
  [
    'Researchers',
    'Research staff, postdocs',
    '50%',
    'Literature review, summarising, and drafting papers show measurable gains.',
  ],
  [
    'Educator-Researchers',
    'Combined teaching and research roles',
    '53%',
    'Balanced mix of academic and administrative tasks.',
  ],
  [
    'Library & Learning Resources',
    'Librarians, learning developers',
    '50%',
    'Metadata, summarisation, and research assistance tasks are moderately AI-amenable.',
  ],
];

const adoptionRows = [
  ['Basic', '35%', '8% faster completion', '0.55 × 0.35 × 0.08 = 1.5% overall'],
  ['Intermediate', '60%', '12% faster completion', '0.55 × 0.60 × 0.12 = 4.0% overall'],
  ['Advanced', '80%', '15% faster completion', '0.55 × 0.80 × 0.15 = 6.6% overall'],
];

const evidenceRows = [
  [
    'Productivity uplift (5-15%)',
    'Bick et al. (2025); OECD / Filippucci et al. (2025); Brynjolfsson, Li and Raymond (2025).',
  ],
  ['Adoption levels (35-80%)', 'BCG (2025); McKinsey (2025).'],
  ['Task eligibility (~50%)', 'Henseke et al. (2025); McKinsey (2025).'],
  ['Higher education adoption', 'Microsoft (2025); HEPI / Freeman (2025); UNESCO (2023).'],
  ['Cost avoidance and back-office efficiency', 'Dell\u2019Acqua et al. (2023, Harvard / Wharton / BCG).'],
  ['Error reduction and quality control', 'Dell\u2019Acqua et al. (2023); PwC (2024).'],
  ['Salary and working patterns', 'ONS ASHE (2024).'],
];
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Savings Calculator"
    title="How our Calculator Works"
    subtitle="Understanding how we estimate your potential savings and capacity uplift"
  />
  <Note
    title="Evidence-led estimates"
    description=" The WorkSmart-AI Savings Calculator uses peer-reviewed and public research to estimate how much time, cost, and capacity your organisation could reclaim through staff training on AI."
  />
  <Features2
    title="The calculator has two modes"
    subtitle="Both are grounded in real evidence on productivity, task automation, and adoption patterns in higher education."
    columns={2}
    items={modes}
  />
  <Steps
    title="1. The Standard Calculator"
    subtitle="A quick, directional estimate for your whole department."
    items={standardItems}
  />
  <Steps
    title="2. The Advanced Calculator"
    subtitle="A more precise model that accounts for different academic and professional service roles."
    items={advancedItems}
    isReversed
  />

  <section class="bg-section px-6 py-16 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-6xl space-y-10">
      <div class="rounded-2xl bg-card p-6 shadow-card ring-1 ring-border sm:p-8">
        <h2 class="font-heading text-3xl font-bold text-heading">Role categories and data foundations</h2>
        <p class="mt-4 text-muted">
          When you enter counts for these roles, the calculator replaces the single headcount figure and weights savings
          by role type, producing a blended productivity and capacity estimate.
        </p>
        <div class="mt-6 overflow-x-auto">
          <table class="w-full min-w-[760px] text-left text-base">
            <thead class="bg-brand text-white"
              ><tr
                ><th class="px-4 py-3">Role type</th><th class="px-4 py-3">Example departments or functions</th><th
                  class="px-4 py-3">Typical AI-eligible task share</th
                ><th class="px-4 py-3">Rationale</th></tr
              ></thead
            ><tbody
              >{
                roleRows.map((row) => (
                  <tr class="border-t border-default">
                    <>
                      <td class="px-4 py-3 font-semibold">{row[0]}</td>
                      <td class="px-4 py-3">{row[1]}</td>
                      <td class="px-4 py-3">{row[2]}</td>
                      <td class="px-4 py-3">{row[3]}</td>
                    </>
                  </tr>
                ))
              }</tbody
            >
          </table>
        </div>
      </div>
      <div class="rounded-2xl bg-card p-6 shadow-card ring-1 ring-border sm:p-8">
        <h2 id="adoption" class="font-heading text-3xl font-bold text-heading">
          3. Understanding Target Adoption Level
        </h2>
        <p class="mt-4 text-muted">
          The Target Adoption Level shows how widely and confidently staff are expected to use AI tools in their
          everyday work. It captures both reach (how many people use AI) and depth (how effectively they use it). High
          adoption doesn't just mean more licences - it means AI is built into daily workflows.
        </p>
        <div class="mt-6 overflow-x-auto">
          <table class="w-full min-w-[760px] text-left text-base">
            <thead class="bg-brand text-white"
              ><tr
                ><th class="px-4 py-3">Adoption level</th><th class="px-4 py-3">Approximate adoption rate</th><th
                  class="px-4 py-3">Typical efficiency uplift</th
                ><th class="px-4 py-3">Example overall productivity gain</th></tr
              ></thead
            ><tbody
              >{
                adoptionRows.map((row) => (
                  <tr class="border-t border-default">
                    <>
                      <td class="px-4 py-3 font-semibold">{row[0]}</td>
                      <td class="px-4 py-3">{row[1]}</td>
                      <td class="px-4 py-3">{row[2]}</td>
                      <td class="px-4 py-3">{row[3]}</td>
                    </>
                  </tr>
                ))
              }</tbody
            >
          </table>
        </div>
      </div>
    </div>
  </section>

  <Features2
    title="4. KPIs and how the calculator works them out"
    subtitle="The calculator produces four key results."
    columns={4}
    items={kpis}
  />

  <section class="bg-page px-6 py-16 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-5xl rounded-2xl bg-card p-6 ring-1 ring-border shadow-card sm:p-8">
      <h2 class="font-heading text-3xl font-bold text-heading">Worked example</h2>
      <p class="mt-4 text-muted">
        Using 12% efficiency on eligible tasks, 60% adoption rate, 55% eligible task share, 60 staff, £45,000 average
        salary, and an on-cost factor of 1.25:
      </p>
      <p class="mt-4 rounded-xl bg-elevated p-5 font-semibold text-heading">
        Productivity improvement = 0.55 × 0.60 × 0.12 = 3.96% (rounded to 4%)<br />Annual cost savings = 60 × (£45,000 ×
        1.25) × 0.0396 = £133,650<br />Capacity created = 60 × 0.0396 = 2.4 FTEs<br />Five-year projection = £133,650 ×
        5 = £668,250
      </p>
    </div>
  </section>

  <section class="bg-section px-6 py-16 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-5xl rounded-2xl bg-card p-6 shadow-card ring-1 ring-border sm:p-8">
      <h2 class="font-heading text-3xl font-bold text-heading">5. Data and Evidence Sources</h2>
      <div class="mt-6 overflow-x-auto">
        <table class="w-full min-w-[640px] text-left text-base">
          <thead class="bg-brand text-white"
            ><tr><th class="px-4 py-3">Area</th><th class="px-4 py-3">Evidence base</th></tr></thead
          ><tbody
            >{
              evidenceRows.map((row) => (
                <tr class="border-t border-default">
                  <>
                    <td class="px-4 py-3 font-semibold">{row[0]}</td>
                    <td class="px-4 py-3">{row[1]}</td>
                  </>
                </tr>
              ))
            }</tbody
          >
        </table>
      </div>
    </div>
  </section>

  <section class="bg-page px-6 py-16 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-5xl rounded-2xl bg-card p-6 ring-1 ring-border shadow-card sm:p-8">
      <h2 class="font-heading text-3xl font-bold text-heading">References</h2>
      <ul class="mt-6 space-y-4 text-base text-muted list-none">
        <li>
          Bick, A., Blandin, A. and Deming, D.J. (2025) The Rapid Adoption of Generative AI. Federal Reserve Bank of St.
          Louis Working Paper 2024-027C (revised February 2025). Available at: <a
            href="https://www.stlouisfed.org/on-the-economy/2025/feb/impact-generative-ai-work-productivity"
            class="text-primary underline hover:no-underline"
            target="_blank"
            rel="noopener noreferrer">stlouisfed.org</a
          >
        </li>
        <li>
          Bick, A., Blandin, A. and Deming, D.J. (2025) The State of Generative AI Adoption in 2025. Federal Reserve
          Bank of St. Louis, On the Economy, 13 November 2025. Available at: <a
            href="https://www.stlouisfed.org/on-the-economy/2025/nov/state-generative-ai-adoption-2025"
            class="text-primary underline hover:no-underline"
            target="_blank"
            rel="noopener noreferrer">stlouisfed.org</a
          >
        </li>
        <li>
          Boston Consulting Group (2025) AI at Work 2025: Momentum Builds, But Gaps Remain. Third edition, June 2025.
          Available at: <a
            href="https://www.bcg.com/publications/2025/ai-at-work-momentum-builds-but-gaps-remain"
            class="text-primary underline hover:no-underline"
            target="_blank"
            rel="noopener noreferrer">bcg.com</a
          >
        </li>
        <li>
          Brynjolfsson, E., Li, D. and Raymond, L.R. (2025) 'Generative AI at Work', <em
            >The Quarterly Journal of Economics</em
          >, 140(2), pp. 889–942. Available at: <a
            href="https://academic.oup.com/qje/article/140/2/889/7990658"
            class="text-primary underline hover:no-underline"
            target="_blank"
            rel="noopener noreferrer">academic.oup.com</a
          >
        </li>
        <li>
          Dell'Acqua, F., McFowland III, E., Mollick, E.R., Lifshitz-Assaf, H., Kellogg, K., Rajendran, S., Krayer, L.,
          Candelon, F. and Lakhani, K.R. (2023) Navigating the Jagged Technological Frontier: Field Experimental
          Evidence of the Effects of AI on Knowledge Worker Productivity and Quality. Harvard Business School Working
          Paper No. 24-013. Available at: <a
            href="https://papers.ssrn.com/sol3/papers.cfm?abstract_id=4573321"
            class="text-primary underline hover:no-underline"
            target="_blank"
            rel="noopener noreferrer">ssrn.com</a
          >
        </li>
        <li>
          Filippucci, F., Gal, P., Laengle, K. and Schief, M. (2025) Opportunities and Risks of Artificial Intelligence
          for Productivity. OECD AI Papers. Available at: <a
            href="https://www.oecd.org/en/blogs/2025/07/unlocking-productivity-with-generative-ai-evidence-from-experimental-studies.html"
            class="text-primary underline hover:no-underline"
            target="_blank"
            rel="noopener noreferrer">oecd.org</a
          >
        </li>
        <li>
          Freeman, J. (2025) Student Generative AI Survey 2025. HEPI Policy Note 61. Higher Education Policy Institute,
          in partnership with Kortext. Available at: <a
            href="https://www.hepi.ac.uk/reports/student-generative-ai-survey-2025/"
            class="text-primary underline hover:no-underline"
            target="_blank"
            rel="noopener noreferrer">hepi.ac.uk</a
          >
        </li>
        <li>
          Henseke, G., Davies, R., Felstead, A. and Zhou, Y. (2025) How Exposed Are UK Jobs to Generative AI? Developing
          and Applying a Novel Task-Based Index. arXiv preprint 2507.22748. Available at: <a
            href="https://arxiv.org/abs/2507.22748"
            class="text-primary underline hover:no-underline"
            target="_blank"
            rel="noopener noreferrer">arxiv.org</a
          >
        </li>
        <li>
          McKinsey &amp; Company (2025) The State of AI in 2025: Agents, Innovation, and Transformation. November 2025.
          Available at: <a
            href="https://www.mckinsey.com/capabilities/quantumblack/our-insights/the-state-of-ai"
            class="text-primary underline hover:no-underline"
            target="_blank"
            rel="noopener noreferrer">mckinsey.com</a
          >
        </li>
        <li>
          Microsoft (2025) 2025 AI in Education Report. Available at: <a
            href="https://www.microsoft.com/en-us/education/blog/2025/08/ai-in-education-report-insights-to-support-teaching-and-learning/"
            class="text-primary underline hover:no-underline"
            target="_blank"
            rel="noopener noreferrer">microsoft.com</a
          >
        </li>
        <li>
          Office for National Statistics (2024) Employee Earnings in the UK: 2024. Annual Survey of Hours and Earnings
          statistical bulletin, 29 October 2024. Available at: <a
            href="https://www.ons.gov.uk/employmentandlabourmarket/peopleinwork/earningsandworkinghours/bulletins/annualsurveyofhoursandearnings/2024"
            class="text-primary underline hover:no-underline"
            target="_blank"
            rel="noopener noreferrer">ons.gov.uk</a
          >
        </li>
        <li>
          PwC (2024) 2024 Global AI Jobs Barometer. PricewaterhouseCoopers. Available at: <a
            href="https://www.pwc.com/gx/en/news-room/press-releases/2024/pwc-2024-global-ai-jobs-barometer.html"
            class="text-primary underline hover:no-underline"
            target="_blank"
            rel="noopener noreferrer">pwc.com</a
          >
        </li>
        <li>
          UNESCO (2023) Guidance for Generative AI in Education and Research. Authored by Miao, F. and Holmes, W. Paris:
          UNESCO. Available at: <a
            href="https://www.unesco.org/en/articles/guidance-generative-ai-education-and-research"
            class="text-primary underline hover:no-underline"
            target="_blank"
            rel="noopener noreferrer">unesco.org</a
          >
        </li>
      </ul>
    </div>
  </section>

  <Note
    title="Interpreting your results"
    description=" The calculator's figures are directional, not definitive. They illustrate the scale of potential benefit if AI is adopted effectively, supported by training and governance."
  />
  <CallToAction
    title="Ready to estimate your potential savings?"
    subtitle="Use the calculator or book a call to discuss what the figures could mean for your organisation."
    actions={[
      { variant: 'primary', text: 'Try the Calculator', href: '/#roi-calculator-home' },
      { text: 'Book a Call', href: BOOK_A_CALL_URL },
    ]}
  />
</Layout>
