const content =
  '<div class="container single-page-container">\n\t<div class="row">\n\t\t\t\t<div class="nv-single-page-wrap col">\n\t\t\t<div class="nv-page-title-wrap nv-big-title" >\n\t<div class="nv-page-title ">\n\t\t<small class="neve-breadcrumbs-wrapper"></small>\t\t<h1>Modern Slavery</h1>\n\t\t\t\t\t</div>\n</div> \n\t<div class="nv-content-wrap entry-content">\n<h3 class="wp-block-heading">Modern Slavery and Human Trafficking Statement</h3>\n\n\n\n<p>WorkSmart AI is committed to acting ethically and with integrity in all our business dealings and relationships. We oppose all forms of modern slavery and human trafficking and are committed to ensuring these practices do not occur in our operations or supply chains.</p>\n\n\n\n<h2 class="wp-block-heading">1. Our Business</h2>\n\n\n\n<p>WorkSmart AI provides AI skills training and consultancy services to organisations in education, public sector, and business. Our operations are primarily UK-based, and we do not manufacture or distribute physical goods. Our supply chain is therefore low risk in relation to modern slavery and human trafficking.</p>\n\n\n\n<h2 class="wp-block-heading">2. Our Commitment</h2>\n\n\n\n<p>We are committed to:</p>\n\n\n\n<ul class="wp-block-list">\n<li>Ensuring there is no modern slavery, forced labour, or human trafficking in any part of our business.</li>\n\n\n\n<li>Only working with suppliers, contractors, and partners who share our values and comply with relevant legislation.</li>\n\n\n\n<li>Acting transparently and responsibly in how we conduct business.</li>\n</ul>\n\n\n\n<h2 class="wp-block-heading">3. Supply Chains</h2>\n\n\n\n<p>Our supply chains mainly consist of:</p>\n\n\n\n<ul class="wp-block-list">\n<li>Professional service providers (training venues, IT, consultancy support).</li>\n\n\n\n<li>Technology platforms (cloud hosting, software providers).</li>\n</ul>\n\n\n\n<p>We assess these suppliers as low risk, but we remain vigilant.</p>\n\n\n\n<h2 class="wp-block-heading">4. Policies &amp; Practices</h2>\n\n\n\n<p>To reinforce our commitment:</p>\n\n\n\n<ul class="wp-block-list">\n<li>We have zero tolerance for slavery or human trafficking.</li>\n\n\n\n<li>We include ethical considerations in supplier selection.</li>\n\n\n\n<li>We encourage staff, partners, and clients to raise concerns about potential risks.</li>\n\n\n\n<li>We will take immediate action if any evidence of modern slavery is identified in our supply chain.</li>\n</ul>\n\n\n\n<h2 class="wp-block-heading">5. Training &amp; Awareness</h2>\n\n\n\n<p>While our team is small, we are committed to awareness-raising so all staff understand the risks of modern slavery and how to report concerns.</p>\n\n\n\n<h2 class="wp-block-heading">6. Reporting Concerns</h2>\n\n\n\n<p>Anyone working with WorkSmart AI who suspects modern slavery or unethical labour practices should report it directly to [Insert contact email]. We will investigate and act on all reports.</p>\n\n\n\n<h2 class="wp-block-heading">7. Approval</h2>\n\n\n\n<p>This statement has been approved by WorkSmart AI leadership and will be reviewed annually.</p>\n\n\n\n<p>📩 Contact: [Insert contact email]</p>\n\n\n\n<p></p>\n</div>\t\t</div>\n\t\t\t</div>\n</div>';
