{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/training", "destination": "/services/", "permanent": true },
    { "source": "/training/", "destination": "/services/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
