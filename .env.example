# Copy to .env and fill in. For production, set the same in your host (Vercel, Netlify, etc.)
# at *build* time so the static page can call Supabase.
#
# Use the Project URL and anon (public) key from Supabase: Project Settings -> API.
# The anon key is safe to embed in the site; do not use the service_role key in the browser.

PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
