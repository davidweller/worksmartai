# Copy to .env for local `npm run build` / `astro dev`.
# In GitHub Actions, set the same as repository secrets (used by .github/workflows/actions.yaml
# for the build job) so the static site embeds the public anon key in the lead form.
#
# Supabase: Project Settings -> API -> Project URL and anon (public) key.

PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
